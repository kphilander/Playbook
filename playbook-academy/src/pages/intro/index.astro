  <!-- Section observer for audio sync + progress tracking -->
  <script>
    // Sync audio player with scroll sections
    const sections = document.querySelectorAll('.intro-section');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const index = Array.from(sections).indexOf(entry.target as Element);
          if (index >= 0) {
            window.dispatchEvent(new CustomEvent('reveal-slide-changed', {
              detail: { indexh: index }
            }));
          }
        }
      });
    }, { threshold: 0.4 });

    sections.forEach((section) => observer.observe(section));

    // Listen for audio player section changes → scroll to section
    window.addEventListener('audio-slide-change', ((e: CustomEvent) => {
      const slideIndex = e.detail?.slideIndex ?? 0;
      const target = sections[slideIndex];
      if (target) {
        target.scrollIntoView({ behavior: 'smooth' });
      }
    }) as EventListener);

    // Mark intro as started
    const progress = JSON.parse(localStorage.getItem('playbook-academy-progress') || '{}');
    if (!progress['intro']) {
      progress['intro'] = { completed: false, quizScore: null, lastLesson: 0, timeSpent: 0, completedLessons: [] };
      localStorage.setItem('playbook-academy-progress', JSON.stringify(progress));
      window.dispatchEvent(new Event('progress-updated'));
    }

    // Mark complete when last section is visible
    const lastSection = sections[sections.length - 1];
    const completionObserver = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        const p = JSON.parse(localStorage.getItem('playbook-academy-progress') || '{}');
        p['intro'] = { ...p['intro'], completed: true, completedLessons: [] };
        localStorage.setItem('playbook-academy-progress', JSON.stringify(p));
        window.dispatchEvent(new Event('progress-updated'));
      }
    }, { threshold: 0.5 });
    if (lastSection) completionObserver.observe(lastSection);
  </script>

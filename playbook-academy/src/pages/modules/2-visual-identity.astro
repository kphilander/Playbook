---
import ModuleLayout from '../../layouts/ModuleLayout.astro';
import KnowledgeCheck from '../../components/KnowledgeCheck.tsx';
import KeyTakeaway from '../../components/KeyTakeaway.astro';
import KeyConcept from '../../components/KeyConcept.astro';
import TierToggle from '../../components/TierToggle.tsx';
import AccessibilityChecker from '../../components/AccessibilityChecker.tsx';
import Glossary from '../../components/Glossary.astro';
import GenerativeExercise from '../../components/GenerativeExercise.tsx';

const module = {
  id: '2-visual-identity',
  number: 2,
  title: 'Visual Identity & Design',
  duration: '20 min',
  lessons: [
    { title: 'Visual System Principles', slug: 'visual-system-principles' },
    { title: 'Tier 1 vs Tier 2 Visual Rules', slug: 'tier-visual-rules' },
    { title: 'Accessibility Requirements', slug: 'accessibility-requirements' },
  ],
};

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tracks = [
  { slideIndex: 0, src: `${base}/audio/modules/m4-visual-system-principles.mp3`, transcript: "Playbook's visual system uses three core colors. Navy, the primary brand color, conveys trust and authority. Teal is the accent for interactive elements, links, and calls to action. Bold orange brings energy to Tier 1 material, but disappears completely in Tier 2. The visual system is designed for maximum contrast and accessibility. Every color combination must meet WCAG double-A standards. The typography uses a heading font for hierarchy and a body font for readability. Icons follow a consistent line-weight style. The system is deliberately restrained. Visual noise is the enemy of player education." },
  { slideIndex: 1, src: `${base}/audio/modules/m4-tier-visual-rules.mp3`, transcript: "Tier 1 and Tier 2 use the same brand quality. The difference is restraint, not quality. Tier 1 gets the full visual system. Navy backgrounds, teal accents, bold orange highlights, playful iconography, and branded illustrations. This is where the personality lives. Tier 2 strips everything back. Orange disappears. Decorative elements disappear. The palette reduces to neutrals plus teal for essential actions. Layout goes single-column, maximum six-forty pixels wide. White space increases dramatically. And critically, Tier 2 always renders in light mode, even if the user has dark mode enabled. When someone needs help, every unnecessary visual element is friction." },
  { slideIndex: 2, src: `${base}/audio/modules/m4-accessibility-requirements.mp3`, transcript: "Accessibility isn't optional. It's the foundation of inclusive player education. Every layout must support keyboard navigation and screen readers. Color contrast ratios must meet WCAG double-A minimum. Four-point-five to one for body text, three to one for large text. Never use color alone to convey meaning. All images need descriptive alt text. Touch targets on mobile must be at least forty-four pixels. Interactive elements need visible focus indicators. And Tier 2 pages always render in light mode, because dark mode can feel isolating in crisis contexts. The goal is simple. Every player, regardless of ability, can access every piece of material." },
  { slideIndex: 3, src: `${base}/audio/modules/m4-knowledge-check.mp3`, transcript: "LuckyDraw Casino redesigned their responsible gambling page using the tier-based visual system. Before. Cluttered layout. Gray text on white with poor contrast. Decorative gambling imagery mixed with support information. Helpline buried at the bottom. Accessibility score: forty-seven out of one hundred. After. Clean layout with Tier 1 tools and literacy material using the full brand visual system. And a dedicated Tier 2 support section with stripped-back design. No orange, no decoration, maximum restraint. Accessibility score: ninety-four out of one hundred. The information was reorganized, not rewritten. Visual design did the heavy lifting." },
];

const questions = [
  {
    id: 'q1',
    question: 'What is the "visual quality rule" for Playbook content?',
    options: [
      'Playbook content should use a distinct, clinical aesthetic to differentiate it from commercial content',
      'Playbook content must match the production quality of the operator\'s commercial marketing',
      'Playbook content should be minimalist so it doesn\'t compete with the operator\'s brand',
      'Playbook content should follow government health communication design standards',
    ],
    correctIndex: 1,
    explanation: 'If the Playbook content looks generic, dated, or lower-quality than the promotional content around it, players will treat it like fine print. Design it like you\'d design a product launch — because that\'s what it is.',
    reviewSlug: 'visual-system-principles',
  },
  {
    id: 'q2',
    question: 'What is the "adaptive identity model"?',
    options: [
      'A system where Playbook looks identical across all operators',
      'A system where operators keep Playbook\'s structural identity (layout, hierarchy, icons) but apply their own colors and fonts',
      'A system that automatically changes based on the player\'s segment',
      'A system that uses AI to generate custom designs per market',
    ],
    correctIndex: 1,
    explanation: 'Operators customize colors and fonts to match their brand, but the structural elements — layout patterns, information hierarchy, icon system, spacing — stay consistent. A player who encounters Playbook content at one platform will recognize the structure at another.',
    reviewSlug: 'visual-system-principles',
  },
  {
    id: 'q3',
    question: 'How should Tier 2 (support/crisis) content differ visually from Tier 1?',
    options: [
      'Use red and warning colors throughout to signal urgency',
      'Make it visually sparse — no brand styling at all',
      'Same brand quality but strip back to essentials: clean layout, generous white space, maximum contrast, zero visual noise',
      'Use a completely different design system from Tier 1',
    ],
    correctIndex: 2,
    explanation: 'Tier 2 uses the same brand quality and design system but with maximum restraint: clean layout, generous white space, high contrast, no decoration. The goal is zero friction — nothing competes with the support information. And Tier 2 should always render in light mode, even if the user has dark mode enabled.',
    reviewSlug: 'tier-visual-rules',
  },
  {
    id: 'q4',
    question: 'What is the minimum contrast ratio for normal text under WCAG 2.1 AA?',
    options: [
      '2:1',
      '3:1',
      '4.5:1',
      '7:1',
    ],
    correctIndex: 2,
    explanation: '4.5:1 is the minimum for normal text (under 18px or under 14px bold). Large text needs 3:1. UI components and graphical objects need 3:1. These are non-negotiable — accessibility isn\'t a feature, it\'s a requirement.',
    reviewSlug: 'accessibility-requirements',
  },
  {
    id: 'q5',
    question: 'Why does Playbook use Source Code Pro for helpline numbers?',
    options: [
      'It looks more modern than other fonts',
      'It\'s the brand\'s primary font',
      'It disambiguates similar characters — 0/O and 1/l/I are visually distinct',
      'It\'s required by gambling regulators',
    ],
    correctIndex: 2,
    explanation: 'When someone is trying to call a helpline, confusing a 0 with an O or a 1 with an l could mean dialing the wrong number. Source Code Pro makes every character visually distinct. This is a functional design decision, not an aesthetic one.',
    reviewSlug: 'visual-system-principles',
  },
];
---

<ModuleLayout module={module} panelMode={true} tracks={tracks}>

  <!-- Module intro -->
  <div class="mb-8 p-5 rounded-xl bg-navy/5 border border-navy/10">
    <p class="text-sm text-navy font-heading mb-2">
      <strong>Visual Identity & Design</strong> — The adaptive identity model, Tier 1 vs Tier 2 visual rules, color system, typography, and accessibility requirements.
    </p>
    <p class="text-sm text-navy mb-3 font-heading"><strong>By the end of this module, you will be able to:</strong></p>
    <ul class="text-sm text-n700 mb-4 space-y-1.5 pl-4 list-disc">
      <li>Explain the adaptive identity model and how operators customize Playbook</li>
      <li>Apply Tier 1 and Tier 2 visual rules to any piece of player-facing content</li>
      <li>Verify WCAG 2.1 AA compliance for contrast, touch targets, and font choices</li>
    </ul>
    <button
      id="start-narration-btn"
      class="inline-flex items-center gap-2 px-4 py-2 bg-teal text-navy font-heading font-bold rounded-lg hover:bg-teal-light transition-colors text-sm"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      Play Audio Guide
    </button>
  </div>

  <script>
    document.getElementById('start-narration-btn')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('start-playback'));
    });
  </script>

  <!-- Lightbox for collateral images -->
  <script>
    document.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('.collateral-lightbox') as HTMLElement | null;
      if (!btn) return;
      const src = btn.dataset.src;
      const title = btn.dataset.title || '';
      if (!src) return;

      const overlay = document.createElement('div');
      overlay.className = 'fixed inset-0 z-[100] flex items-center justify-center p-6 bg-black/80 backdrop-blur-sm cursor-zoom-out';
      overlay.style.animation = 'fadeIn 0.2s ease-out';
      overlay.innerHTML = `
        <div class="relative max-w-3xl w-full">
          <img src="${src}" alt="${title}" class="w-full rounded-xl shadow-2xl" />
          ${title ? `<p class="text-center text-white/80 text-sm font-heading mt-3">${title}</p>` : ''}
          <button class="absolute -top-3 -right-3 w-8 h-8 rounded-full bg-navy text-white flex items-center justify-center hover:bg-navy-light transition-colors shadow-lg" aria-label="Close">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>
      `;
      overlay.addEventListener('click', (ev) => {
        if (ev.target === overlay || (ev.target as HTMLElement).closest('button[aria-label="Close"]')) {
          overlay.remove();
        }
      });
      document.addEventListener('keydown', function handler(ev) {
        if (ev.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', handler); }
      });
      document.body.appendChild(overlay);
    });
  </script>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- LESSON 1: Visual System Principles             -->
  <!-- ═══════════════════════════════════════════════ -->
  <section id="visual-system-principles" data-slide-index="0" data-lesson-slug="visual-system-principles" class="module-section py-16">
    <h2>Visual System Principles</h2>

    <p class="text-lg text-n600 mb-6">
      Most responsible gambling content looks like it was designed by a compliance department. Because it usually was. Playbook takes a different approach: player education content should be <strong>visually indistinguishable in quality</strong> from the operator's commercial content.
    </p>

    <blockquote>
      <p><strong>The visual quality rule:</strong> Playbook content must match the production quality of the operator's commercial marketing. If the Playbook content looks generic, players will treat it like fine print.</p>
    </blockquote>

    <div class="my-8 flex justify-center">
      <div class="rounded-xl bg-white border border-n100 shadow-sm px-10 py-8 inline-flex flex-col items-center gap-4">
        <svg width="200" height="46" viewBox="0 0 242 56" class="block">
          <text y="40" font-family="Inter, sans-serif" font-size="44" letter-spacing="-1.3">
            <tspan font-weight="800" fill="#1B2838">Play</tspan><tspan font-weight="300" letter-spacing="-1.0" fill="#1B2838">BOOK</tspan>
          </text>
        </svg>
        <p class="text-xs text-n500 font-heading">The typographic contrast — <strong class="text-navy">800 weight</strong> vs <span class="font-light text-navy">300 weight</span> — defines the entire visual system</p>
      </div>
    </div>

    <h3 id="the-adaptive-identity-model">The adaptive identity model</h3>

    <p>
      Playbook isn't a rigid visual system that every operator copies identically. It's an <strong>adaptive identity</strong> — operators keep their own colors and fonts, but the structural elements stay consistent:
    </p>

    <table>
      <thead>
        <tr>
          <th>What operators customize</th>
          <th>What stays consistent</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Color palette (primary, secondary, accent)</td>
          <td>Layout patterns and spacing</td>
        </tr>
        <tr>
          <td>Typography (heading + body fonts)</td>
          <td>Information hierarchy</td>
        </tr>
        <tr>
          <td>Logo and co-branding</td>
          <td>Icon system (dual stroke-weight)</td>
        </tr>
        <tr>
          <td>Photography style</td>
          <td>Component structure</td>
        </tr>
      </tbody>
    </table>

    <p>
      The result: a player who encounters Playbook-based content at one operator will intuitively recognize the content structure at another — even though they look different. It's recognizable without being identical.
    </p>

    <KeyConcept title="Adaptive Identity">
      <p>Operators customize colors and fonts to match their brand, but the structural elements — layout patterns, information hierarchy, icon system, spacing — stay consistent. A player who encounters Playbook content at one platform will recognize the structure at another.</p>
    </KeyConcept>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- LESSON 1b: Default Palette & Typography        -->
  <!-- ═══════════════════════════════════════════════ -->
  <section id="default-palette" data-slide-index="0" data-lesson-slug="visual-system-principles" class="module-section py-16">
    <h3 id="the-default-palette">The default palette</h3>

    <p>
      Playbook's default colors are chosen to feel like a lifestyle brand, not a health program:
    </p>

    <div class="grid grid-cols-3 gap-4 my-6">
      <div class="rounded-xl overflow-hidden shadow-sm border border-n100">
        <div class="h-20 bg-navy"></div>
        <div class="p-3 bg-white">
          <p class="font-heading font-bold text-navy text-sm">Deep Navy</p>
          <p class="font-mono text-xs text-n500">#1B2838</p>
          <p class="text-xs text-n500 mt-1">Primary — headers, backgrounds</p>
        </div>
      </div>
      <div class="rounded-xl overflow-hidden shadow-sm border border-n100">
        <div class="h-20 bg-teal"></div>
        <div class="p-3 bg-white">
          <p class="font-heading font-bold text-navy text-sm">Electric Teal</p>
          <p class="font-mono text-xs text-n500">#00D4AA</p>
          <p class="text-xs text-n500 mt-1">Secondary — interactive, highlights</p>
        </div>
      </div>
      <div class="rounded-xl overflow-hidden shadow-sm border border-n100">
        <div class="h-20 bg-orange"></div>
        <div class="p-3 bg-white">
          <p class="font-heading font-bold text-navy text-sm">Bold Orange</p>
          <p class="font-mono text-xs text-n500">#FF6B35</p>
          <p class="text-xs text-n500 mt-1">Accent — CTAs, attention</p>
        </div>
      </div>
    </div>

    <table>
      <thead>
        <tr>
          <th>Role</th>
          <th>Color</th>
          <th>Hex</th>
          <th>Usage</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Primary</strong></td>
          <td>Deep navy</td>
          <td>#1B2838</td>
          <td>Brand identity, headers, backgrounds — authority and sophistication</td>
        </tr>
        <tr>
          <td><strong>Secondary</strong></td>
          <td>Electric teal</td>
          <td>#00D4AA</td>
          <td>Interactive elements, highlights — energy and modernity</td>
        </tr>
        <tr>
          <td><strong>Accent</strong></td>
          <td>Bold orange</td>
          <td>#FF6B35</td>
          <td>CTAs, attention — action and urgency</td>
        </tr>
      </tbody>
    </table>

    <p>
      Plus a semantic palette that communicates specific states consistently:
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 my-6">
      <div class="rounded-lg overflow-hidden border border-n100 shadow-sm">
        <div class="h-10" style="background:#00C853"></div>
        <div class="p-2.5 bg-white">
          <p class="font-heading font-semibold text-sm text-navy">Success</p>
          <p class="font-mono text-xs text-n500">#00C853</p>
          <p class="text-xs text-n500">Quiz passed, limit set</p>
        </div>
      </div>
      <div class="rounded-lg overflow-hidden border border-n100 shadow-sm">
        <div class="h-10" style="background:#FFB300"></div>
        <div class="p-2.5 bg-white">
          <p class="font-heading font-semibold text-sm text-navy">Warning</p>
          <p class="font-mono text-xs text-n500">#FFB300</p>
          <p class="text-xs text-n500">Approaching limit</p>
        </div>
      </div>
      <div class="rounded-lg overflow-hidden border border-n100 shadow-sm">
        <div class="h-10" style="background:#FF3D00"></div>
        <div class="p-2.5 bg-white">
          <p class="font-heading font-semibold text-sm text-navy">Danger</p>
          <p class="font-mono text-xs text-n500">#FF3D00</p>
          <p class="text-xs text-n500">Tier 2 only — crisis</p>
        </div>
      </div>
      <div class="rounded-lg overflow-hidden border border-n100 shadow-sm">
        <div class="h-10" style="background:#2979FF"></div>
        <div class="p-2.5 bg-white">
          <p class="font-heading font-semibold text-sm text-navy">Info</p>
          <p class="font-mono text-xs text-n500">#2979FF</p>
          <p class="text-xs text-n500">Tips, explainers</p>
        </div>
      </div>
    </div>

    <KeyConcept title="Semantic Colors Are Functional">
      <p>When customizing the palette, keep the semantic colors (success/warning/danger/info) standard. Players learn these associations across products and platforms. Your brand colors express identity; semantic colors express function. Mixing the two creates confusion — a red CTA button next to a red danger alert loses its signal.</p>
    </KeyConcept>

    <h3 id="typography-system">Typography system</h3>

    <p>
      The type system uses three font families, each with a specific purpose:
    </p>

    <div class="grid gap-4 sm:grid-cols-3 my-6">
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-navy mb-1">Headings & UI</p>
        <p class="text-sm text-n600 mb-2"><strong>Inter</strong> (300-900)</p>
        <p class="text-sm text-n500">Headlines, section headers, quiz questions, CTAs, logo</p>
      </div>
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-navy mb-1">Body text</p>
        <p class="text-sm text-n600 mb-2"><strong>Source Sans 3</strong> (300-600)</p>
        <p class="text-sm text-n500">Paragraph text, descriptions, form labels</p>
      </div>
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-navy mb-1">Data & helplines</p>
        <p class="text-sm text-n600 mb-2"><strong>Source Code Pro</strong> (400-600)</p>
        <p class="text-sm text-n500">Helpline numbers, odds displays, RTP values, data</p>
      </div>
    </div>

    <p>
      <strong>Why Source Code Pro for helpline numbers?</strong> It disambiguates 0/O and 1/l/I. When someone is trying to reach a helpline, those distinctions can be the difference between getting help and dialing a wrong number. This is a functional choice, not an aesthetic one.
    </p>

    <h3 id="iconography-the-weight-contrast-system">Iconography: the weight-contrast system</h3>

    <p>
      The Playbook icon system mirrors the logo's typographic contrast — <strong>Play</strong> (800 weight) vs <strong>BOOK</strong> (300 weight) — through dual stroke weights:
    </p>

    <div class="list-card">
      <ul>
        <li><strong>Primary strokes (2px)</strong> — outer containers, main shapes, defining structure</li>
        <li><strong>Detail strokes (1px)</strong> — inner details, accents, secondary elements</li>
      </ul>
    </div>

    <div class="my-6 rounded-xl border border-n100 bg-white shadow-sm p-5">
      <p class="font-heading font-semibold text-navy text-sm mb-4">Playbook icon library — dual stroke-weight system</p>
      <div class="grid grid-cols-4 sm:grid-cols-8 gap-4">
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-lg bg-n50 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B2838" stroke-linecap="round" stroke-linejoin="round"><g stroke-width="2"><rect x="2" y="2" width="9" height="9" rx="1.5"/><rect x="13" y="13" width="9" height="9" rx="1.5"/></g><g stroke-width="1"><circle cx="6.5" cy="6.5" r="0.75" fill="#1B2838" stroke="none"/><circle cx="15.5" cy="15.5" r="0.75" fill="#1B2838" stroke="none"/><circle cx="19.5" cy="15.5" r="0.75" fill="#1B2838" stroke="none"/><circle cx="15.5" cy="19.5" r="0.75" fill="#1B2838" stroke="none"/><circle cx="19.5" cy="19.5" r="0.75" fill="#1B2838" stroke="none"/></g></svg>
          </div>
          <span class="text-xs text-n500">Dice</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-lg bg-n50 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B2838" stroke-linecap="round" stroke-linejoin="round"><g stroke-width="2"><rect x="3" y="5" width="7" height="15" rx="1.5"/><rect x="14" y="10" width="7" height="10" rx="1.5"/></g><g stroke-width="1"><line x1="2" y1="20" x2="22" y2="20"/><line x1="5" y1="9" x2="8" y2="9"/><line x1="5" y1="13" x2="8" y2="13"/><line x1="16" y1="14" x2="19" y2="14"/></g></svg>
          </div>
          <span class="text-xs text-n500">Edge</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-lg bg-n50 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B2838" stroke-linecap="round" stroke-linejoin="round"><g stroke-width="2"><circle cx="12" cy="12" r="9"/></g><g stroke-width="1"><path d="M9 9c0-1.7 1.3-3 3-3s3 1.3 3 3c0 2-3 2-3 4"/><circle cx="12" cy="17" r="0.5" fill="#1B2838" stroke="none"/></g></svg>
          </div>
          <span class="text-xs text-n500">Quiz</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-lg bg-n50 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B2838" stroke-linecap="round" stroke-linejoin="round"><g stroke-width="2"><path d="M3 8h4l6 8h4"/><path d="M3 16h4l6-8h4"/></g><g stroke-width="1"><polyline points="18 6 21 8 18 10"/><polyline points="18 14 21 16 18 18"/></g></svg>
          </div>
          <span class="text-xs text-n500">RNG</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-lg bg-n50 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B2838" stroke-linecap="round" stroke-linejoin="round"><g stroke-width="2"><circle cx="12" cy="12" r="9"/></g><g stroke-width="1"><line x1="12" y1="7" x2="12" y2="17"/><line x1="7" y1="12" x2="17" y2="12"/></g></svg>
          </div>
          <span class="text-xs text-n500">Help</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-lg bg-n50 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B2838" stroke-linecap="round" stroke-linejoin="round"><g stroke-width="2"><path d="M4 14v5a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-5"/></g><g stroke-width="1"><line x1="12" y1="3" x2="12" y2="15"/><polyline points="8 7 12 3 16 7"/></g></svg>
          </div>
          <span class="text-xs text-n500">Share</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-lg bg-n50 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B2838" stroke-linecap="round" stroke-linejoin="round"><g stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></g><g stroke-width="1"><polyline points="9 12 11 14 15 10"/></g></svg>
          </div>
          <span class="text-xs text-n500">Limit</span>
        </div>
        <div class="flex flex-col items-center gap-2">
          <div class="w-12 h-12 rounded-lg bg-n50 flex items-center justify-center">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#1B2838" stroke-linecap="round" stroke-linejoin="round"><g stroke-width="2"><circle cx="12" cy="12" r="9"/></g><g stroke-width="1"><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></g></svg>
          </div>
          <span class="text-xs text-n500">Warning</span>
        </div>

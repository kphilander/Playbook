---
import ModuleLayout from '../../layouts/ModuleLayout.astro';
import KnowledgeCheck from '../../components/KnowledgeCheck.tsx';
import KeyTakeaway from '../../components/KeyTakeaway.astro';
import Glossary from '../../components/Glossary.astro';
import TouchpointMap from '../../components/TouchpointMap.tsx';
import EscalationTimeline from '../../components/EscalationTimeline.tsx';
import GameGuidePreview from '../../components/GameGuidePreview.tsx';
import MythBrowser from '../../components/MythBrowser.tsx';
import GenerativeExercise from '../../components/GenerativeExercise.tsx';

const module = {
  id: '5-customer-journey',
  number: 5,
  title: 'Customer Journey',
  duration: '25 min',
  lessons: [
    { title: 'The Player Journey', slug: 'player-journey' },
    { title: 'Content & Campaigns', slug: 'content-and-campaigns' },
  ],
};

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tracks = [
  { slideIndex: 0, src: `${base}/audio/modules/m5-player-journey.mp3`, transcript: 'Playbook follows what we call a material escalation model. It starts with what every player actually wants, which is learning how to play, and builds toward what long-term regulars eventually need. Most players never reach the later stages. That is by design. There are five stages. At Awareness, the player has not signed up yet. Playbook appears as a companion brand alongside the product. It teaches how the game works. Odds, rules, what the numbers mean. It makes gambling less intimidating. This is not a safety section. It is a product feature. At the New Player stage, once they know the basic rules, you introduce myth-busting. Cognitive distortions like "I am due for a win" or "this machine is hot." This builds gambling resilience indirectly through education, not through warnings. At the Active Player stage, the player is settled in. This is where entertainment literacy lives. Finer points, strategy where it applies, product-specific knowledge. Quizzes, game guides, articles. The player is engaged enough to want more. At the Regular stage, and only at this stage, you introduce self-management tools. Activity tracking, budgeting, limit-setting. The relationship is established, so these feel like a natural upgrade, not a warning sign. And Support Seeking can happen at any point. This is Tier 2. Direct path to support resources. No friction, no forms, no questions asked. This is not a funnel. Most players engage with the first two stages only. Some reach stage three. A minority become Regulars. The framework tells you what to have ready, not that every player will need all of it. Notice what Playbook does not do. It does not push deposit limits on Day One. It does not surface self-exclusion tools during onboarding. That is the generic responsible gambling approach, and it fails because players do not have a relationship with the brand yet. Instead, Playbook earns the relationship in stages. Education first, then tools. Use the touchpoint map and the worked example below to explore how this plays out across real channels and real timelines. Then try the game guides to see what players actually experience at the Awareness stage.' },
  { slideIndex: 1, src: `${base}/audio/modules/m5-content-and-campaigns.mp3`, transcript: 'Playbook ships with a complete campaign framework. Pre-built campaigns, a myth-busting library, and a message hierarchy that scales from a tagline to a five-hundred-word article. The message hierarchy has four levels. Level one is taglines. Interchangeable lines organized by pillar, used in ads and hero banners. Level two is pillar messages. One core message per pillar, used in campaign themes and landing pages. Level three is contextual messages. Specific to a touchpoint, audience, or action, like deposit screens and email subject lines. Level four is long-form. Educational, explanatory, or interactive material for articles, video scripts, and quiz experiences. Playbook ships with pre-built campaigns. Each one maps to specific verticals, including both retail and online casino. Slots Myths Week and Beat the House translate directly to online casino because the myths are identical whether the game is on a physical floor or a screen. The only adaptation is swapping physical references for digital ones. Scheduling rules. Avoid peak gambling periods. Allow one week between campaigns. Plan for four campaigns per year. Start with one well-executed campaign rather than trying to launch everything at once. Myth-busting is Playbook\'s core material category. The library holds researched myths organized by game type, each pre-written in multiple formats. Social cards are fifty to eighty words, punchy and shareable. Article explainers are three hundred to five hundred words with links to tools and quizzes. Quiz questions have four options with instant feedback. One myth per week gives you months of material across multiple channels simultaneously. Each myth in the library is tagged with the underlying cognitive distortion, like the Gambler\'s Fallacy or the Near-Miss Effect. You can filter by game type or by distortion to find exactly the right piece for your campaign. Now explore the myth-busting library below.' },
  { slideIndex: 2, src: `${base}/audio/modules/m5-knowledge-check.mp3`, transcript: 'Time to test what you have learned. Five questions covering the player journey and the campaign strategy. You need eighty percent to mark this module complete. Take your time.' },
];

const questions = [
  {
    id: 'q1',
    question: 'What content does Playbook deliver to a brand-new player on Day 1?',
    options: [
      'Deposit limit prompts and budgeting tools',
      'Game education — how the game works, what the numbers mean',
      'Helpline numbers and self-exclusion options',
      'Activity dashboards and session tracking',
    ],
    correctIndex: 1,
    explanation: 'Playbook starts with game education — teaching how the game works, making it less intimidating. Tools like budgeting and activity tracking come much later, once the player has an established relationship with the brand.',
    reviewSlug: 'player-journey',
  },
  {
    id: 'q2',
    question: 'When does Playbook introduce self-management tools (budgeting, activity tracking, limits)?',
    options: [
      'At registration — every player needs tools from Day 1',
      'During the New Player stage — alongside game education',
      'At the Regular stage — after weeks of engagement when the relationship is established',
      'Only when at-risk behavior is detected',
    ],
    correctIndex: 2,
    explanation: 'Tools arrive at the Regular stage — after the player has engaged for weeks and trusts the brand. Introducing tools on Day 1 is the generic RG approach. Playbook earns the relationship first through education, then introduces tools as features, not interventions.',
    reviewSlug: 'player-journey',
  },
  {
    id: 'q3',
    question: 'What content formats does each myth in the Playbook library come in?',
    options: [
      'Social card only',
      'Social card and quiz question',
      'Social card, article explainer, and quiz question',
      'Video, social card, article, and quiz question',
    ],
    correctIndex: 2,
    explanation: 'Every myth is pre-written in multiple formats: a social card (50-80 words, shareable), an article explainer (300-500 words, educational), and a quiz question (with four options and feedback). This lets you deploy the same truth across social, content hub, and interactive channels.',
    reviewSlug: 'content-and-campaigns',
  },
  {
    id: 'q4',
    question: 'How should you schedule myth-busting campaigns relative to peak gambling periods?',
    options: [
      'Launch during peak periods — that\'s when players need education most',
      'Schedule for shoulder periods — players are less receptive during peak action',
      'Only run campaigns during regulatory awareness weeks',
      'Run continuously with no scheduling considerations',
    ],
    correctIndex: 1,
    explanation: 'Players are focused on action during peak periods and less receptive to educational content. Schedule campaigns for shoulder periods. Allow at least one week between campaigns to prevent message fatigue.',
    reviewSlug: 'content-and-campaigns',
  },
  {
    id: 'q5',
    question: 'A player who was Recreational in casino now signs up for sports betting. What segment are they in for sports content?',
    options: [
      'Still Recreational — segment is person-level',
      'New/Novice — segment is product-contextual, and they\'re new to this vertical',
      'Enthusiast — they\'re clearly engaged if they\'re adding a new product',
      'At-Risk — expanding to a new product is a warning sign',
    ],
    correctIndex: 1,
    explanation: 'Segment is product-contextual. A seasoned casino player trying sports betting for the first time needs sports-specific education. They\'re knowledgeable about gambling generally but novice in this specific product.',
    reviewSlug: 'player-journey',
  },
];
---

<ModuleLayout module={module} panelMode={true} tracks={tracks}>
  <!-- Module intro -->
  <div class="mb-8 p-5 rounded-xl bg-navy/5 border border-navy/10">
    <p class="text-sm text-navy font-heading mb-2">
      <strong>Customer Journey</strong> — How Playbook content maps to every touchpoint in the player experience, plus ready-to-run campaigns.
    </p>
    <button
      id="start-narration-btn"
      class="inline-flex items-center gap-2 px-4 py-2 bg-teal text-navy font-heading font-bold rounded-lg hover:bg-teal-light transition-colors text-sm"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      Play Audio Guide
    </button>
  </div>

  <!-- Learning objectives (visible before content) -->
  <div class="mb-6 p-4 rounded-lg bg-teal/5 border border-teal/10">
    <p class="text-sm text-navy mb-3 font-heading"><strong>By the end of this module, you will be able to:</strong></p>
    <ul class="text-sm text-n700 mb-4 space-y-1.5 pl-4 list-disc">
      <li>Map the five-stage player content journey from Awareness to Support Seeking</li>
      <li>Design a content escalation sequence that introduces tools at the right stage</li>
      <li>Plan a campaign using the myth-busting library and scheduling framework</li>
    </ul>
  </div>

  <script>
    document.getElementById('start-narration-btn')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('start-playback'));
    });
  </script>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- LESSON 5.1: The Player Journey                  -->
  <!-- ═══════════════════════════════════════════════ -->
  <section id="player-journey" data-slide-index="0" data-lesson-slug="player-journey" data-has-exercise class="module-section py-16">
    <h2>The Player Journey</h2>

    <p class="text-lg text-n600 mb-6">
      Playbook's content follows a <strong>content escalation</strong> model. It starts with what every player wants — how to play — and builds toward what long-term regulars need. Most players never reach the later stages, and that's by design.
    </p>

    <h3>The 5 stages</h3>

    <table>
      <thead>
        <tr>
          <th>Stage</th>
          <th>What's happening</th>
          <th>Playbook's role</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>1. Awareness</strong></td>
          <td>Player hasn't signed up yet. Encountering the brand through ads, social, search.</td>
          <td>Playbook appears as a <strong>companion brand</strong> alongside the product. Content teaches how the game works — odds, rules, what the numbers mean. Makes gambling less intimidating. Not a safety section; a product feature.</td>
        </tr>
        <tr>
          <td><strong>2. New Player</strong></td>
          <td>Signed up, first sessions. Learning the basics, placing first bets or spins.</td>
          <td>Once they know the basic rules, introduce <strong>myth-busting</strong> content — cognitive distortions like "I'm due for a win" or "this machine is hot." Builds gambling resilience indirectly through education, not warnings.</td>
        </tr>
        <tr>
          <td><strong>3. Active Player</strong></td>
          <td>Settled in. Regular sessions, familiar with the product.</td>
          <td><strong>Entertainment literacy.</strong> Finer points, strategy (where applicable), product-specific knowledge. The player is engaged enough to want to learn more — quizzes, game guides, content hub articles.</td>
        </tr>
        <tr>
          <td><strong>4. Regular</strong></td>
          <td>Long-term player. Predictable pattern of play over weeks or months.</td>
          <td>Now introduce <strong>self-management tools</strong> — activity tracking, budgeting, limit-setting. The relationship is established, so these feel like a natural upgrade, not a warning sign.</td>
        </tr>
        <tr>
          <td><strong>5. Support Seeking</strong></td>
          <td>Player or someone close to them is looking for help.</td>
          <td>Tier 2 content. Direct path to support resources — no friction, no forms, no questions asked.</td>
        </tr>
      </tbody>
    </table>

    <blockquote>
      <p>This is not a funnel. Most players engage with Stages 1–2 only. Some reach Stage 3. A minority become Regulars. Support Seeking can happen at any point. The framework tells you what content to have ready — not that every player will need it.</p>
    </blockquote>

    <TouchpointMap client:visible />

    <h3>The content escalation logic</h3>

    <p>
      Notice what Playbook does <strong>not</strong> do: it doesn't push deposit limits on Day 1 or surface self-exclusion tools during onboarding. That's the generic RG approach — and it fails because players don't have a relationship with the brand yet.
    </p>

    <p>
      Instead, Playbook earns the relationship in stages:
    </p>

    <div class="grid gap-4 sm:grid-cols-2 my-6">
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-teal-dark mb-1">Stage 1–2: Education first</p>
        <p class="text-sm text-n600">"Here's how the game works. Here's what most people get wrong." The player sees Playbook as useful — a companion that helps them play smarter. No compliance language, no tool-pushing.</p>
      </div>
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-teal-dark mb-1">Stage 3–4: Tools earn their moment</p>
        <p class="text-sm text-n600">Only after weeks of engagement — when the player trusts the brand — do self-management tools appear. They arrive as features, not interventions. "Your activity dashboard is ready" instead of "You should set a limit."</p>
      </div>
    </div>

    <EscalationTimeline client:visible />

    <h3>What "game education" looks like</h3>

    <p>
      The game guides below are what players see at the Awareness and New Player stages. Each one teaches how the game works — rules, odds, what the numbers mean — without any responsible gambling framing. They're product education, designed to make gambling less intimidating.
    </p>

    <GameGuidePreview client:visible />

    <h3>Key transitions</h3>

    <p>Three moments where the content strategy shifts:</p>

    <div class="grid gap-4 sm:grid-cols-3 my-6">
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-navy mb-2">New &rarr; Active</p>
        <p class="text-sm text-n600">Game education gives way to myth-busting and entertainment literacy. The player has the basics — now build resilience through cognitive distortion content.</p>
      </div>
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-navy mb-2">Active &rarr; Regular</p>
        <p class="text-sm text-n600">From education to tools. Activity dashboards, budgeting features, limit-setting — introduced as upgrades, not interventions. The relationship earns this moment.</p>
      </div>
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-navy mb-2">Any &rarr; Support</p>
        <p class="text-sm text-n600">Tier 2 content. Direct path to support — no friction, no marketing. Available at any stage, always one tap away.</p>
      </div>
    </div>

    <KeyTakeaway>
      Playbook's content escalation starts with what every player wants — <strong>how to play</strong> — and builds toward what regulars need — <strong>self-management tools</strong>. Most players only see the educational content, and that's fine. The early stages (game education, myth-busting) build resilience on their own. Tools arrive later, when they've been earned.
    </KeyTakeaway>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- LESSON 5.2: Content & Campaigns                 -->
  <!-- ═══════════════════════════════════════════════ -->
  <section id="content-and-campaigns" data-slide-index="1" data-lesson-slug="content-and-campaigns" data-has-exercise class="module-section py-16">
    <h2>Content & Campaigns</h2>

    <p class="text-lg text-n600 mb-6">
      Playbook ships with a complete campaign framework: pre-built campaigns, a myth-busting library, and a message hierarchy that scales from a tagline to a 500-word article.
    </p>

    <h3>The message hierarchy</h3>

    <table>
      <thead>
        <tr>
          <th>Level</th>
          <th>What it is</th>
          <th>Where it appears</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td><strong>Level 1: Taglines</strong></td>
          <td>Interchangeable taglines organized by pillar</td>
          <td>Ads, hero banners, campaigns</td>
        </tr>
        <tr>
          <td><strong>Level 2: Pillar messages</strong></td>
          <td>One core message per pillar</td>
          <td>Campaign themes, landing pages</td>
        </tr>
        <tr>
          <td><strong>Level 3: Contextual</strong></td>
          <td>Specific to a touchpoint, audience, or action</td>
          <td>Deposit screens, email subject lines</td>
        </tr>
        <tr>
          <td><strong>Level 4: Long-form</strong></td>
          <td>Educational, explanatory, or interactive</td>
          <td>Articles, video scripts, quiz content</td>
        </tr>
      </tbody>
    </table>

    <h3>Ready-to-run campaigns</h3>

    <p>
      Playbook ships with pre-built campaigns. The table shows which verticals each supports — including how casino campaigns adapt for online casino:
    </p>

    <div class="overflow-x-auto">
      <table>
        <thead>
          <tr><th>Campaign</th><th>Duration</th><th>Retail Casino</th><th>Online Casino</th><th>Sportsbook</th><th>Lottery</th></tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>Slots Myths Week</strong></td>
            <td>2 weeks</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-n300">—</td>
            <td class="text-center text-n300">—</td>
          </tr>
          <tr>
            <td><strong>Beat the House?</strong></td>
            <td>10 days</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-n300">—</td>
            <td class="text-center text-n300">—</td>
          </tr>
          <tr>
            <td><strong>Sports Betting Reality Check</strong></td>
            <td>2 weeks</td>
            <td class="text-center text-n300">—</td>
            <td class="text-center text-n300">—</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-n300">—</td>
          </tr>
          <tr>
            <td><strong>Luck, Numbers & Lotteries</strong></td>
            <td>1 week</td>
            <td class="text-center text-n300">—</td>
            <td class="text-center text-n300">—</td>
            <td class="text-center text-n300">—</td>
            <td class="text-center text-success font-bold">&#10003;</td>
          </tr>
          <tr>
            <td><strong>The Money Myths</strong></td>
            <td>10 days</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-success font-bold">&#10003;</td>
          </tr>
          <tr>
            <td><strong>Game IQ Challenge</strong></td>
            <td>1 week</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-success font-bold">&#10003;</td>
            <td class="text-center text-success font-bold">&#10003;</td>
          </tr>
        </tbody>
      </table>
    </div>

    <blockquote>
      <p><strong>Online casino note:</strong> Both Slots Myths Week and Beat the House? translate directly to online casino — the myths (RNG, "hot" machines, near-misses, house edge) are identical whether the game is on a physical floor or a screen. The only adaptation needed is swapping physical references ("walk away from the machine") for digital ones ("close the session").</p>
    </blockquote>

    <p>
      <strong>Scheduling rules:</strong> Avoid peak gambling periods. Allow one week between campaigns. Plan for four campaigns per year. Start with one well-executed campaign rather than trying to launch everything at once.
    </p>

    <h3>Myth-busting as content engine</h3>

    <p>
      Myth-busting is Playbook's core content category. The library contains researched myths organized by game type — each pre-written in multiple formats:
    </p>

    <div class="grid gap-4 sm:grid-cols-3 my-6">
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-navy mb-1">Social card</p>
        <p class="text-sm text-n600">50-80 words. Punchy, shareable. Instagram, X/Twitter, in-app cards.</p>
      </div>
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-navy mb-1">Article explainer</p>
        <p class="text-sm text-n600">300-500 words. Explains the math, links to tools and quizzes. Content hub, blog, email.</p>
      </div>
      <div class="rounded-xl border border-n100 bg-n50 p-5">
        <p class="font-heading font-semibold text-navy mb-1">Quiz question</p>
        <p class="text-sm text-n600">Four options + instant feedback + "learn more" link. Game IQ quiz, social media.</p>
      </div>
    </div>

    <p>
      One myth per week gives you months of content across multiple channels simultaneously.
    </p>

    <MythBrowser client:visible />

    <GenerativeExercise
      client:visible
      title="Map a Touchpoint to Content"
      context="Your sportsbook operator is launching a pre-season NFL promotion. An Enthusiast-segment player visits the 'How Parlays Work' page for the first time during the campaign. They've been betting singles for 2 years but have never tried parlays."
      prompt="Write the contextual message that appears at the top of the 'How Parlays Work' page for this player. Remember: they're an Enthusiast (high engagement, good understanding of singles) encountering a new product type (parlay = New/Novice context)."
      rubric={[
        { label: 'Acknowledges their experience', description: 'Recognizes they already understand sports betting — doesn\'t patronize' },
        { label: 'Frames parlays as new territory', description: 'Treats this as a New/Novice context for parlays specifically, not for sports betting generally' },
        { label: 'Uses Playful/Witty or Confident/Informative register', description: 'This is Tier 1, education-forward content for an engaged player' },
        { label: 'References a specific parlay concept', description: 'Mentions odds multiplication, correlation, or how parlay pricing works — not just generic "learn more"' },
      ]}
      modelAnswer="You know your singles. Parlays are a different game — literally. Each leg multiplies the odds, which means the potential payout grows fast, but so does the house edge. Before you stack your first slip, here's how the math actually works."
    />

    <KeyTakeaway>
      The framework is simple: <strong>phases</strong> tell you where content goes, <strong>segments</strong> tell you how to frame it, <strong>campaigns</strong> give you ready-to-run content packages, and <strong>myth-busting</strong> is your content engine. Start with one campaign for your primary vertical, schedule it for a shoulder period, and build from there.
    </KeyTakeaway>
  </section>

  <!-- ═══════════════════════════════════════════════ -->
  <!-- KNOWLEDGE CHECK                                -->
  <!-- ═══════════════════════════════════════════════ -->
  <section id="knowledge-check" data-slide-index="2" data-lesson-slug="knowledge-check" class="module-section py-16">
    <h2>Knowledge Check</h2>
    <p class="mb-8 text-n700">Five questions covering the player journey and content strategy. You need 80% to mark this module complete.</p>
    <KnowledgeCheck client:visible moduleId="5-customer-journey" questions={questions} passingScore={80} nextModuleHref={`${base}/modules/6-measuring-success`} nextModuleTitle="Module 6: Measuring Success" />
  </section>
</ModuleLayout>

    <script>
      const wrapper = document.getElementById('brand-dna-wrapper');
      const tooltip = document.getElementById('dna-tooltip');
      if (wrapper && tooltip) {
        const nodes = wrapper.querySelectorAll('.dna-node');
        nodes.forEach(node => {
          node.addEventListener('mouseenter', (e) => {
            const tip = node.getAttribute('data-tip');
            if (!tip) return;
            tooltip.textContent = tip;
            tooltip.classList.remove('hidden');
          });
          node.addEventListener('mousemove', (e) => {
            const rect = wrapper.getBoundingClientRect();
            const x = (e as MouseEvent).clientX - rect.left + 12;
            const y = (e as MouseEvent).clientY - rect.top - 8;
            tooltip.style.left = x + 'px';
            tooltip.style.top = y + 'px';
          });
          node.addEventListener('mouseleave', () => {
            tooltip.classList.add('hidden');
          });
        });
      }
    </script>


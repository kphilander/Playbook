---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CertificateGenerator from '../../components/CertificateGenerator.tsx';
---

<BaseLayout title="Certificate of Completion">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8 text-center">
      <h1 class="text-4xl font-heading font-bold text-navy">Your Certificate</h1>
      <p class="text-n500 mt-3 text-lg max-w-2xl mx-auto">
        Complete all 6 modules to earn your Playbook Academy certificate of completion.
      </p>
    </div>
    <CertificateGenerator client:visible />
  </div>
</BaseLayout>

---
import AcademyLayout from '../../../../../layouts/AcademyLayout.astro';
import { getCollection } from 'astro:content';

const programId = 'executive-briefing';
const programName = 'Executive Briefing';

const allModules = await getCollection('academy', (entry) => {
  return entry.data.program_id === programId && entry.data.content_type === 'training-module';
});
const modules = allModules.sort((a, b) => (a.data.module_number ?? 0) - (b.data.module_number ?? 0));

function getModuleSlug(id: string): string {
  const parts = id.split('/');
  return parts[parts.length - 1].replace(/\.md$/, '');
}

const moduleData = modules.map(mod => ({
  slug: getModuleSlug(mod.id),
  title: mod.data.title,
  number: mod.data.module_number ?? 0,
}));
---

<AcademyLayout title={`Completion — ${programName}`} programId={programId} programName={programName}>
  <section class="bg-navy text-white py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <a href={`/tools/playbook/academy/${programId}`} class="inline-flex items-center gap-1 text-white/60 hover:text-white text-sm font-heading mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Back to {programName}
      </a>
      <h1 class="text-3xl sm:text-4xl font-heading font-black">Program Completion</h1>
      <p class="text-white/70 mt-2 font-heading">Complete all reflections to finish the executive briefing.</p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 mb-16">
    <div id="progress-card" class="bg-white dark:bg-navy rounded-xl shadow-lg border border-n100 dark:border-navy-light overflow-hidden">
      <div class="p-6">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-heading font-semibold text-n700 dark:text-n300" id="progress-label">Loading progress...</span>
          <span class="text-sm font-heading font-bold text-teal" id="progress-pct"></span>
        </div>
        <div class="h-3 bg-n100 dark:bg-navy-light rounded-full overflow-hidden">
          <div class="h-full bg-teal rounded-full transition-all duration-500" id="progress-bar" style="width: 0%"></div>
        </div>

        <div class="mt-6 space-y-3" id="module-checklist">
          {moduleData.map((mod) => (
            <div class="flex items-center gap-3 px-4 py-3 rounded-lg border border-n100 dark:border-navy-light bg-n50 dark:bg-navy-dark" data-cert-module={mod.slug}>
              <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 bg-n200 dark:bg-navy-light" data-cert-icon>
                <span class="text-xs text-n500 dark:text-n300 font-heading font-bold">{mod.number + 1}</span>
              </div>
              <span class="text-sm font-heading font-semibold text-n700 dark:text-n300" data-cert-title>{mod.title}</span>
              <span class="ml-auto text-xs font-heading text-n500 dark:text-n300" data-cert-status>Not started</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Program Complete (shown when all reflections done) -->
    <div id="complete-display" class="hidden mt-8">
      <div class="bg-white dark:bg-navy-dark border-4 border-navy dark:border-teal rounded-2xl p-8 sm:p-12 text-center shadow-xl" id="complete-card">
        <div class="mb-6">
          <svg class="w-16 h-16 mx-auto text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
          </svg>
        </div>
        <p class="text-xs font-heading font-bold uppercase tracking-[0.2em] text-teal mb-2">Playbook Academy</p>
        <h2 class="text-3xl sm:text-4xl font-heading font-black text-navy dark:text-white mb-4">Program Complete</h2>
        <p class="text-n500 dark:text-n300 max-w-md mx-auto mb-6">
          You have completed the Executive Briefing. You now have the strategic context needed to champion Playbook within your organization.
        </p>
        <p class="text-sm font-heading text-n500 dark:text-n300">Completed on <span id="complete-date"></span></p>
        <div class="mt-8 pt-6 border-t border-n100 dark:border-navy-light">
          <h3 class="text-sm font-heading font-bold text-navy dark:text-white mb-3">What comes next?</h3>
          <div class="grid gap-3 sm:grid-cols-2 max-w-md mx-auto">
            <a href="/tools/playbook/academy" class="block p-3 rounded-lg border border-n100 dark:border-navy-light hover:border-teal transition-colors text-sm font-heading font-semibold text-navy dark:text-white">
              View All Programs
            </a>
            <a href="/tools/playbook/academy/all-employees" class="block p-3 rounded-lg border border-n100 dark:border-navy-light hover:border-teal transition-colors text-sm font-heading font-semibold text-navy dark:text-white">
              Start Staff Training
            </a>
          </div>
        </div>
      </div>
    </div>

    <!-- Incomplete Message -->
    <div id="incomplete-msg" class="hidden mt-8 bg-white dark:bg-navy rounded-xl border border-n100 dark:border-navy-light p-6 text-center">
      <svg class="w-10 h-10 mx-auto text-orange mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
      </svg>
      <h3 class="font-heading font-bold text-navy dark:text-white text-lg mb-2">Keep Going!</h3>
      <p class="text-sm text-n500 dark:text-n300 mb-4">Complete the remaining modules and their reflections.</p>
      <div id="incomplete-links" class="space-y-2"></div>
    </div>
  </section>

  <script is:inline define:vars={{ programId, moduleData }}>
    (function() {
      const storageKey = `playbook-academy-${programId}`;
      const progress = JSON.parse(localStorage.getItem(storageKey) || '{}');
      const total = moduleData.length;
      let completed = 0;
      const incomplete = [];

      moduleData.forEach(mod => {
        const el = document.querySelector(`[data-cert-module="${mod.slug}"]`);
        if (!el) return;
        const iconEl = el.querySelector('[data-cert-icon]');
        const statusEl = el.querySelector('[data-cert-status]');
        const modProgress = progress[mod.slug];

        if (modProgress && modProgress.completed) {
          completed++;
          if (iconEl) {
            iconEl.classList.remove('bg-n200', 'dark:bg-navy-light');
            iconEl.classList.add('bg-success');
            iconEl.innerHTML = '<svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';
          }
          if (statusEl) {
            statusEl.textContent = 'Reflection complete';
            statusEl.classList.remove('text-n500', 'dark:text-n300');
            statusEl.classList.add('text-success');
          }
        } else if (modProgress && modProgress.completedLessons?.length > 0) {
          if (statusEl) {
            statusEl.textContent = 'In progress';
            statusEl.classList.remove('text-n500', 'dark:text-n300');
            statusEl.classList.add('text-orange');
          }
          incomplete.push(mod);
        } else {
          incomplete.push(mod);
        }
      });

      const pct = Math.round((completed / total) * 100);
      const label = document.getElementById('progress-label');
      const pctEl = document.getElementById('progress-pct');
      const bar = document.getElementById('progress-bar');
      if (label) label.textContent = `${completed} of ${total} modules complete`;
      if (pctEl) pctEl.textContent = `${pct}%`;
      if (bar) bar.style.width = `${pct}%`;

      if (completed === total) {
        const display = document.getElementById('complete-display');
        if (display) display.classList.remove('hidden');
        const today = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
        const dateEl = document.getElementById('complete-date');
        if (dateEl) dateEl.textContent = today;
      } else if (incomplete.length > 0) {
        const incMsg = document.getElementById('incomplete-msg');
        if (incMsg) incMsg.classList.remove('hidden');
        const linksEl = document.getElementById('incomplete-links');
        if (linksEl) {
          incomplete.forEach(mod => {
            const a = document.createElement('a');
            a.href = `/tools/playbook/academy/${programId}/${mod.slug}`;
            a.className = 'block text-sm font-heading font-semibold text-navy dark:text-teal hover:text-teal dark:hover:text-teal-light transition-colors';
            a.textContent = `${mod.title} →`;
            linksEl.appendChild(a);
          });
        }
      }
    })();
  </script>
</AcademyLayout>

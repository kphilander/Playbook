---
import AcademyLayout from '../../../../../layouts/AcademyLayout.astro';
import { getCollection } from 'astro:content';

const programId = 'all-employees';
const programName = 'All Employees';
const certName = 'Playbook Foundations Certificate';
const passingScore = 80;

const allModules = await getCollection('academy', (entry) => {
  return entry.data.program_id === programId && entry.data.content_type === 'training-module';
});
const modules = allModules.sort((a, b) => (a.data.module_number ?? 0) - (b.data.module_number ?? 0));

function getModuleSlug(id: string): string {
  const parts = id.split('/');
  return parts[parts.length - 1].replace(/\.md$/, '');
}

const moduleData = modules.map(mod => ({
  slug: getModuleSlug(mod.id),
  title: mod.data.title,
  number: mod.data.module_number ?? 0,
}));
---

<AcademyLayout title={`Certificate — ${programName}`} programId={programId} programName={programName}>
  <section class="bg-navy text-white py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <a href={`/tools/playbook/academy/${programId}`} class="inline-flex items-center gap-1 text-white/60 hover:text-white text-sm font-heading mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        Back to {programName}
      </a>
      <h1 class="text-3xl sm:text-4xl font-heading font-black">{certName}</h1>
      <p class="text-white/70 mt-2 font-heading">Complete all modules with {passingScore}% or higher to earn your certificate.</p>
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 -mt-6 mb-16">
    <!-- Progress Card -->
    <div id="progress-card" class="bg-white dark:bg-navy rounded-xl shadow-lg border border-n100 dark:border-navy-light overflow-hidden">
      <div class="p-6">
        <div class="flex items-center justify-between mb-3">
          <span class="text-sm font-heading font-semibold text-n700 dark:text-n300" id="progress-label">Loading progress...</span>
          <span class="text-sm font-heading font-bold text-teal" id="progress-pct"></span>
        </div>
        <div class="h-3 bg-n100 dark:bg-navy-light rounded-full overflow-hidden">
          <div class="h-full bg-teal rounded-full transition-all duration-500" id="progress-bar" style="width: 0%"></div>
        </div>

        <!-- Module Checklist -->
        <div class="mt-6 space-y-3" id="module-checklist">
          {moduleData.map((mod) => (
            <div class="flex items-center gap-3 px-4 py-3 rounded-lg border border-n100 dark:border-navy-light bg-n50 dark:bg-navy-dark" data-cert-module={mod.slug}>
              <div class="w-6 h-6 rounded-full flex items-center justify-center flex-shrink-0 bg-n200 dark:bg-navy-light" data-cert-icon>
                <span class="text-xs text-n500 dark:text-n300 font-heading font-bold">{mod.number + 1}</span>
              </div>
              <span class="text-sm font-heading font-semibold text-n700 dark:text-n300" data-cert-title>{mod.title}</span>
              <span class="ml-auto text-xs font-heading text-n500 dark:text-n300" data-cert-status>Not started</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Certificate (hidden until all complete) -->
    <div id="certificate-display" class="hidden mt-8">
      <div class="bg-white dark:bg-navy-dark border-4 border-navy dark:border-teal rounded-2xl p-8 sm:p-12 text-center shadow-xl print:shadow-none print:border-2" id="certificate-printable">
        <div class="mb-6">
          <svg class="w-12 h-12 mx-auto text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.746 3.746 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
          </svg>
        </div>
        <p class="text-xs font-heading font-bold uppercase tracking-[0.2em] text-teal mb-2">Playbook Academy</p>
        <h2 class="text-2xl sm:text-3xl font-heading font-black text-navy dark:text-white mb-1">Certificate of Completion</h2>
        <p class="text-sm font-heading text-n500 dark:text-n300 mb-8">{certName}</p>
        <p class="text-sm font-heading text-n500 dark:text-n300 mb-2">This certifies that</p>
        <div class="mb-6">
          <input type="text" id="cert-name-input" placeholder="Enter your name" class="text-center text-xl sm:text-2xl font-heading font-bold text-navy dark:text-white bg-transparent border-b-2 border-n200 dark:border-navy-light focus:border-teal outline-none px-4 py-2 w-full max-w-md mx-auto placeholder:text-n300 dark:placeholder:text-n500" />
        </div>
        <p class="text-sm font-heading text-n500 dark:text-n300 mb-1">has successfully completed the</p>
        <p class="text-lg font-heading font-bold text-navy dark:text-white mb-1">{programName} Program</p>
        <p class="text-sm font-heading text-n500 dark:text-n300 mb-6">on <span id="cert-date"></span></p>
        <div class="flex items-center justify-center gap-8 pt-6 border-t border-n100 dark:border-navy-light">
          <div class="text-center">
            <div class="w-24 border-b border-n300 dark:border-n500 mb-1"></div>
            <p class="text-xs font-heading text-n500 dark:text-n300">Program Director</p>
          </div>
          <div class="text-center">
            <div class="w-24 border-b border-n300 dark:border-n500 mb-1"></div>
            <p class="text-xs font-heading text-n500 dark:text-n300">Date</p>
          </div>
        </div>
      </div>
      <div class="mt-6 text-center print:hidden">
        <button id="print-btn" class="inline-flex items-center gap-2 px-6 py-3 bg-teal hover:bg-teal-dark text-navy font-heading font-bold rounded-xl transition-colors">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m0 0a48.394 48.394 0 0110.5 0m-10.5 0V5.256c0-.621.504-1.125 1.125-1.125h8.25c.621 0 1.125.504 1.125 1.125v3.778" /></svg>
          Print Certificate
        </button>
      </div>
    </div>

    <!-- Incomplete Message (shown when not all modules passed) -->
    <div id="incomplete-msg" class="hidden mt-8 bg-white dark:bg-navy rounded-xl border border-n100 dark:border-navy-light p-6 text-center">
      <svg class="w-10 h-10 mx-auto text-orange mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
      </svg>
      <h3 class="font-heading font-bold text-navy dark:text-white text-lg mb-2">Almost There!</h3>
      <p class="text-sm text-n500 dark:text-n300 mb-4">Complete the remaining modules to earn your certificate.</p>
      <div id="incomplete-links" class="space-y-2"></div>
    </div>
  </section>

  <style>
    @media print {
      nav, footer, #progress-card, #incomplete-msg, .print\\:hidden, a[href] { display: none !important; }
      #certificate-display { margin: 0 !important; }
      #certificate-printable { border-width: 2px !important; box-shadow: none !important; }
      body { background: white !important; }
    }
  </style>

  <script is:inline define:vars={{ programId, moduleData, passingScore }}>
    (function() {
      const storageKey = `playbook-academy-${programId}`;
      const progress = JSON.parse(localStorage.getItem(storageKey) || '{}');
      const total = moduleData.length;
      let passed = 0;
      const incomplete = [];

      moduleData.forEach(mod => {
        const el = document.querySelector(`[data-cert-module="${mod.slug}"]`);
        if (!el) return;
        const iconEl = el.querySelector('[data-cert-icon]');
        const statusEl = el.querySelector('[data-cert-status]');
        const modProgress = progress[mod.slug];

        if (modProgress && modProgress.completed && modProgress.quizScore >= passingScore) {
          passed++;
          if (iconEl) {
            iconEl.classList.remove('bg-n200', 'dark:bg-navy-light');
            iconEl.classList.add('bg-success');
            iconEl.innerHTML = '<svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>';
          }
          if (statusEl) {
            statusEl.textContent = `${modProgress.quizScore}% — Passed`;
            statusEl.classList.remove('text-n500', 'dark:text-n300');
            statusEl.classList.add('text-success');
          }
        } else if (modProgress && modProgress.quizScore !== null) {
          if (iconEl) {
            iconEl.classList.remove('bg-n200', 'dark:bg-navy-light');
            iconEl.classList.add('bg-danger');
            iconEl.innerHTML = '<svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>';
          }
          if (statusEl) {
            statusEl.textContent = `${modProgress.quizScore}% — Needs ${passingScore}%`;
            statusEl.classList.remove('text-n500', 'dark:text-n300');
            statusEl.classList.add('text-danger');
          }
          incomplete.push(mod);
        } else {
          incomplete.push(mod);
        }
      });

      const pct = Math.round((passed / total) * 100);
      const label = document.getElementById('progress-label');
      const pctEl = document.getElementById('progress-pct');
      const bar = document.getElementById('progress-bar');
      if (label) label.textContent = `${passed} of ${total} modules complete`;
      if (pctEl) pctEl.textContent = `${pct}%`;
      if (bar) bar.style.width = `${pct}%`;

      if (passed === total) {
        const certDisplay = document.getElementById('certificate-display');
        if (certDisplay) certDisplay.classList.remove('hidden');
        const today = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
        const dateEl = document.getElementById('cert-date');
        if (dateEl) dateEl.textContent = today;
      } else if (incomplete.length > 0) {
        const incMsg = document.getElementById('incomplete-msg');
        if (incMsg) incMsg.classList.remove('hidden');
        const linksEl = document.getElementById('incomplete-links');
        if (linksEl) {
          incomplete.forEach(mod => {
            const a = document.createElement('a');
            a.href = `/tools/playbook/academy/${programId}/${mod.slug}`;
            a.className = 'block text-sm font-heading font-semibold text-navy dark:text-teal hover:text-teal dark:hover:text-teal-light transition-colors';
            a.textContent = `${mod.title} →`;
            linksEl.appendChild(a);
          });
        }
      }

      document.getElementById('print-btn')?.addEventListener('click', () => window.print());
    })();
  </script>
</AcademyLayout>

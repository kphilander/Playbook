---
import AcademyLayout from '../../../../../layouts/AcademyLayout.astro';

const programId = 'compliance';
const programName = 'Compliance';
const firstModuleHref = `/tools/playbook/academy/${programId}/00-regulatory-landscape`;

const slides = [
  {
    heading: 'Compliance Training',
    body: 'Where brand voice meets regulation. This program teaches you how to read jurisdiction modules, apply advertising and messaging rules, and run the audit process that keeps your operation compliant.',
    caption: 'Compliance is not the opposite of good branding. It is the guardrail that makes good branding sustainable.',
    icon: 'scale',
  },
  {
    heading: 'Read, Apply, Audit',
    body: 'Three skills: understand the regulatory landscape and how jurisdiction modules work, apply advertising and messaging rules to real content, and run quarterly audits that catch problems before regulators do.',
    caption: 'Each module pairs regulatory knowledge with practical Playbook application.',
    icon: 'clipboard',
  },
  {
    heading: "Let's Begin",
    body: '3 modules. About 55 minutes. Score 80% or higher on each quiz to earn your Compliance Certificate. Recertification is required every 6 months.',
    caption: 'Prerequisite: All Employees program. Have your jurisdiction module handy if you have one.',
    icon: 'rocket',
  },
];
---

<AcademyLayout title={`Intro — ${programName}`} programId={programId} programName={programName}>
  <div class="relative min-h-[calc(100vh-3.5rem)] overflow-hidden" id="intro-deck" data-total={slides.length}>
    {slides.map((slide, i) => (
      <section
        class:list={[
          'intro-slide absolute inset-0 flex items-center justify-center transition-opacity duration-500',
          i === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0',
        ]}
        data-slide={i}
        aria-hidden={i !== 0 ? 'true' : undefined}
      >
        <div class={`w-full min-h-full flex items-center justify-center px-4 sm:px-6 lg:px-8 py-16 ${i === slides.length - 1 ? 'bg-gradient-to-br from-navy via-navy-dark to-navy' : i % 2 === 0 ? 'bg-gradient-to-br from-navy to-navy-dark' : 'bg-gradient-to-br from-navy-dark to-navy'}`}>
          <div class="max-w-2xl mx-auto text-center">
            <div class="mb-8">
              {slide.icon === 'scale' && (
                <svg class="w-16 h-16 mx-auto text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0012 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 01-2.031.352 5.988 5.988 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0l2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 01-2.031.352 5.989 5.989 0 01-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971z" />
                </svg>
              )}
              {slide.icon === 'clipboard' && (
                <svg class="w-16 h-16 mx-auto text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                </svg>
              )}
              {slide.icon === 'rocket' && (
                <svg class="w-16 h-16 mx-auto text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.59 14.37a6 6 0 01-5.84 7.38v-4.8m5.84-2.58a14.98 14.98 0 006.16-12.12A14.98 14.98 0 009.631 8.41m5.96 5.96a14.926 14.926 0 01-5.841 2.58m-.119-8.54a6 6 0 00-7.381 5.84h4.8m2.58-5.84a14.927 14.927 0 00-2.58 5.84m2.699 2.7c-.103.021-.207.041-.311.06a15.09 15.09 0 01-2.448-2.448 14.9 14.9 0 01.06-.312m-2.24 2.39a4.493 4.493 0 00-1.757 4.306 4.493 4.493 0 004.306-1.758M16.5 9a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z" />
                </svg>
              )}
            </div>
            <h2 class="text-3xl sm:text-5xl font-heading font-black text-white mb-6">{slide.heading}</h2>
            <p class="text-lg sm:text-xl text-white/80 leading-relaxed mb-8 max-w-xl mx-auto">{slide.body}</p>
            <div class="bg-white/10 backdrop-blur-sm rounded-lg px-4 py-3 inline-block">
              <p class="text-sm text-white/60 font-heading italic">{slide.caption}</p>
            </div>
            {i === slides.length - 1 && (
              <div class="mt-10">
                <a href={firstModuleHref} class="inline-flex items-center gap-2 px-8 py-4 bg-teal hover:bg-teal-dark text-navy font-heading font-bold text-lg rounded-xl transition-colors shadow-lg shadow-teal/20">
                  Start Program
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </a>
              </div>
            )}
          </div>
        </div>
      </section>
    ))}

    <div class="fixed bottom-8 left-1/2 -translate-x-1/2 z-20 flex items-center gap-4">
      <button id="prev-btn" class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm text-white hover:bg-white/30 transition-colors flex items-center justify-center disabled:opacity-30 disabled:cursor-not-allowed" disabled aria-label="Previous slide">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" /></svg>
      </button>
      <div class="flex items-center gap-2" id="dot-indicators">
        {slides.map((_, i) => (
          <button
            class:list={[
              'w-2.5 h-2.5 rounded-full transition-all duration-300',
              i === 0 ? 'bg-teal w-6' : 'bg-white/40 hover:bg-white/60',
            ]}
            data-dot={i}
            aria-label={`Go to slide ${i + 1}`}
          />
        ))}
      </div>
      <button id="next-btn" class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm text-white hover:bg-white/30 transition-colors flex items-center justify-center disabled:opacity-30 disabled:cursor-not-allowed" aria-label="Next slide">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
      </button>
    </div>
  </div>

  <script is:inline>
    (function() {
      const deck = document.getElementById('intro-deck');
      const total = parseInt(deck?.dataset.total || '0');
      let current = 0;

      function goTo(index) {
        if (index < 0 || index >= total) return;
        const slides = document.querySelectorAll('.intro-slide');
        const dots = document.querySelectorAll('[data-dot]');
        slides.forEach((s, i) => {
          s.classList.toggle('opacity-100', i === index);
          s.classList.toggle('opacity-0', i !== index);
          s.classList.toggle('z-10', i === index);
          s.classList.toggle('z-0', i !== index);
          s.setAttribute('aria-hidden', i !== index ? 'true' : 'false');
        });
        dots.forEach((d, i) => {
          d.classList.toggle('bg-teal', i === index);
          d.classList.toggle('w-6', i === index);
          d.classList.toggle('bg-white/40', i !== index);
          d.classList.toggle('w-2.5', i !== index);
        });
        current = index;
        document.getElementById('prev-btn').disabled = current === 0;
        document.getElementById('next-btn').disabled = current === total - 1;
      }

      document.getElementById('prev-btn')?.addEventListener('click', () => goTo(current - 1));
      document.getElementById('next-btn')?.addEventListener('click', () => goTo(current + 1));
      document.querySelectorAll('[data-dot]').forEach(dot => {
        dot.addEventListener('click', () => goTo(parseInt(dot.dataset.dot)));
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') goTo(current - 1);
        if (e.key === 'ArrowRight') goTo(current + 1);
      });
    })();
  </script>
</AcademyLayout>

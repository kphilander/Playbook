---
import AcademyLayout from '../../../../../layouts/AcademyLayout.astro';
import ModuleCard from '../../../../../components/academy/ModuleCard.astro';
import { getCollection } from 'astro:content';

const programId = 'marcomm';
const programName = 'Marcomm';

const allModules = await getCollection('academy', (entry) => {
  return entry.data.program_id === programId && entry.data.content_type === 'training-module';
});
const modules = allModules.sort((a, b) => (a.data.module_number ?? 0) - (b.data.module_number ?? 0));

const moduleDescriptions: Record<string, string> = {
  '00-brand-system-deep-dive': 'Brand architecture, visual identity, voice/tone, cultural adaptation.',
  '01-content-creation-workshop': 'Message library, taglines, CTAs, myth-busting, quiz creation.',
  '02-campaign-planning-and-measurement': 'Campaign briefs, segments, templates, A/B testing, measurement.',
};

function getModuleSlug(id: string): string {
  const parts = id.split('/');
  return parts[parts.length - 1].replace(/\.md$/, '');
}

function resolve(text: string): string {
  return text.replace(/\{\{PROGRAM_NAME\}\}/g, 'Playbook');
}
---

<AcademyLayout title={programName} programId={programId} programName={programName}>
  <!-- Hero -->
  <section class="bg-navy text-white py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/tools/playbook/academy" class="inline-flex items-center gap-1 text-white/60 hover:text-white text-sm font-heading mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        All Programs
      </a>
      <div class="flex items-center gap-3 mb-4">
        <span class="px-3 py-1 bg-teal/20 text-teal rounded-full text-xs font-heading font-bold uppercase tracking-wider">Marketing / Creative</span>
        <span class="text-white/50 text-sm font-heading">~180 min</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-heading font-black mb-4">{programName}</h1>
      <p class="text-xl text-white/80 leading-relaxed max-w-2xl">For marketing and creative teams. Deep dive into the brand system, hands-on content creation, and campaign planning with measurement frameworks.</p>
    </div>
  </section>

  <!-- Stats Grid -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
      <div class="bg-white dark:bg-navy rounded-xl shadow-sm border border-n100 dark:border-navy-light p-4 text-center">
        <div class="text-2xl font-heading font-black text-navy dark:text-white">3</div>
        <div class="text-xs text-n500 dark:text-n300 font-heading uppercase tracking-wider mt-1">Modules</div>
      </div>
      <div class="bg-white dark:bg-navy rounded-xl shadow-sm border border-n100 dark:border-navy-light p-4 text-center">
        <div class="text-2xl font-heading font-black text-navy dark:text-white">~180 min</div>
        <div class="text-xs text-n500 dark:text-n300 font-heading uppercase tracking-wider mt-1">Duration</div>
      </div>
      <div class="bg-white dark:bg-navy rounded-xl shadow-sm border border-n100 dark:border-navy-light p-4 text-center">
        <div class="text-2xl font-heading font-black text-navy dark:text-white">80%</div>
        <div class="text-xs text-n500 dark:text-n300 font-heading uppercase tracking-wider mt-1">Passing Score</div>
      </div>
      <div class="bg-white dark:bg-navy rounded-xl shadow-sm border border-n100 dark:border-navy-light p-4 text-center">
        <div class="text-2xl font-heading font-black text-navy dark:text-white">12 mo</div>
        <div class="text-xs text-n500 dark:text-n300 font-heading uppercase tracking-wider mt-1">Recertification</div>
      </div>
    </div>
  </section>

  <!-- Credentials -->
  <section class="py-8 border-b border-n100 dark:border-navy-light bg-white dark:bg-navy">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-12 h-12 rounded-full bg-navy/10 dark:bg-white/10 flex items-center justify-center">
          <svg class="w-6 h-6 text-navy dark:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
          </svg>
        </div>
        <div>
          <p class="font-heading font-semibold text-navy dark:text-white text-sm">Developed by GP Advisory</p>
          <p class="text-sm text-n500 dark:text-n400 mt-1">Research-driven gambling policy consulting. This curriculum is built on the Playbook open-source brand system and the informed choice model from gambling studies.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Module Cards -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mt-12">
    <h2 class="text-2xl font-heading font-bold text-navy dark:text-white mb-6">Modules</h2>
    <div class="grid gap-6 sm:grid-cols-2">
      {modules.map((mod) => {
        const slug = getModuleSlug(mod.id);
        return (
          <ModuleCard
            href={`/tools/playbook/academy/${programId}/${slug}`}
            moduleSlug={slug}
            moduleNumber={mod.data.module_number ?? 0}
            title={resolve(mod.data.title)}
            description={moduleDescriptions[slug] || ''}
            duration={mod.data.duration_minutes ?? 0}
            color="teal"
          />
        );
      })}
    </div>
  </section>

  <!-- What Comes Next -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 mt-16 mb-8">
    <h2 class="text-2xl font-heading font-bold text-navy dark:text-white mb-4">What Comes Next</h2>
    <p class="text-n700 dark:text-n300 mb-6">This is the complete marketing and creative track. Use the campaign templates and measurement frameworks from Module 3 as your ongoing toolkit.</p>
  </section>

  <!-- Progress Tracking Script -->
  <script is:inline define:vars={{ programId }}>
    (function() {
      const storageKey = `playbook-academy-${programId}`;
      const progress = JSON.parse(localStorage.getItem(storageKey) || '{}');

      document.querySelectorAll('[data-module-card]').forEach(card => {
        const slug = card.getAttribute('data-module-card');
        if (!slug || !progress[slug]) return;

        const pct = progress[slug].progress || 0;
        const progressEl = card.querySelector('[data-module-progress]');
        if (progressEl) {
          progressEl.classList.remove('hidden');
          const label = progressEl.querySelector('[data-progress-label]');
          const pctEl = progressEl.querySelector('[data-progress-pct]');
          const bar = progressEl.querySelector('[data-progress-bar]');
          if (label) label.textContent = pct >= 100 ? 'Completed' : 'In progress';
          if (pctEl) pctEl.textContent = `${Math.round(pct)}%`;
          if (bar) bar.style.width = `${pct}%`;
        }

        if (pct > 0) {
          const cta = card.querySelector('[data-module-cta]');
          if (cta) cta.textContent = pct >= 100 ? 'Review module' : 'Continue module';
        }
      });
    })();
  </script>
</AcademyLayout>

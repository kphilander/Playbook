---
import AcademyLayout from '../../../../../layouts/AcademyLayout.astro';
import LessonSidebar from '../../../../../components/academy/LessonSidebar.astro';
import Quiz from '../../../../../components/academy/Quiz.astro';
import { getCollection, render } from 'astro:content';

const programId = 'marcomm';
const programName = 'Marcomm';
const basePath = `/tools/playbook/academy/${programId}`;
const { module: moduleSlug } = Astro.params;

const allModules = await getCollection('academy', (entry) => {
  return entry.data.program_id === programId && entry.data.content_type === 'training-module';
});
const modules = allModules.sort((a, b) => (a.data.module_number ?? 0) - (b.data.module_number ?? 0));

const currentIndex = modules.findIndex((m) => m.id.endsWith(`/${moduleSlug}.md`) || m.id.endsWith(`/${moduleSlug}`));
const currentModule = modules[currentIndex];

if (!currentModule) {
  return Astro.redirect(basePath);
}

// Render markdown to HTML string, then parse into structured sections
const { Content } = await render(currentModule);
const prevModule = currentIndex > 0 ? modules[currentIndex - 1] : null;
const nextModule = currentIndex < modules.length - 1 ? modules[currentIndex + 1] : null;
const data = currentModule.data;

function getSlug(id: string): string {
  const parts = id.split('/');
  return parts[parts.length - 1].replace(/\.md$/, '');
}

export async function getStaticPaths() {
  const modules = await getCollection('academy', (entry) => {
    return entry.data.program_id === 'marcomm' && entry.data.content_type === 'training-module';
  });
  return modules.map((mod) => ({
    params: { module: mod.id.split('/').pop()!.replace(/\.md$/, '') },
  }));
}

// Brand configuration for placeholder resolution
const brandConfig: Record<string, string> = {
  'PROGRAM_NAME': 'Playbook',
  'PLAYBOOK_REPO': 'https://github.com/kphilander/Branding',
  'HELPLINE_NUMBER': '1-800-522-4700',
  'TEXT_NUMBER': '1-800-522-4700',
  'CHAT_URL': 'www.ncpgambling.org/chat',
  'MIN_AGE': '21',
  'SELF_EXCLUSION_PROCESS_URL': '#',
  'CLINICAL_SERVICES_URL': '#',
  'PRODUCT_TRAINING_URL': '#',
  'MANDATORY_TRAINING_URL': '#',
  'INTERNAL_POLICIES_URL': '#',
};

// Server-side placeholder resolution for title and objectives
function resolve(text: string): string {
  let result = text;
  for (const [key, value] of Object.entries(brandConfig)) {
    result = result.replace(new RegExp(`\\{\\{${key}\\}\\}`, 'g'), value);
  }
  return result;
}

const resolvedTitle = resolve(data.title);
const resolvedObjectives = (data.learning_objectives || []).map((o: string) => resolve(o));
---

<AcademyLayout title={`${resolvedTitle} — ${programName}`} programId={programId} programName={programName}>
  <!-- Module Header -->
  <section class="bg-navy text-white py-10 lg:py-12">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 lg:ml-80">
      <a href={basePath} class="inline-flex items-center gap-1 text-white/60 hover:text-white text-sm font-heading mb-4 transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        {programName}
      </a>
      <div class="flex items-center gap-3 mb-3">
        <span class="px-3 py-1 bg-teal/20 text-teal rounded-full text-xs font-heading font-bold uppercase tracking-wider">
          Module {(data.module_number ?? 0) + 1}
        </span>
        {data.duration_minutes && (
          <span class="text-white/50 text-sm font-heading">~{data.duration_minutes} min</span>
        )}
      </div>
      <h1 class="text-3xl sm:text-4xl font-heading font-black leading-tight">{resolvedTitle}</h1>
    </div>
  </section>

  <!-- Learning Objectives bar -->
  {resolvedObjectives.length > 0 && (
    <section class="bg-teal/5 dark:bg-teal/10 border-b border-teal/20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 lg:ml-80 py-5">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-teal mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <div>
            <h2 class="text-sm font-heading font-bold text-navy dark:text-white uppercase tracking-wider mb-2">Learning Objectives</h2>
            <ul class="space-y-1">
              {resolvedObjectives.map((obj: string) => (
                <li class="text-sm text-n700 dark:text-n300 flex items-start gap-2">
                  <span class="text-teal mt-1">&#8226;</span>
                  <span>{obj}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Main content area with sidebar -->
  <div class="flex min-h-screen">
    <!-- Desktop sidebar -->
    <aside id="lesson-sidebar" class="hidden lg:block fixed left-0 top-14 w-72 h-[calc(100vh-3.5rem)] bg-white dark:bg-navy border-r border-n100 dark:border-navy-light overflow-y-auto z-40 transition-all duration-300">
      <!-- Sidebar header with collapse toggle -->
      <button id="sidebar-toggle" class="w-full flex items-center justify-between p-4 border-b border-n100 dark:border-navy-light hover:bg-n50 dark:hover:bg-navy-light transition-colors" aria-label="Toggle sidebar" aria-expanded="true">
        <div class="text-left">
          <p class="text-xs font-heading font-semibold uppercase tracking-wider text-n500 dark:text-n300 mb-1">Lessons</p>
          <p class="text-sm font-heading font-bold text-navy dark:text-white truncate">{resolvedTitle}</p>
        </div>
        <svg id="sidebar-chevron" class="w-4 h-4 text-n400 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
      <!-- Progress bar in sidebar -->
      <div class="px-4 py-2 border-b border-n100 dark:border-navy-light">
        <div class="flex items-center justify-between mb-1">
          <span class="text-xs text-n500 dark:text-n400 font-heading" id="sidebar-progress-label">0% complete</span>
        </div>
        <div class="h-1.5 bg-n100 dark:bg-navy-light rounded-full overflow-hidden">
          <div id="sidebar-progress-bar" class="h-full bg-teal rounded-full transition-all duration-500" style="width: 0%"></div>
        </div>
      </div>
      <nav aria-label="Module lessons" class="p-2" id="sidebar-nav">
        <!-- Populated by client-side script after sections are identified -->
      </nav>
    </aside>

    <!-- Noscript fallback -->
    <noscript>
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 lg:ml-80 py-6">
        <div class="rounded-lg border border-orange/30 bg-orange/5 p-4 text-sm text-n700 dark:text-n300">
          This module requires JavaScript for interactive exercises and assessments. Please enable JavaScript to continue.
        </div>
      </div>
    </noscript>

    <!-- Content -->
    <article id="module-content" class="flex-1 max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 lg:ml-80 py-12 pb-24 lg:pb-12">
      <div class="module-prose">
        <Content />
      </div>
    </article>
  </div>

  <!-- Prev / Next Navigation -->
  <nav class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 lg:ml-80 pb-16" aria-label="Module navigation">
    <div class="flex items-stretch gap-4 border-t border-n100 dark:border-navy-light pt-8">
      {prevModule ? (
        <a href={`${basePath}/${getSlug(prevModule.id)}`}
           class="flex-1 group p-4 rounded-xl border border-n100 dark:border-navy-light hover:shadow-md transition-all text-left">
          <div class="text-xs text-n500 dark:text-n300 font-heading uppercase tracking-wider mb-1">Previous</div>
          <div class="font-heading font-bold text-navy dark:text-white group-hover:text-teal transition-colors">{resolve(prevModule.data.title)}</div>
        </a>
      ) : <div class="flex-1" />}
      {nextModule ? (
        <a href={`${basePath}/${getSlug(nextModule.id)}`}
           class="flex-1 group p-4 rounded-xl border border-n100 dark:border-navy-light hover:shadow-md transition-all text-right">
          <div class="text-xs text-n500 dark:text-n300 font-heading uppercase tracking-wider mb-1">Next</div>
          <div class="font-heading font-bold text-navy dark:text-white group-hover:text-teal transition-colors">{resolve(nextModule.data.title)}</div>
        </a>
      ) : (
        <a href={basePath}
           class="flex-1 group p-4 rounded-xl border border-teal/30 bg-teal/5 hover:shadow-md transition-all text-right">
          <div class="text-xs text-teal font-heading uppercase tracking-wider mb-1">Completed</div>
          <div class="font-heading font-bold text-navy dark:text-white group-hover:text-teal transition-colors">Back to {programName}</div>
        </a>
      )}
    </div>
  </nav>

  <!-- Mobile bottom stepper (matches existing academy: navy/95 backdrop-blur) -->
  <div id="mobile-stepper" class="lg:hidden fixed bottom-0 left-0 right-0 bg-navy/95 backdrop-blur-sm z-40 px-4 py-2.5 flex items-center justify-between shadow-lg">
    <button id="stepper-prev" class="p-2 rounded-lg hover:bg-white/10 transition-colors text-white/50 disabled:opacity-30" disabled aria-label="Previous section">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <button id="stepper-counter" class="px-4 py-1.5 rounded-lg bg-white/10 text-sm font-heading font-semibold text-white hover:bg-white/20 transition-colors" aria-label="Open lesson list" aria-expanded="false">
      Section 1
    </button>
    <button id="stepper-next" class="p-2 rounded-lg hover:bg-white/10 transition-colors text-white" aria-label="Next section">
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
    </button>
  </div>

  <!-- Mobile lesson drawer (slides up from bottom) -->
  <div id="mobile-drawer-overlay" class="lg:hidden fixed inset-0 bg-black/50 z-50 hidden" aria-hidden="true"></div>
  <div id="mobile-drawer" class="lg:hidden fixed bottom-0 left-0 right-0 bg-white dark:bg-navy rounded-t-2xl z-50 transform translate-y-full transition-transform duration-300 max-h-[70vh] overflow-y-auto shadow-2xl" role="dialog" aria-label="Lesson navigation" aria-hidden="true">
    <div class="sticky top-0 bg-white dark:bg-navy border-b border-n100 dark:border-navy-light p-4 flex items-center justify-between">
      <h3 class="font-heading font-bold text-navy dark:text-white text-sm">Lessons</h3>
      <button id="drawer-close" class="p-1.5 rounded-lg hover:bg-n50 dark:hover:bg-navy-light transition-colors" aria-label="Close">
        <svg class="w-5 h-5 text-n500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="p-3" id="drawer-nav">
      <!-- Populated by client-side script -->
    </nav>
  </div>

  <div class="lg:hidden h-16"></div>

  <!-- Audio players are built inline by section 9 script below -->
</AcademyLayout>

<!-- Post-render: resolve placeholders, style content, build sidebar, wire interactivity -->
<script is:inline define:vars={{ brandConfig, programId, moduleSlug: moduleSlug || '', nextModuleUrl: nextModule ? `${basePath}/${getSlug(nextModule.id)}` : '', nextModuleTitle: nextModule ? resolve(nextModule.data.title) : '' }}>
(function() {
  const content = document.querySelector('.module-prose');
  if (!content) return;

  // ─── 0. Resolve {{PLACEHOLDER}} tokens ───
  const html = content.innerHTML;
  let resolved = html;
  for (const [key, value] of Object.entries(brandConfig)) {
    resolved = resolved.replace(new RegExp('\\{\\{' + key + '\\}\\}', 'g'), value);
    // Also fix URL-encoded versions
    resolved = resolved.replace(new RegExp('%7B%7B' + key + '%7D%7D', 'g'), value);
  }
  if (resolved !== html) content.innerHTML = resolved;

  // Also resolve in the page title
  document.title = document.title.replace(/\{\{PROGRAM_NAME\}\}/g, brandConfig.PROGRAM_NAME || 'Playbook');

  // ─── 0b. Hide operator notes and quick-scan index ───
  content.querySelectorAll('h2').forEach(h => {
    const text = h.textContent || '';
    if (text.match(/Quick.scan index/i) || text.match(/^Learning objectives$/i)) {
      // Hide the quick-scan table and learning objectives (rendered in header bar)
      let next = h.nextElementSibling;
      h.style.display = 'none';
      while (next && next.tagName !== 'H2') {
        next.style.display = 'none';
        next = next.nextElementSibling;
      }
    }
  });

  // Hide operator note blockquotes (they contain "Operator note")
  content.querySelectorAll('blockquote').forEach(bq => {
    const firstStrong = bq.querySelector('strong');
    if (firstStrong && firstStrong.textContent.match(/Operator (note|integration point)/i)) {
      bq.style.display = 'none';
    }
  });

  // Hide the "Program: ... | Duration: ... | Prerequisites: ..." line
  content.querySelectorAll('p').forEach(p => {
    if (p.textContent.match(/^\s*Program:.*Duration:.*Prerequisites:/)) {
      p.style.display = 'none';
    }
  });

  // ─── 0c. Hide quiz answers from view and build interactive quiz ───
  let quizSection = null;
  content.querySelectorAll('h2').forEach(h => {
    if (h.textContent.match(/Module Test/i)) {
      quizSection = h;
    }
  });

  if (quizSection) {
    // Extract quiz questions before hiding
    const questions = [];
    let qNode = quizSection.nextElementSibling;
    let currentQ = null;

    while (qNode && qNode.tagName !== 'H2') {
      const text = qNode.textContent || '';

      if (qNode.tagName === 'H3' && text.match(/Question \d+/)) {
        if (currentQ) questions.push(currentQ);
        currentQ = { stem: '', options: [], correct: '', explanation: '', index: questions.length + 1 };
      } else if (currentQ) {
        if (text.match(/^\s*Stem:/)) {
          currentQ.stem = text.replace(/^\s*Stem:\s*/, '');
        } else if (text.match(/^\s*Correct:\s*/)) {
          currentQ.correct = text.replace(/^\s*Correct:\s*/, '').trim();
        } else if (text.match(/^\s*Explanation:/)) {
          currentQ.explanation = text.replace(/^\s*Explanation:\s*/, '');
        } else if (qNode.tagName === 'TABLE') {
          // Extract options from table rows
          qNode.querySelectorAll('tbody tr').forEach(row => {
            const cells = row.querySelectorAll('td');
            if (cells.length >= 2) {
              currentQ.options.push({
                letter: (cells[0].textContent || '').trim(),
                text: (cells[1].textContent || '').trim()
              });
            }
          });
        }
      }
      qNode = qNode.nextElementSibling;
    }
    if (currentQ) questions.push(currentQ);

    // Hide all raw quiz content
    let node = quizSection.nextElementSibling;
    while (node && node.tagName !== 'H2') {
      node.style.display = 'none';
      node = node.nextElementSibling;
    }

    // Build interactive quiz UI
    if (questions.length > 0) {
      const quizContainer = document.createElement('div');
      quizContainer.className = 'mt-6 rounded-xl border border-n100 dark:border-navy-light overflow-hidden';
      quizContainer.innerHTML = `
        <div class="bg-navy px-5 py-4 flex items-center justify-between">
          <div>
            <span class="text-xs font-heading font-bold uppercase tracking-wider text-orange">Module Test</span>
            <h3 class="font-heading font-bold text-lg mt-0.5" style="color: white;">Knowledge Check</h3>
          </div>
          <span class="text-sm text-white/60 font-heading">${questions.length} questions · 80% to pass</span>
        </div>
        <div class="p-5 sm:p-6 bg-white dark:bg-navy" id="quiz-body"></div>
      `;

      const quizBody = quizContainer.querySelector('#quiz-body');
      let answered = 0, correct = 0;
      let currentQuizQ = 0; // tracks which question is currently visible
      const threshold = Math.ceil(questions.length * 0.8);

      // Add a progress indicator at top of quiz body
      const quizProgressEl = document.createElement('div');
      quizProgressEl.className = 'flex items-center justify-between mb-6 pb-3 border-b border-n100 dark:border-navy-light';
      quizProgressEl.innerHTML = '<span class="text-sm font-heading font-semibold text-navy dark:text-white" id="quiz-step-label">Question 1 of ' + questions.length + '</span><div class="flex gap-1" id="quiz-step-dots"></div>';
      quizBody.appendChild(quizProgressEl);
      var quizStepDots = quizProgressEl.querySelector('#quiz-step-dots');
      for (var di = 0; di < questions.length; di++) {
        var dot = document.createElement('span');
        dot.className = 'w-2.5 h-2.5 rounded-full ' + (di === 0 ? 'bg-teal' : 'bg-n200 dark:bg-navy-light');
        dot.dataset.dotIndex = String(di);
        quizStepDots.appendChild(dot);
      }

      function updateQuizStepUI() {
        var label = document.getElementById('quiz-step-label');
        if (label) label.textContent = 'Question ' + (currentQuizQ + 1) + ' of ' + questions.length;
        quizStepDots.querySelectorAll('span').forEach(function(d, i) {
          d.className = 'w-2.5 h-2.5 rounded-full ' + (i < answered ? 'bg-success' : i === currentQuizQ ? 'bg-teal' : 'bg-n200 dark:bg-navy-light');
        });
      }

      questions.forEach((q, qi) => {
        const qDiv = document.createElement('div');
        qDiv.className = 'quiz-question mb-8 pb-8 border-b border-n100 dark:border-navy-light last:border-0 last:mb-0 last:pb-0' + (qi > 0 ? ' quiz-hidden' : '');
        qDiv.innerHTML = `
          <p class="text-xs text-n500 dark:text-n300 font-heading uppercase tracking-wider mb-2">Question ${qi + 1} of ${questions.length}</p>
          <p class="text-navy dark:text-white font-heading font-semibold text-lg mb-4">${q.stem}</p>
          <div class="space-y-2 quiz-options-${qi}" role="radiogroup" aria-label="Answer options for question ${qi + 1}"></div>
          <div class="quiz-feedback-${qi} hidden rounded-lg p-4 mt-3 text-sm" tabindex="-1"></div>
        `;

        const optContainer = qDiv.querySelector(`.quiz-options-${qi}`);
        q.options.forEach(opt => {
          const btn = document.createElement('button');
          const isCorrect = opt.letter === q.correct;
          btn.className = 'quiz-option flex items-start gap-3 w-full text-left px-4 py-3 rounded-lg border-2 border-n100 dark:border-navy-light bg-white dark:bg-navy-dark hover:border-teal transition-all';
          btn.setAttribute('role', 'radio');
          btn.setAttribute('aria-checked', 'false');
          btn.innerHTML = `
            <span class="flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center border-2 border-n300 text-xs font-heading font-bold text-n500 mt-0.5">${opt.letter}</span>
            <span class="text-sm leading-relaxed text-n700 dark:text-n300">${opt.text}</span>
          `;
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            if (btn.dataset.answered) return;
            // Mark all options in this question as answered
            optContainer.querySelectorAll('button').forEach(b => { b.dataset.answered = 'true'; b.style.pointerEvents = 'none'; b.disabled = true; b.setAttribute('tabindex', '-1'); b.setAttribute('aria-checked', 'false'); });
            btn.setAttribute('aria-checked', 'true');

            if (isCorrect) {
              btn.classList.remove('border-n100', 'dark:border-navy-light');
              btn.classList.add('border-success', 'bg-success/10');
              correct++;
            } else {
              btn.classList.remove('border-n100', 'dark:border-navy-light');
              btn.classList.add('border-danger', 'bg-danger/10');
              // Highlight correct answer
              optContainer.querySelectorAll('button').forEach(b => {
                if (b.querySelector('span').textContent.trim() === q.correct) {
                  b.classList.remove('border-n100', 'dark:border-navy-light');
                  b.classList.add('border-success', 'bg-success/10');
                }
              });
            }
            answered++;

            // Show feedback and move focus to it
            const fb = qDiv.querySelector(`.quiz-feedback-${qi}`);
            if (fb) {
              fb.classList.remove('hidden');
              fb.className = `quiz-feedback-${qi} rounded-lg p-4 mt-3 text-sm ${isCorrect ? 'bg-success/10 border border-success/20' : 'bg-danger/10 border border-danger/20'}`;
              fb.setAttribute('tabindex', '-1');
              var quizLead = q.explanation.split('.')[0];
              var quizRemainder = q.explanation.slice(quizLead.length).replace(/^[.\s]+/, '');
              fb.innerHTML = `<p class="font-heading font-semibold mb-1 ${isCorrect ? 'text-success' : 'text-danger'}">${isCorrect ? quizLead + '.' : 'Not quite \u2014 ' + quizLead.toLowerCase() + '.'}</p>${quizRemainder ? '<p class="text-n700 dark:text-n300">' + quizRemainder + '</p>' : ''}`;
              fb.focus({ preventScroll: true });
            }

            // Update step dots
            updateQuizStepUI();

            // Show "Next Question" button if not the last question
            if (qi < questions.length - 1) {
              var nextBtn = document.createElement('button');
              nextBtn.className = 'quiz-next-btn';
              nextBtn.innerHTML = 'Next Question <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>';
              qDiv.appendChild(nextBtn);
              nextBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                // Hide current question, show next
                qDiv.classList.add('quiz-hidden');
                currentQuizQ = qi + 1;
                var allQDivs = quizBody.querySelectorAll('.quiz-question');
                if (allQDivs[qi + 1]) {
                  allQDivs[qi + 1].classList.remove('quiz-hidden');
                  allQDivs[qi + 1].scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
                updateQuizStepUI();
              });
            }

            // Check if all answered — show results
            if (answered === questions.length) {
              const score = Math.round((correct / questions.length) * 100);
              const passed = score >= 80;
              const results = document.createElement('div');
              results.className = 'text-center py-8 mt-4 border-t border-n100 dark:border-navy-light';
              // Build question-by-question review for retry
              let reviewHtml = '';
              if (!passed) {
                reviewHtml = '<div class="text-left mt-6 mb-4 space-y-3">';
                reviewHtml += '<p class="text-xs font-heading font-bold uppercase tracking-wider text-n500 mb-2">Question Review</p>';
                quizBody.querySelectorAll('.quiz-question').forEach((qd, qi) => {
                  const wasCorrect = qd.querySelector('.border-success [aria-checked="true"]') || (qd.querySelector('[aria-checked="true"]')?.classList.contains('border-success'));
                  const fb = qd.querySelector('[class*="quiz-feedback"]');
                  const fbText = fb ? fb.textContent.substring(0, 120) : '';
                  reviewHtml += '<div class="flex items-start gap-2 p-2.5 rounded-lg ' + (wasCorrect ? 'bg-success/5' : 'bg-danger/5') + '">';
                  reviewHtml += '<span class="flex-shrink-0 mt-0.5">' + (wasCorrect ? '<svg class="w-4 h-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>' : '<svg class="w-4 h-4 text-danger" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>') + '</span>';
                  reviewHtml += '<span class="text-xs text-n700 dark:text-n300">Q' + (qi+1) + ': ' + fbText + '</span></div>';
                });
                reviewHtml += '</div>';
              }

              // Celebration confetti for pass
              let confettiHtml = '';
              if (passed) {
                const colors = ['#00D4AA', '#FF6B35', '#4A90D9', '#FFD700', '#FF3D6E'];
                for (let ci = 0; ci < 20; ci++) {
                  const left = Math.random() * 80 + 10;
                  const delay = Math.random() * 0.5;
                  const color = colors[ci % colors.length];
                  confettiHtml += '<div class="confetti-piece" style="left:' + left + '%;top:20%;background:' + color + ';animation-delay:' + delay + 's;"></div>';
                }
              }

              results.innerHTML = `
                <div style="position:relative;overflow:hidden;padding:2rem 0;">
                  ${confettiHtml}
                  <div class="celebrate-badge w-20 h-20 rounded-full mx-auto mb-4 flex items-center justify-center ${passed ? 'bg-success' : 'bg-danger'}" style="box-shadow: 0 4px 20px ${passed ? 'rgba(0,200,83,0.3)' : 'rgba(255,61,0,0.2)'};">
                    <svg class="w-10 h-10 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="${passed ? 'M5 13l4 4L19 7' : 'M6 18L18 6M6 6l12 12'}" />
                    </svg>
                  </div>
                  <h3 class="text-2xl font-heading font-bold text-navy dark:text-white mb-2">${passed ? 'Module Complete!' : 'Not quite \u2014 review and retry'}</h3>
                  <p class="text-navy dark:text-white font-heading font-semibold text-lg mb-1">${correct} of ${questions.length} correct (${score}%)</p>
                  <p class="text-n500 text-sm mb-4">${passed ? 'You\u2019ve mastered the core concepts. This module is marked complete.' : 'You need ' + threshold + ' of ' + questions.length + ' correct (80%) to pass. Review the feedback below.'}</p>
                  ${passed ? '<div class="inline-block px-4 py-2 bg-success/10 text-success rounded-full text-sm font-heading font-bold mb-6"><svg class="w-4 h-4 inline mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>Badge earned: Welcome to Playbook</div>' : ''}
                  ${reviewHtml}
                  ${passed && nextModuleUrl ? '<a href="' + nextModuleUrl + '" class="inline-block px-6 py-3 bg-teal text-navy font-heading font-bold rounded-lg hover:bg-teal-light transition-colors shadow-md hover:shadow-lg">Continue to ' + (nextModuleTitle ? nextModuleTitle : 'Next Module') + ' &rarr;</a>' : ''}
                  ${passed && !nextModuleUrl ? '<a href="' + ('/tools/playbook/academy/' + programId) + '" class="inline-block px-6 py-3 bg-teal text-navy font-heading font-bold rounded-lg hover:bg-teal-light transition-colors shadow-md hover:shadow-lg">Back to Program &rarr;</a>' : ''}
                  ${!passed ? '<button id="quiz-retry-btn" class="px-6 py-3 bg-orange text-white font-heading font-bold rounded-lg hover:bg-orange-dark transition-colors shadow-md hover:shadow-lg">Review &amp; Retry Quiz</button>' : ''}
                </div>
              `;
              // Reveal all questions so review panel context is visible, remove next buttons
              quizBody.querySelectorAll('.quiz-question').forEach(qd => qd.classList.remove('quiz-hidden'));
              quizBody.querySelectorAll('.quiz-next-btn').forEach(b => b.remove());
              // Hide step progress header since quiz is complete
              if (quizProgressEl) quizProgressEl.style.display = 'none';

              quizBody.appendChild(results);
              requestAnimationFrame(() => {
                results.scrollIntoView({ behavior: 'smooth', block: 'center' });
              });

              // Retry handler
              if (!passed) {
                results.querySelector('#quiz-retry-btn')?.addEventListener('click', (e) => {
                  e.stopPropagation();
                  answered = 0; correct = 0;
                  quizBody.querySelectorAll('button.quiz-option').forEach(b => {
                    b.classList.remove('border-success', 'bg-success/10', 'border-danger', 'bg-danger/10');
                    b.classList.add('border-n100', 'dark:border-navy-light');
                    b.style.pointerEvents = ''; b.dataset.answered = '';
                    b.disabled = false; b.removeAttribute('tabindex'); b.setAttribute('aria-checked', 'false'); b.removeAttribute('aria-disabled');
                  });
                  quizBody.querySelectorAll('[class*="quiz-feedback"]').forEach(f => f.classList.add('hidden'));
                  // Remove "Next Question" buttons from previous attempt
                  quizBody.querySelectorAll('.quiz-next-btn').forEach(b => b.remove());
                  // Reset one-at-a-time: hide all except first, reset step counter
                  currentQuizQ = 0;
                  quizBody.querySelectorAll('.quiz-question').forEach((qd, qi) => {
                    if (qi > 0) qd.classList.add('quiz-hidden');
                    else qd.classList.remove('quiz-hidden');
                  });
                  if (quizProgressEl) quizProgressEl.style.display = '';
                  updateQuizStepUI();
                  results.remove();
                  const firstQ = quizBody.querySelector('.quiz-question');
                  (firstQ || quizBody.firstElementChild || quizContainer).scrollIntoView({ behavior: 'smooth', block: 'start' });
                });
              }

              if (passed) {
                // Lock progress bar at 100%
                moduleIsCompleted = true;
                const _sp = document.getElementById('sidebar-progress-bar');
                const _sl = document.getElementById('sidebar-progress-label');
                if (_sp) _sp.style.width = '100%';
                if (_sl) _sl.textContent = '100% complete';
                try {
                  const key = 'playbook-academy-' + programId;
                  const progress = JSON.parse(localStorage.getItem(key) || '{}');
                  if (!progress[moduleSlug]) progress[moduleSlug] = { completedLessons: [], completed: false, quizScore: null, totalLessons: 0 };
                  progress[moduleSlug].quizScore = score;
                  progress[moduleSlug].completed = true;
                  progress[moduleSlug].lastAccessed = new Date().toISOString();
                  localStorage.setItem(key, JSON.stringify(progress));
                  window.dispatchEvent(new CustomEvent('progress-updated'));
                } catch(e) {}
              }
            }
          });
          optContainer.appendChild(btn);
        });
        quizBody.appendChild(qDiv);
      });

      // Insert quiz after the h2
      quizSection.parentNode.insertBefore(quizContainer, quizSection.nextSibling);
    }
  }

  // ─── 0d. Convert exercise tables into interactive click-to-match ───
  content.querySelectorAll('h3').forEach(h3 => {
    const text = h3.textContent || '';
    if (!text.match(/^Exercise:/)) return;

    const exerciseName = text.replace(/^Exercise:\s*/, '');
    // Find the type, instructions, and table
    let node = h3.nextElementSibling;
    let type = 'drag-and-drop';
    let instructions = '';
    let tableEl = null;

    while (node && node.tagName !== 'H2' && node.tagName !== 'H3') {
      const t = node.textContent || '';
      if (t.match(/^\s*Type:/)) type = t.replace(/^\s*Type:\s*/, '').trim();
      else if (t.match(/^\s*Instructions:/)) instructions = t.replace(/^\s*Instructions:\s*/, '').trim();
      else if (node.tagName === 'TABLE') { tableEl = node; break; }
      node = node.nextElementSibling;
    }

    // Skip generative exercise types — handled by section 0d2
    if (/rewrite|fill-in|reflection|audit/i.test(type)) return;

    if (!tableEl) return;

    // Extract items from table (skip header row)
    const items = [];
    const categories = new Set();
    tableEl.querySelectorAll('tbody tr').forEach(row => {
      const cells = row.querySelectorAll('td');
      if (cells.length >= 4) {
        const item = {
          content: (cells[0].textContent || '').trim(),
          correct: (cells[1].textContent || '').trim(),
          fbCorrect: (cells[2].textContent || '').trim(),
          fbIncorrect: (cells[3].textContent || '').trim(),
        };
        items.push(item);
        categories.add(item.correct);
      }
    });

    if (items.length === 0) return;

    // Hide the raw exercise elements
    h3.style.display = 'none';
    let hideNode = h3.nextElementSibling;
    while (hideNode && hideNode.tagName !== 'H2' && hideNode.tagName !== 'H3') {
      hideNode.style.display = 'none';
      hideNode = hideNode.nextElementSibling;
    }

    // Build interactive exercise UI
    const wrapper = document.createElement('div');
    wrapper.className = 'my-8 rounded-xl border border-n100 dark:border-navy-light overflow-hidden';
    wrapper.dataset.hasExercise = '';
    wrapper.dataset.exerciseId = 'exercise-' + exerciseName.toLowerCase().replace(/[^a-z0-9]+/g, '-');

    const catArray = Array.from(categories);
    let completedCount = 0;

    wrapper.innerHTML = `
      <div class="bg-navy px-5 py-4 flex items-center justify-between">
        <div>
          <span class="text-xs font-heading font-bold uppercase tracking-wider text-teal">Interactive Exercise</span>
          <h3 class="font-heading font-bold text-lg mt-0.5" style="color: white;">${exerciseName}</h3>
        </div>
        <span class="text-sm text-white/60 font-heading exercise-score">${completedCount} of ${items.length}</span>
      </div>
      <div class="p-5 bg-white dark:bg-navy-dark">
        <p class="text-sm text-n500 dark:text-n400 mb-4">${instructions || 'Drag items to a category, or click a button to match.'}</p>
        <div class="category-drop-zones grid gap-3 mb-5" style="grid-template-columns: repeat(${catArray.length}, 1fr);"></div>
        <div class="exercise-items space-y-3"></div>
      </div>
    `;

    // Build category drop zones
    const dropZonesContainer = wrapper.querySelector('.category-drop-zones');
    const dropZones = {};
    catArray.forEach(cat => {
      const zone = document.createElement('div');
      zone.className = 'category-drop-zone';
      zone.dataset.category = cat;
      zone.innerHTML = `<div class="category-drop-zone-label">${cat}</div><div class="drop-zone-items"></div>`;
      zone.addEventListener('dragover', (e) => { e.preventDefault(); zone.classList.add('drag-over'); });
      zone.addEventListener('dragleave', () => { zone.classList.remove('drag-over'); });
      zone.addEventListener('drop', (e) => {
        e.preventDefault();
        zone.classList.remove('drag-over');
        const dragIdx = parseInt(e.dataTransfer.getData('text/plain'), 10);
        if (isNaN(dragIdx)) return;
        const dragItem = items[dragIdx];
        const itemDiv = itemsContainer.querySelectorAll(':scope > div.exercise-item')[dragIdx];
        if (!itemDiv || itemDiv.dataset.answered) return;
        itemDiv.dataset.answered = 'true';
        const isCorrect = cat === dragItem.correct;
        completedCount++;
        scoreLabel.textContent = `${completedCount} of ${items.length}`;
        const chip = document.createElement('span');
        const chipContent = dragItem.content.replace(/^[""\u201C\u201D\u2018\u2019'`]+|[""\u201C\u201D\u2018\u2019'`]+$/g, '');
        chip.className = 'dropped-item ' + (isCorrect ? 'correct' : 'incorrect');
        chip.textContent = chipContent.length > 40 ? chipContent.slice(0, 37) + '\u2026' : chipContent;
        zone.querySelector('.drop-zone-items').appendChild(chip);
        itemDiv.setAttribute('draggable', 'false');
        itemDiv.style.opacity = '0.5';
        itemDiv.style.cursor = 'default';
        const btnContainer = itemDiv.querySelector('.cat-buttons');
        const feedback = itemDiv.querySelector('.exercise-item-feedback');
        btnContainer.querySelectorAll('button').forEach(b => { b.style.pointerEvents = 'none'; b.disabled = true; b.setAttribute('tabindex', '-1'); b.setAttribute('aria-disabled', 'true'); b.setAttribute('aria-checked', 'false'); b.classList.add('opacity-50'); });
        btnContainer.querySelectorAll('button').forEach(b => {
          if (b.textContent === cat) {
            b.setAttribute('aria-checked', 'true');
            if (isCorrect) { b.classList.remove('opacity-50'); b.classList.add('border-success', 'bg-success/10', 'text-success'); }
            else { b.classList.remove('opacity-50'); b.classList.add('border-danger', 'bg-danger/10', 'text-danger'); }
          }
          if (!isCorrect && b.textContent === dragItem.correct) { b.classList.remove('opacity-50'); b.classList.add('border-success', 'bg-success/10', 'text-success'); }
        });
        feedback.classList.remove('hidden');
        feedback.className = `exercise-item-feedback mt-3 rounded-lg p-3 text-sm ${isCorrect ? 'bg-success/10 border border-success/20' : 'bg-danger/10 border border-danger/20'}`;
        if (isCorrect) itemDiv.classList.add('exercise-item-correct');
        const fbText = isCorrect ? dragItem.fbCorrect : dragItem.fbIncorrect;
        const teachLead = fbText.split(/[.!]/)[0];
        const fbRemainder = fbText.slice(teachLead.length).replace(/^[.!\s]+/, '');
        feedback.innerHTML = `<p class="font-heading font-semibold mb-1 ${isCorrect ? 'text-success' : 'text-danger'}">${teachLead}.</p>${fbRemainder ? '<p class="text-n700 dark:text-n300">' + fbRemainder + '</p>' : ''}`;
        try {
          const key = 'playbook-academy-' + programId;
          const progress = JSON.parse(localStorage.getItem(key) || '{}');
          if (!progress[moduleSlug]) progress[moduleSlug] = { completedLessons: [], completed: false, quizScore: null, totalLessons: 0 };
          const exId = 'exercise-' + exerciseName.toLowerCase().replace(/[^a-z0-9]+/g, '-');
          if (!progress[moduleSlug].completedLessons.includes(exId)) progress[moduleSlug].completedLessons.push(exId);
          localStorage.setItem(key, JSON.stringify(progress));
          window.dispatchEvent(new CustomEvent('exercise-completed', { detail: { exerciseId: exId } }));
        } catch(e) {}
        try {
          var exStateKey = 'playbook-academy-ex-state-' + moduleSlug;
          var exState = JSON.parse(localStorage.getItem(exStateKey) || '{}');
          var exId2 = wrapper.dataset.exerciseId;
          if (!exState[exId2]) exState[exId2] = {};
          exState[exId2][dragIdx] = { chosen: cat, isCorrect: isCorrect };
          localStorage.setItem(exStateKey, JSON.stringify(exState));
        } catch(e) {}
      });
      dropZonesContainer.appendChild(zone);
      dropZones[cat] = zone;
    });

    const itemsContainer = wrapper.querySelector('.exercise-items');
    const scoreLabel = wrapper.querySelector('.exercise-score');

    items.forEach((item, idx) => {
      const itemDiv = document.createElement('div');
      itemDiv.className = 'exercise-item p-4 rounded-lg border border-n100 dark:border-navy-light bg-n50 dark:bg-navy';
      itemDiv.setAttribute('draggable', 'true');
      itemDiv.addEventListener('dragstart', (e) => {
        if (itemDiv.dataset.answered) { e.preventDefault(); return; }
        e.dataTransfer.setData('text/plain', String(idx));
        e.dataTransfer.effectAllowed = 'move';
        itemDiv.style.opacity = '0.5';
      });
      itemDiv.addEventListener('dragend', () => {
        if (!itemDiv.dataset.answered) itemDiv.style.opacity = '1';
      });
      const displayContent = item.content.replace(/^[""\u201C\u201D\u2018\u2019'`]+|[""\u201C\u201D\u2018\u2019'`]+$/g, '');
      itemDiv.innerHTML = `
        <p class="text-sm font-semibold text-navy dark:text-white mb-3">\u201C${displayContent}\u201D</p>
        <div class="flex flex-wrap gap-2 cat-buttons" role="radiogroup" aria-label="Category choices"></div>
        <div class="exercise-item-feedback hidden mt-3 rounded-lg p-3 text-sm" tabindex="-1"></div>
      `;

      const btnContainer = itemDiv.querySelector('.cat-buttons');
      const feedback = itemDiv.querySelector('.exercise-item-feedback');

      catArray.forEach(cat => {
        const btn = document.createElement('button');
        btn.className = 'px-3 py-1.5 rounded-lg border border-n300 dark:border-navy-light text-xs font-heading font-semibold text-navy dark:text-n300 hover:border-teal hover:bg-teal/5 transition-all';
        btn.setAttribute('role', 'radio');
        btn.setAttribute('aria-checked', 'false');
        btn.textContent = cat;
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (itemDiv.dataset.answered) return;
          itemDiv.dataset.answered = 'true';
          const isCorrect = cat === item.correct;
          completedCount++;
          scoreLabel.textContent = `${completedCount} of ${items.length}`;

          // Persist exercise completion
          try {
            const key = 'playbook-academy-' + programId;
            const progress = JSON.parse(localStorage.getItem(key) || '{}');
            if (!progress[moduleSlug]) progress[moduleSlug] = { completedLessons: [], completed: false, quizScore: null, totalLessons: 0 };
            const exId = 'exercise-' + exerciseName.toLowerCase().replace(/[^a-z0-9]+/g, '-');
            if (!progress[moduleSlug].completedLessons.includes(exId)) {
              progress[moduleSlug].completedLessons.push(exId);
            }
            localStorage.setItem(key, JSON.stringify(progress));
            window.dispatchEvent(new CustomEvent('exercise-completed', { detail: { exerciseId: exId } }));
          } catch(e) {}

          // Persist individual item answer for visual restore
          try {
            var exStateKey = 'playbook-academy-ex-state-' + moduleSlug;
            var exState = JSON.parse(localStorage.getItem(exStateKey) || '{}');
            var exId2 = wrapper.dataset.exerciseId;
            if (!exState[exId2]) exState[exId2] = {};
            exState[exId2][idx] = { chosen: cat, isCorrect: isCorrect };
            localStorage.setItem(exStateKey, JSON.stringify(exState));
          } catch(e) {}

          // Disable all buttons for this item
          btnContainer.querySelectorAll('button').forEach(b => { b.style.pointerEvents = 'none'; b.disabled = true; b.setAttribute('tabindex', '-1'); b.setAttribute('aria-disabled', 'true'); b.setAttribute('aria-checked', 'false'); b.classList.add('opacity-50'); });
          btn.setAttribute('aria-checked', 'true');

          // Highlight selected
          if (isCorrect) {
            btn.classList.remove('border-n300', 'dark:border-navy-light', 'opacity-50');
            btn.classList.add('border-success', 'bg-success/10', 'text-success');
          } else {
            btn.classList.remove('border-n300', 'dark:border-navy-light', 'opacity-50');
            btn.classList.add('border-danger', 'bg-danger/10', 'text-danger');
            // Highlight correct
            btnContainer.querySelectorAll('button').forEach(b => {
              if (b.textContent === item.correct) {
                b.classList.remove('opacity-50');
                b.classList.add('border-success', 'bg-success/10', 'text-success');
              }
            });
          }

          // Show feedback and move focus to it
          feedback.classList.remove('hidden');
          feedback.className = `exercise-item-feedback mt-3 rounded-lg p-3 text-sm ${isCorrect ? 'bg-success/10 border border-success/20' : 'bg-danger/10 border border-danger/20'}`;
          feedback.setAttribute('tabindex', '-1');
          const fbText = isCorrect ? item.fbCorrect : item.fbIncorrect;
          const teachLead = fbText.split(/[.!]/)[0];
          const fbRemainder = fbText.slice(teachLead.length).replace(/^[.!\s]+/, '');
          feedback.innerHTML = `<p class="font-heading font-semibold mb-1 ${isCorrect ? 'text-success' : 'text-danger'}">${teachLead}.</p>${fbRemainder ? '<p class="text-n700 dark:text-n300">' + fbRemainder + '</p>' : ''}`;
          feedback.focus({ preventScroll: true });
        });
        btnContainer.appendChild(btn);
      });

      itemsContainer.appendChild(itemDiv);
    });

    // Restore saved exercise state on reload
    try {
      var exStateKey = 'playbook-academy-ex-state-' + moduleSlug;
      var exState = JSON.parse(localStorage.getItem(exStateKey) || '{}');
      var savedItems = exState[wrapper.dataset.exerciseId];
      if (savedItems) {
        var allItemDivs = itemsContainer.querySelectorAll(':scope > div.exercise-item');
        items.forEach(function(item, idx) {
          var saved = savedItems[idx];
          if (!saved) return;
          var itemDiv = allItemDivs[idx];
          if (!itemDiv) return;
          itemDiv.dataset.answered = 'true';
          itemDiv.setAttribute('draggable', 'false');
          itemDiv.style.opacity = '0.5';
          itemDiv.style.cursor = 'default';
          completedCount++;
          var btnContainer = itemDiv.querySelector('.cat-buttons');
          var feedback = itemDiv.querySelector('.exercise-item-feedback');
          if (dropZones[saved.chosen]) {
            var chip = document.createElement('span');
            var chipContent = item.content.replace(/^[""\u201C\u201D\u2018\u2019'`]+|[""\u201C\u201D\u2018\u2019'`]+$/g, '');
            chip.className = 'dropped-item ' + (saved.isCorrect ? 'correct' : 'incorrect');
            chip.textContent = chipContent.length > 40 ? chipContent.slice(0, 37) + '\u2026' : chipContent;
            dropZones[saved.chosen].querySelector('.drop-zone-items').appendChild(chip);
          }
          btnContainer.querySelectorAll('button').forEach(function(b) {
            b.style.pointerEvents = 'none'; b.disabled = true;
            b.setAttribute('tabindex', '-1'); b.setAttribute('aria-disabled', 'true');
            b.setAttribute('aria-checked', 'false'); b.classList.add('opacity-50');
            if (b.textContent === saved.chosen) {
              b.setAttribute('aria-checked', 'true');
              if (saved.isCorrect) {
                b.classList.remove('border-n300', 'dark:border-navy-light', 'opacity-50');
                b.classList.add('border-success', 'bg-success/10', 'text-success');
              } else {
                b.classList.remove('border-n300', 'dark:border-navy-light', 'opacity-50');
                b.classList.add('border-danger', 'bg-danger/10', 'text-danger');
              }
            }
            if (!saved.isCorrect && b.textContent === item.correct) {
              b.classList.remove('opacity-50');
              b.classList.add('border-success', 'bg-success/10', 'text-success');
            }
          });
          var fbText = saved.isCorrect ? item.fbCorrect : item.fbIncorrect;
          var teachLead = fbText.split(/[.!]/)[0];
          var fbRemainder = fbText.slice(teachLead.length).replace(/^[.!\s]+/, '');
          feedback.classList.remove('hidden');
          feedback.className = 'exercise-item-feedback mt-3 rounded-lg p-3 text-sm ' + (saved.isCorrect ? 'bg-success/10 border border-success/20' : 'bg-danger/10 border border-danger/20');
          feedback.innerHTML = '<p class="font-heading font-semibold mb-1 ' + (saved.isCorrect ? 'text-success' : 'text-danger') + '">' + teachLead + '.</p>' + (fbRemainder ? '<p class="text-n700 dark:text-n300">' + fbRemainder + '</p>' : '');
        });
        scoreLabel.textContent = completedCount + ' of ' + items.length;
      }
    } catch(e) {}

    // Insert after the hidden elements
    h3.parentNode.insertBefore(wrapper, h3);
  });

  // ─── 0d2. Handle generative exercises (rewrite / fill-in-blank / reflection / audit-rewrite) ───
  content.querySelectorAll('h3').forEach(h3 => {
    const text = h3.textContent || '';
    if (!text.match(/^Exercise:/i)) return;
    // Skip if already processed by section 0d (would be hidden)
    if (h3.style.display === 'none') return;

    // Scan siblings for type, instructions, table, model answer blockquote
    let node = h3.nextElementSibling;
    let type = '';
    let fillinInstructions = '';
    let modelAnswer = '';
    let tableEl = null;
    let fillinListHtml = '';
    let extraContentHtml = '';
    while (node && node.tagName !== 'H2' && node.tagName !== 'H3') {
      const t = node.textContent || '';
      if (t.match(/^\s*\*?\*?Type:\*?\*?\s*/)) type = t.replace(/^\s*\*?\*?Type:\*?\*?\s*/, '').trim().toLowerCase();
      else if (t.match(/^\s*\*?\*?Instructions:\*?\*?\s*/)) fillinInstructions = t.replace(/^\s*\*?\*?Instructions:\*?\*?\s*/, '').trim();
      else if (node.tagName === 'OL') fillinListHtml = node.outerHTML;
      else if (node.tagName === 'UL' && !tableEl) extraContentHtml += node.outerHTML;
      if (node.tagName === 'TABLE') tableEl = node;
      if (node.tagName === 'BLOCKQUOTE') {
        var bqText = node.textContent || '';
        if (bqText.match(/Model answer:/i)) {
          modelAnswer = bqText.replace(/^\s*\*?\*?Model answer:\*?\*?\s*/i, '').trim();
        }
      }
      // Also capture paragraphs that contain task/prompt content (for multi-task exercises)
      if (node.tagName === 'P' && !t.match(/^\s*\*?\*?Type:/) && !t.match(/^\s*\*?\*?Instructions:/) && type && fillinInstructions && !tableEl) {
        extraContentHtml += node.outerHTML;
      }
      node = node.nextElementSibling;
    }

    // Only handle generative types or exercises with fillable tables
    var isGenerative = /rewrite|fill-in|reflection|audit/i.test(type);
    var hasFillableTable = false;
    if (tableEl && !isGenerative) {
      tableEl.querySelectorAll('tbody tr').forEach(function(row) {
        var cells = row.querySelectorAll('td');
        if (cells.length === 2) {
          var val = (cells[1].textContent || '').trim();
          if (val === '' || val.match(/^\(.*\)$/) || val.match(/^\*?\(.*\)\*?$/) || val.match(/Write this|Your /i)) {
            hasFillableTable = true;
          }
        }
      });
    }
    if (!isGenerative && !modelAnswer && !hasFillableTable) return;

    const exerciseName = text.replace(/^Exercise:\s*/, '');

    // For rewrite exercises with a table, extract original text and model rewrite
    var originalText = '';
    var modelRewrite = '';
    var rewriteRows = [];
    if (tableEl && /rewrite|audit/i.test(type)) {
      tableEl.querySelectorAll('tbody tr').forEach(function(row) {
        var cells = row.querySelectorAll('td');
        if (cells.length >= 3) {
          rewriteRows.push({
            original: (cells[0].textContent || '').trim(),
            audit: (cells[1].textContent || '').trim(),
            model: (cells[2].textContent || '').trim(),
            feedback: cells.length >= 4 ? (cells[3].textContent || '').trim() : ''
          });
        } else if (cells.length === 2) {
          rewriteRows.push({
            original: (cells[0].textContent || '').trim(),
            audit: '',
            model: (cells[1].textContent || '').trim(),
            feedback: ''
          });
        }
      });
      if (rewriteRows.length > 0) {
        originalText = rewriteRows.map(function(r) { return r.original; }).join('\n\n');
        modelRewrite = rewriteRows.map(function(r) { return r.model; }).join('\n\n');
      }
    }

    // For fill-in-blank exercises with a table (e.g., "Write a Quiz Question", "Design an A/B Test")
    var fillableTableHtml = '';
    if (tableEl && /fill-in|scenario/i.test(type) && !(/rewrite|audit/i.test(type))) {
      var rows = tableEl.querySelectorAll('tbody tr');
      var hasFillable = false;
      rows.forEach(function(row) {
        var cells = row.querySelectorAll('td');
        if (cells.length === 2) {
          var val = (cells[1].textContent || '').trim();
          if (val === '' || val.match(/^\(.*\)$/) || val.match(/^\*?\(.*\)\*?$/) || val.match(/Write this|Your /i)) {
            hasFillable = true;
          }
        }
      });
      if (hasFillable) {
        fillableTableHtml = '<div class="mb-4 text-sm text-n700 dark:text-n300 overflow-x-auto">' + tableEl.outerHTML + '</div>';
      }
    }

    // Use model from table if no blockquote model answer
    if (!modelAnswer && modelRewrite) {
      modelAnswer = modelRewrite;
    }

    // Hide raw exercise content
    let hideNode = h3.nextElementSibling;
    h3.style.display = 'none';
    while (hideNode && hideNode.tagName !== 'H2' && hideNode.tagName !== 'H3') {
      hideNode.style.display = 'none';
      hideNode = hideNode.nextElementSibling;
    }

    // Determine label based on type
    var exerciseLabel = /rewrite|audit/i.test(type) ? 'Rewrite Exercise' : /reflection/i.test(type) ? 'Reflection Exercise' : 'Writing Exercise';
    var placeholder = /rewrite|audit/i.test(type) ? 'Type your rewrite here...' : 'Type your answer here...';
    var fillinPrompt = fillinInstructions || (/rewrite|audit/i.test(type) ? 'Rewrite the text below, then compare with the model answer.' : 'Write your answer below.');

    // Build context block for rewrite exercises (show original text)
    var contextHtml = '';
    if (rewriteRows.length > 0) {
      contextHtml = '<div class="mb-4 space-y-3">';
      rewriteRows.forEach(function(r, i) {
        contextHtml += '<div class="p-4 rounded-lg bg-n50 dark:bg-navy border border-n100 dark:border-navy-light">';
        if (rewriteRows.length > 1) contextHtml += '<p class="text-xs font-heading font-bold uppercase tracking-wider text-n500 dark:text-n400 mb-2">Item ' + (i + 1) + '</p>';
        contextHtml += '<p class="text-sm text-n700 dark:text-n300 leading-relaxed"><span class="font-heading font-semibold text-navy dark:text-white">Original: </span>' + r.original + '</p>';
        if (r.audit) contextHtml += '<p class="text-sm text-n500 dark:text-n400 mt-2 leading-relaxed"><span class="font-heading font-semibold">Issues: </span>' + r.audit + '</p>';
        if (r.feedback) contextHtml += '<p class="text-xs text-n400 dark:text-n500 mt-2 italic">' + r.feedback + '</p>';
        contextHtml += '</div>';
      });
      contextHtml += '</div>';
    }

    // Build interactive exercise
    const wrapper = document.createElement('div');
    wrapper.className = 'my-8 rounded-xl border border-n100 dark:border-navy-light overflow-hidden';
    wrapper.innerHTML = `
      <div class="bg-navy px-5 py-4">
        <span class="text-xs font-heading font-bold uppercase tracking-wider text-teal">${exerciseLabel}</span>
        <h3 class="font-heading font-bold text-lg mt-0.5" style="color: white;">${exerciseName}</h3>
      </div>
      <div class="p-5 bg-white dark:bg-navy-dark">
        <p class="text-sm text-n500 dark:text-n400 mb-4">${fillinPrompt}</p>
        ${fillinListHtml ? '<div class="mb-4 text-sm text-n700 dark:text-n300 space-y-1 pl-1">' + fillinListHtml + '</div>' : ''}
        ${extraContentHtml ? '<div class="mb-4 text-sm text-n700 dark:text-n300">' + extraContentHtml + '</div>' : ''}
        ${fillableTableHtml}
        ${contextHtml}
        <textarea class="fillin-textarea w-full p-3 rounded-lg border border-n100 dark:border-navy-light bg-n50 dark:bg-navy text-n700 dark:text-n300 text-sm leading-relaxed min-h-[120px] focus:outline-none focus:ring-2 focus:ring-teal" placeholder="${placeholder}"></textarea>
        <div class="flex items-center justify-between mt-3">
          <button class="fillin-reveal px-4 py-2 rounded-lg bg-n300 text-white font-heading font-semibold text-sm cursor-not-allowed transition-colors" disabled aria-disabled="true">Write your answer first</button>
          <span class="fillin-wordcount text-xs text-n400 font-heading">0 words</span>
        </div>
        <div class="fillin-model hidden mt-4 p-4 rounded-lg bg-teal/5 dark:bg-teal/10 border border-teal/20">
          <p class="text-xs font-heading font-semibold uppercase tracking-wider text-teal mb-2">Model Answer</p>
          <p class="text-n700 dark:text-n300 text-sm leading-relaxed whitespace-pre-line">${modelAnswer || 'Model answer not available.'}</p>
        </div>
      </div>
    `;

    const textarea = wrapper.querySelector('.fillin-textarea');
    const revealBtn = wrapper.querySelector('.fillin-reveal');
    const wordcount = wrapper.querySelector('.fillin-wordcount');
    const MIN_WORDS = 10;

    var fillinKey = 'playbook-academy-fillin-' + moduleSlug + '-' + exerciseName.toLowerCase().replace(/[^a-z0-9]+/g, '-');

    textarea?.addEventListener('input', function() {
      const words = this.value.trim().split(/\s+/).filter(w => w.length > 0).length;
      if (wordcount) wordcount.textContent = words + ' word' + (words !== 1 ? 's' : '');
      if (words >= MIN_WORDS) {
        revealBtn.disabled = false;
        revealBtn.setAttribute('aria-disabled', 'false');
        revealBtn.className = 'fillin-reveal px-4 py-2 rounded-lg bg-navy text-white font-heading font-semibold text-sm hover:bg-navy-light transition-colors cursor-pointer';
        revealBtn.textContent = 'Compare with Model Answer';
      } else {
        revealBtn.disabled = true;
        revealBtn.setAttribute('aria-disabled', 'true');
        revealBtn.className = 'fillin-reveal px-4 py-2 rounded-lg bg-n300 text-white font-heading font-semibold text-sm cursor-not-allowed transition-colors';
        revealBtn.textContent = (MIN_WORDS - words) + ' more word' + ((MIN_WORDS - words) !== 1 ? 's' : '') + ' needed';
      }
      // Persist textarea content
      try {
        var saved = JSON.parse(localStorage.getItem(fillinKey) || '{}');
        saved.text = this.value;
        localStorage.setItem(fillinKey, JSON.stringify(saved));
      } catch(e) {}
    });

    revealBtn?.addEventListener('click', function(e) {
      e.stopPropagation();
      if (this.disabled) return;
      const model = wrapper.querySelector('.fillin-model');
      if (model) {
        model.classList.toggle('hidden');
        this.textContent = model.classList.contains('hidden') ? 'Compare with Model Answer' : 'Hide Model Answer';
        // Persist reveal state
        try {
          var saved = JSON.parse(localStorage.getItem(fillinKey) || '{}');
          saved.revealed = !model.classList.contains('hidden');
          localStorage.setItem(fillinKey, JSON.stringify(saved));
        } catch(e) {}
      }
    });

    // Restore saved state on reload
    try {
      var savedFillin = JSON.parse(localStorage.getItem(fillinKey) || '{}');
      if (savedFillin.text) {
        textarea.value = savedFillin.text;
        textarea.dispatchEvent(new Event('input'));
        if (savedFillin.revealed) {
          var model = wrapper.querySelector('.fillin-model');
          if (model) {
            model.classList.remove('hidden');
            revealBtn.textContent = 'Hide Model Answer';
          }
        }
      }
    } catch(e) {}

    h3.parentNode.insertBefore(wrapper, h3);
  });

  // ─── 0d3. Final sweep: hide any remaining raw tables/paragraphs leaked from exercises & quizzes ───
  // Exercise sections: any <table> still visible inside a region between an Exercise: h3 and the next h2/h3
  content.querySelectorAll('h3').forEach(function(h3) {
    if (!(h3.textContent || '').match(/^Exercise:/i)) return;
    var sib = h3.nextElementSibling;
    while (sib && sib.tagName !== 'H2' && sib.tagName !== 'H3') {
      if (sib.tagName === 'TABLE' && sib.style.display !== 'none') sib.style.display = 'none';
      sib = sib.nextElementSibling;
    }
  });
  // Quiz / Module Test section: hide any remaining visible tables and answer-key paragraphs
  // IMPORTANT: skip the dynamically-created interactive quiz container (has #quiz-body inside)
  if (quizSection) {
    var qSib = quizSection.nextElementSibling;
    while (qSib && qSib.tagName !== 'H2') {
      if (qSib.style.display !== 'none' && !qSib.querySelector('#quiz-body')) qSib.style.display = 'none';
      qSib = qSib.nextElementSibling;
    }
  }
  // Hide stray answer-key paragraphs anywhere in the prose (Stem:, Correct:, Explanation:, Assesses:, Source:)
  content.querySelectorAll('p').forEach(function(p) {
    var t = p.textContent || '';
    if (/^\s*(Stem:|Correct:|Explanation:|Assesses:|Source:)/i.test(t)) {
      p.style.display = 'none';
    }
  });

  // ─── 0e. Hide narrator stage directions ───
  content.querySelectorAll('blockquote').forEach(bq => {
    bq.innerHTML = bq.innerHTML
      .replace(/\[transition slide\]/gi, '')
      .replace(/\[show [^\]]+\]/gi, '')
      .replace(/\[pause\]/gi, '')
      .replace(/\[key point\]/gi, '')
      .replace(/\[highlight [^\]]+\]/gi, '')
      .replace(/\[transition to [^\]]+\]/gi, '')
      .replace(/\[transition\]/gi, '')
      .replace(/\[read [^\]]+\]/gi, '')
      .replace(/\[walk through [^\]]+\]/gi, '');
  });

  // ─── 0f. Transform "Failure N:" paragraphs into visual cards ───
  (function() {
    const failurePattern = /^\s*\*\*Failure\s+(\d+):\s*([^.*]+)\.?\*\*\s*(.*)/s;
    const paragraphs = Array.from(content.querySelectorAll('p'));
    let failureCards = [];
    let failureInsertPoint = null;

    paragraphs.forEach(p => {
      const html = p.innerHTML || '';
      const match = html.match(/^<strong>Failure\s+(\d+):\s*([^.<]+)\.?<\/strong>\s*([\s\S]*)/);
      if (match) {
        failureCards.push({ num: match[1], title: match[2].trim(), body: match[3].trim() });
        if (!failureInsertPoint) failureInsertPoint = p;
        p.style.display = 'none';
      }
    });

    if (failureCards.length > 0 && failureInsertPoint) {
      const grid = document.createElement('div');
      grid.className = 'numbered-card-grid cols-2';
      failureCards.forEach(c => {
        const card = document.createElement('div');
        card.className = 'numbered-card card-failure';
        card.innerHTML = `
          <div class="numbered-card-number">${c.num}</div>
          <div class="numbered-card-title">${c.title}</div>
          <div class="numbered-card-body">${c.body}</div>
        `;
        grid.appendChild(card);
      });
      failureInsertPoint.parentNode.insertBefore(grid, failureInsertPoint);
    }
  })();

  // ─── 0g. Transform "Premise N:" paragraphs into visual cards ───
  (function() {
    const paragraphs = Array.from(content.querySelectorAll('p'));
    let premiseCards = [];
    let premiseInsertPoint = null;

    paragraphs.forEach(p => {
      const html = p.innerHTML || '';
      const match = html.match(/^<strong>Premise\s+(\d+):\s*([^.<]+)\.?<\/strong>\s*([\s\S]*)/);
      if (match) {
        premiseCards.push({ num: match[1], title: match[2].trim(), body: match[3].trim() });
        if (!premiseInsertPoint) premiseInsertPoint = p;
        p.style.display = 'none';
      }
    });

    if (premiseCards.length > 0 && premiseInsertPoint) {
      const grid = document.createElement('div');
      grid.className = 'numbered-card-grid cols-2';
      premiseCards.forEach(c => {
        const card = document.createElement('div');
        card.className = 'numbered-card card-premise';
        card.innerHTML = `
          <div class="numbered-card-number">${c.num}</div>
          <div class="numbered-card-title">${c.title}</div>
          <div class="numbered-card-body">${c.body}</div>
        `;
        grid.appendChild(card);
      });
      premiseInsertPoint.parentNode.insertBefore(grid, premiseInsertPoint);
    }
  })();

  // ─── 0h. Transform "Pillar N:" paragraphs into visual cards ───
  (function() {
    const paragraphs = Array.from(content.querySelectorAll('p'));
    let pillarCards = [];
    let pillarInsertPoint = null;

    paragraphs.forEach(p => {
      const html = p.innerHTML || '';
      // Match: **Pillar 1: Open — "No fine print."**
      const match = html.match(/^<strong>Pillar\s+(\d+):\s*(\w+)\s*[\u2014—-]+\s*[\u201C""]([^"\u201D\u201C]+)[\u201D""]\.?<\/strong>\s*([\s\S]*)/);
      if (match) {
        pillarCards.push({ num: match[1], name: match[2].trim(), tagline: match[3].trim(), body: match[4].trim() });
        if (!pillarInsertPoint) pillarInsertPoint = p;
        p.style.display = 'none';
      }
    });

    if (pillarCards.length > 0 && pillarInsertPoint) {
      const grid = document.createElement('div');
      grid.className = 'numbered-card-grid cols-2';
      const pillarIcons = {
        'Open': '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>',
        'Social': '<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>'
      };
      pillarCards.forEach(c => {
        const card = document.createElement('div');
        card.className = 'numbered-card card-pillar';
        card.innerHTML = `
          <div class="numbered-card-number">${pillarIcons[c.name] || c.num}</div>
          <div class="pillar-tagline">${c.tagline}</div>
          <div class="numbered-card-title">${c.name}</div>
          <div class="numbered-card-body">${c.body}</div>

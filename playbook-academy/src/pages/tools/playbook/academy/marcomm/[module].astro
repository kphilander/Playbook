          icon.className = 'section-icon';
          icon.style.cssText = `background:${config.bg};`;
          icon.innerHTML = `<svg class="w-5 h-5" style="color:${config.color}" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">${config.svg}</svg>`;
          h2.insertBefore(icon, h2.firstChild);
          h2.style.display = 'flex';
          h2.style.alignItems = 'center';
          break;
        }
      }
    });
  })();

  // ─── 1. Style the prose content ───
  content.querySelectorAll('h1').forEach(h => {
    h.classList.add('text-3xl', 'font-heading', 'font-bold', 'text-navy', 'dark:text-white', 'mb-6');
    h.style.display = 'none';
  });

  content.querySelectorAll('h2').forEach(h => {
    h.classList.add('text-2xl', 'font-heading', 'font-bold', 'text-navy', 'dark:text-white', 'mt-10', 'mb-6', 'pb-3', 'border-b', 'border-n100', 'dark:border-navy-light', 'scroll-mt-20');
  });

  content.querySelectorAll('h3').forEach(h => {
    h.classList.add('text-lg', 'font-heading', 'font-semibold', 'text-navy', 'dark:text-white', 'mt-8', 'mb-4');
  });

  content.querySelectorAll('p').forEach(p => {
    p.classList.add('text-n700', 'dark:text-n300', 'leading-relaxed', 'mb-4');
  });

  // Lead paragraphs: first p after each h2 gets larger text (matching existing site)
  content.querySelectorAll('h2').forEach(h2 => {
    let next = h2.nextElementSibling;
    if (next && next.tagName === 'P') {
      next.classList.add('text-lg', 'text-n600');
      next.classList.remove('text-n700');
    }
  });

  content.querySelectorAll('ul, ol').forEach(l => {
    l.classList.add('text-n700', 'dark:text-n300', 'leading-relaxed', 'mb-4', 'ml-6');
  });

  content.querySelectorAll('li').forEach(li => {
    li.classList.add('mb-1');
  });

  content.querySelectorAll('strong').forEach(s => {
    s.classList.add('text-navy', 'dark:text-white', 'font-semibold');
  });

  content.querySelectorAll('table').forEach(t => {
    t.classList.add('w-full', 'text-sm', 'mb-6', 'border-collapse');
    t.querySelectorAll('th').forEach(th => {
      th.classList.add('font-heading', 'text-left', 'text-navy', 'dark:text-white', 'bg-n50', 'dark:bg-navy-light', 'px-4', 'py-2.5', 'border-b', 'border-n100', 'text-sm', 'font-semibold');
    });
    t.querySelectorAll('td').forEach(td => {
      td.classList.add('px-4', 'py-2.5', 'border-b', 'border-n100', 'dark:border-navy-light', 'align-top', 'text-n700', 'dark:text-n300');
    });
    // Wrap table in a scrollable container for responsive overflow
    if (!t.parentElement?.classList.contains('table-wrapper')) {
      const wrapper = document.createElement('div');
      wrapper.className = 'table-wrapper';
      t.parentNode.insertBefore(wrapper, t);
      wrapper.appendChild(t);
    }
  });

  content.querySelectorAll('blockquote').forEach(bq => {
    bq.classList.add('border-l-4', 'border-teal', 'bg-teal/5', 'dark:bg-teal/10', 'px-5', 'py-4', 'rounded-r-xl', 'my-6', 'text-n700', 'dark:text-n300');
    // Style narrator blockquotes differently
    const firstStrong = bq.querySelector('strong');
    if (firstStrong && firstStrong.textContent.includes('Narrator')) {
      bq.classList.remove('border-teal', 'bg-teal/5', 'dark:bg-teal/10');
      bq.classList.add('border-navy-light', 'bg-navy/5', 'dark:bg-white/5', 'italic');
      // Add audio icon
      const icon = document.createElement('div');
      icon.className = 'flex items-center gap-2 text-xs font-heading font-semibold uppercase tracking-wider text-n500 dark:text-n400 mb-2 not-italic';
      icon.innerHTML = '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/></svg> Narrator Script';
      bq.insertBefore(icon, bq.firstChild);
    }
    // Style operator integration points
    if (firstStrong && firstStrong.textContent.includes('Operator')) {
      bq.classList.remove('border-teal', 'bg-teal/5', 'dark:bg-teal/10');
      bq.classList.add('border-orange', 'bg-orange/5', 'dark:bg-orange/10');
    }
  });

  content.querySelectorAll('code').forEach(c => {
    if (!c.parentElement?.matches('pre')) {
      c.classList.add('text-teal-dark', 'dark:text-teal', 'bg-teal/10', 'px-1.5', 'py-0.5', 'rounded', 'text-sm', 'font-mono');
    }
  });

  content.querySelectorAll('hr').forEach(hr => {
    hr.classList.add('border-n100', 'dark:border-navy-light', 'my-8');
  });

  // ─── Key Takeaway boxes ───
  content.querySelectorAll('h2').forEach(h2 => {
    if (h2.textContent.match(/Key Takeaway/i)) {
      const wrapper = document.createElement('div');
      wrapper.className = 'key-takeaway-wrapper mb-8 p-6 rounded-xl bg-navy/5 dark:bg-white/5 border border-navy/10 dark:border-white/10';
      // Restyle heading
      h2.classList.remove('border-b', 'border-n100', 'dark:border-navy-light', 'pb-3', 'mt-10');
      h2.classList.add('flex', 'items-center', 'gap-2', 'text-lg', 'mb-3');
      h2.style.marginTop = '0'; h2.style.borderBottom = 'none'; h2.style.paddingBottom = '0';
      const icon = document.createElement('span');
      icon.innerHTML = '<svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
      h2.insertBefore(icon, h2.firstChild);
      // Capture the first sibling BEFORE any DOM changes
      let firstSibling = h2.nextElementSibling;
      const parent = h2.parentNode;
      // Insert wrapper at h2's position, then move h2 into it
      parent.insertBefore(wrapper, h2);
      wrapper.appendChild(h2);
      // Now loop from the saved sibling and move content into wrapper
      let next = firstSibling;
      while (next && next.tagName !== 'H2' && !next.classList.contains('module-section')) {
        const toMove = next;
        next = next.nextElementSibling;
        wrapper.appendChild(toMove);
      }
    }
  });

  // ─── Module Test section styling ───
  content.querySelectorAll('h2').forEach(h2 => {
    if (h2.textContent.match(/Module Test/i)) {
      h2.classList.remove('border-b', 'border-n100', 'dark:border-navy-light', 'pb-3');
      h2.classList.add('text-orange', 'dark:text-orange-light');
      // Add test icon
      const icon = document.createElement('span');
      icon.innerHTML = '<svg class="w-6 h-6 text-orange inline mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
      h2.insertBefore(icon, h2.firstChild);
    }
  });

  // ─── 2. Wrap h2 sections in <section> elements ───
  const h2s = Array.from(content.querySelectorAll('h2'));
  const sections = [];

  h2s.forEach((h2, i) => {
    const title = h2.textContent.trim();
    const slug = title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

    // Collect all siblings until next h2
    const sectionEl = document.createElement('section');
    sectionEl.id = `section-${slug}`;
    sectionEl.dataset.slideIndex = String(i);
    sectionEl.dataset.lessonSlug = slug;
    sectionEl.className = 'module-section py-8 scroll-mt-20';

    // Check if this section has an exercise
    let node = h2.nextElementSibling;
    let hasExercise = false;
    const tempNodes = [h2];
    while (node && node.tagName !== 'H2') {
      if (node.textContent.includes('Exercise:') || node.textContent.includes('Type:')) {
        hasExercise = true;
      }
      tempNodes.push(node);
      node = node.nextElementSibling;
    }

    if (hasExercise) sectionEl.dataset.hasExercise = '';

    // Move nodes into section
    h2.parentNode.insertBefore(sectionEl, h2);
    tempNodes.forEach(n => sectionEl.appendChild(n));

    sections.push({ slug, title, hasExercise, index: i });
  });

  // ─── 3. Build sidebar navigation ───
  const sidebarNav = document.getElementById('sidebar-nav');
  if (sidebarNav && sections.length > 0) {
    const ul = document.createElement('ul');
    ul.className = 'space-y-0.5';

    let visibleIndex = 0;
    sections.forEach((s, i) => {
      // Skip quick-scan index and meta sections
      if (s.title.match(/Quick.scan|References/i)) return;

      visibleIndex++;
      const li = document.createElement('li');
      const isTest = s.title.match(/Module Test/i);
      const isTakeaway = s.title.match(/Key Takeaway/i);

      let displayTitle = s.title
        .replace(/^Section \d+:\s*/i, '')
        .replace(/^##\s*/, '');

      // Truncate long titles
      if (displayTitle.length > 35) displayTitle = displayTitle.substring(0, 32) + '...';

      li.innerHTML = `
        <a href="#section-${s.slug}" data-sidebar-link="${s.slug}"
           class="sidebar-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors
             text-n700 dark:text-n300 hover:bg-n50 dark:hover:bg-navy-light
             ${isTest ? 'mt-2 pt-2 border-t border-n100 dark:border-navy-light font-semibold' : ''}
             ${isTakeaway ? 'font-medium' : ''}">
          <span class="flex-shrink-0 w-5 h-5 rounded-full border-2 ${
            isTest ? 'border-orange' : isTakeaway ? 'border-teal' : 'border-n300 dark:border-n500'
          } flex items-center justify-center text-xs font-heading font-bold ${
            isTest ? 'text-orange' : isTakeaway ? 'text-teal' : 'text-n500'
          }">
            ${isTest ? '!' : isTakeaway ? '★' : visibleIndex}
          </span>
          <span class="truncate">${displayTitle}</span>
        </a>
      `;
      ul.appendChild(li);
    });

    sidebarNav.appendChild(ul);

    // ─── 3b. Mark completed sections from localStorage ───
    try {
      const key = 'playbook-academy-' + programId;
      const progress = JSON.parse(localStorage.getItem(key) || '{}');
      const modProgress = progress[moduleSlug];
      if (modProgress && modProgress.completedLessons && modProgress.completedLessons.length > 0) {
        const completedSet = new Set(modProgress.completedLessons);
        const quizPassed = modProgress.quizScore != null && modProgress.quizScore >= 80;
        sidebarNav.querySelectorAll('.sidebar-link').forEach(link => {
          const slug = link.dataset.sidebarLink;
          const sectionEl = document.getElementById('section-' + slug);
          if (!sectionEl) return;
          // Check if any exercise INSIDE this section has been completed
          const sectionExercises = sectionEl.querySelectorAll('[data-exercise-id]');
          const hasCompletedExercise = Array.from(sectionExercises).some(ex => completedSet.has(ex.dataset.exerciseId));
          const isTestSlug = slug.match(/module-test/i);
          const isTakeawaySlug = slug.match(/key-takeaway/i);
          if (hasCompletedExercise || (quizPassed && isTestSlug) || (quizPassed && isTakeawaySlug)) {
            const circle = link.querySelector('span:first-child');
            if (circle) {
              circle.classList.remove('border-n300', 'dark:border-n500', 'text-n500', 'border-orange', 'text-orange', 'border-teal', 'text-teal');
              circle.classList.add('border-success', 'bg-success', 'text-white');
              circle.innerHTML = '<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
            }
          }
        });
      }
    } catch(e) {}
  }

  // ─── 4. Sidebar collapse toggle ───
  const sidebarToggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('lesson-sidebar');
  const sidebarNavEl = document.getElementById('sidebar-nav');
  const sidebarChevron = document.getElementById('sidebar-chevron');
  const sidebarProgressSection = sidebar ? sidebar.querySelector('.px-4.py-2') : null;
  let sidebarCollapsed = false;

  sidebarToggle?.addEventListener('click', () => {
    sidebarCollapsed = !sidebarCollapsed;
    if (sidebar) sidebar.classList.toggle('collapsed', sidebarCollapsed);
    document.body.classList.toggle('sidebar-collapsed', sidebarCollapsed);
    if (sidebarNavEl) sidebarNavEl.style.display = sidebarCollapsed ? 'none' : '';
    if (sidebarProgressSection) sidebarProgressSection.style.display = sidebarCollapsed ? 'none' : '';
    if (sidebarChevron) sidebarChevron.style.transform = sidebarCollapsed ? 'rotate(180deg)' : '';
    sidebarToggle.setAttribute('aria-expanded', String(!sidebarCollapsed));
  });

  // ─── 4b. Check if module is already completed (used to lock progress bar at 100%) ───
  let moduleIsCompleted = false;
  try {
    const _pk = 'playbook-academy-' + programId;
    const _sp = JSON.parse(localStorage.getItem(_pk) || '{}');
    const _md = _sp[moduleSlug];
    if (_md && (_md.completed || (_md.quizScore != null && _md.quizScore >= 80))) {
      moduleIsCompleted = true;
    }
  } catch(e) {}

  // ─── 5. Scroll tracking with IntersectionObserver ───
  let currentSectionIndex = 0;
  const sectionEls = document.querySelectorAll('.module-section');
  const totalSections = sectionEls.length;
  const visibleSections = Array.from(sectionEls).filter(el => {
    const title = el.querySelector('h2')?.textContent || '';
    return !title.match(/Quick.scan|References/i);
  });
  const visibleCount = visibleSections.length;

  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (entry.isIntersecting) {
        const index = parseInt(entry.target.dataset.slideIndex || '0');
        currentSectionIndex = index;
        updateActive(index);
      }
    }
  }, { rootMargin: '-15% 0px -70% 0px' });

  sectionEls.forEach(el => observer.observe(el));

  function updateActive(index) {
    // Sidebar active state
    document.querySelectorAll('.sidebar-link').forEach(link => link.classList.remove('active'));
    const slug = sectionEls[index]?.dataset.lessonSlug;
    if (slug) {
      const active = document.querySelector(`[data-sidebar-link="${slug}"]`);
      if (active) active.classList.add('active');
      // Also highlight in mobile drawer
      document.querySelectorAll('.drawer-link').forEach(link => link.classList.remove('active'));
      const drawerActive = document.querySelector(`[data-drawer-link="${slug}"]`);
      if (drawerActive) drawerActive.classList.add('active');
    }

    // Mobile stepper counter
    const counter = document.getElementById('stepper-counter');
    if (counter) counter.textContent = `Section ${index + 1} of ${totalSections}`;

    const prev = document.getElementById('stepper-prev');
    const next = document.getElementById('stepper-next');
    if (prev) prev.disabled = index === 0;
    if (next) next.disabled = index >= totalSections - 1;

    // Nav progress bar (percentage through module) — skip if module already completed
    if (!moduleIsCompleted) {
      const pct = totalSections > 1 ? Math.round((index / (totalSections - 1)) * 100) : 100;
      const sidebarProg = document.getElementById('sidebar-progress-bar');
      const sidebarLabel = document.getElementById('sidebar-progress-label');
      if (sidebarProg) sidebarProg.style.width = `${pct}%`;
      if (sidebarLabel) sidebarLabel.textContent = `${pct}% complete`;
    }
  }

  // ─── 6. Mobile stepper + drawer ───
  document.getElementById('stepper-prev')?.addEventListener('click', () => {
    if (currentSectionIndex > 0) {
      sectionEls[currentSectionIndex - 1]?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });
  document.getElementById('stepper-next')?.addEventListener('click', () => {
    if (currentSectionIndex < totalSections - 1) {
      sectionEls[currentSectionIndex + 1]?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  // Mobile drawer open/close
  const drawerOverlay = document.getElementById('mobile-drawer-overlay');
  const drawer = document.getElementById('mobile-drawer');
  const drawerNav = document.getElementById('drawer-nav');

  let drawerTriggerEl = null;

  function getDrawerFocusables() {
    if (!drawer) return [];
    return Array.from(drawer.querySelectorAll('a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'));
  }

  function trapFocusInDrawer(e) {
    const focusables = getDrawerFocusables();
    if (focusables.length === 0) return;
    const first = focusables[0];
    const last = focusables[focusables.length - 1];
    if (e.key === 'Tab') {
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }
    if (e.key === 'Escape') { e.preventDefault(); closeDrawer(); }
  }

  function openDrawer() {
    drawerTriggerEl = document.activeElement;
    if (drawerOverlay) { drawerOverlay.classList.remove('hidden'); drawerOverlay.setAttribute('aria-hidden', 'false'); }
    if (drawer) {
      drawer.style.transform = 'translateY(0)';
      drawer.setAttribute('aria-hidden', 'false');
    }
    const stepperCounter = document.getElementById('stepper-counter');
    if (stepperCounter) stepperCounter.setAttribute('aria-expanded', 'true');
    // Focus the close button inside the drawer
    requestAnimationFrame(() => {
      const closeBtn = document.getElementById('drawer-close');
      if (closeBtn) closeBtn.focus();
    });
    document.addEventListener('keydown', trapFocusInDrawer);
  }
  function closeDrawer() {
    if (drawerOverlay) { drawerOverlay.classList.add('hidden'); drawerOverlay.setAttribute('aria-hidden', 'true'); }
    if (drawer) {
      drawer.style.transform = 'translateY(100%)';
      drawer.setAttribute('aria-hidden', 'true');
    }
    const stepperCounter = document.getElementById('stepper-counter');
    if (stepperCounter) stepperCounter.setAttribute('aria-expanded', 'false');
    document.removeEventListener('keydown', trapFocusInDrawer);
    // Return focus to trigger
    if (drawerTriggerEl && typeof drawerTriggerEl.focus === 'function') {
      drawerTriggerEl.focus();
      drawerTriggerEl = null;
    }
  }

  document.getElementById('stepper-counter')?.addEventListener('click', openDrawer);
  document.getElementById('drawer-close')?.addEventListener('click', closeDrawer);
  drawerOverlay?.addEventListener('click', closeDrawer);

  // Build drawer nav (mirrors sidebar)
  if (drawerNav && sections.length > 0) {
    const ul = document.createElement('ul');
    ul.className = 'space-y-1';
    sections.forEach((s, i) => {
      if (s.title.match(/Quick.scan|References/i)) return;
      const li = document.createElement('li');
      let displayTitle = s.title.replace(/^Section \d+:\s*/i, '').replace(/^##\s*/, '');
      if (displayTitle.length > 40) displayTitle = displayTitle.substring(0, 37) + '...';
      const isTest = s.title.match(/Module Test/i);
      li.innerHTML = `
        <a href="#section-${s.slug}" data-drawer-link="${s.slug}"
           class="drawer-link flex items-center gap-3 px-4 py-2.5 rounded-lg text-sm transition-colors
             text-n700 dark:text-n300 hover:bg-n50 dark:hover:bg-navy-light active:bg-teal/10
             ${isTest ? 'font-semibold border-t border-n100 dark:border-navy-light mt-2 pt-3' : ''}">
          <span class="flex-shrink-0 w-6 h-6 rounded-full ${isTest ? 'bg-orange/10 text-orange' : 'bg-n100 dark:bg-navy-light text-n500'} flex items-center justify-center text-xs font-heading font-bold">${isTest ? '!' : i + 1}</span>
          <span>${displayTitle}</span>
        </a>
      `;
      li.querySelector('a')?.addEventListener('click', () => {
        closeDrawer();
      });
      ul.appendChild(li);
    });
    drawerNav.appendChild(ul);
  }

  updateActive(0);

  // ─── 6b. Section-visit tracking (reading progress) ───
  // Track which sections the learner has spent 5+ seconds viewing.
  // Stored as a Set in localStorage, keyed by module slug. Distinct from exercise completion.
  (function() {
    var visitedKey = 'playbook-academy-visited-' + moduleSlug;
    var visitedSet;
    try { visitedSet = new Set(JSON.parse(localStorage.getItem(visitedKey) || '[]')); } catch(e) { visitedSet = new Set(); }

    // Render visited dots on page load for already-visited sections
    function renderVisitedDots() {
      document.querySelectorAll('.sidebar-link').forEach(function(link) {
        var slug = link.dataset.sidebarLink;
        if (!slug || !visitedSet.has(slug)) return;
        // Don't overwrite a completion checkmark (bg-success)
        var circle = link.querySelector('span:first-child');
        if (!circle || circle.classList.contains('bg-success')) return;
        // Add a small visited dot if not already present
        if (!link.querySelector('.visited-dot')) {
          var dot = document.createElement('span');
          dot.className = 'visited-dot';
          dot.setAttribute('aria-label', 'Visited');
          link.appendChild(dot);
        }
      });
    }
    renderVisitedDots();

    // Use IntersectionObserver + timers to detect 5-second dwell per section
    var dwellTimers = {};
    var visitObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        var slug = entry.target.dataset.lessonSlug;
        if (!slug) return;
        if (entry.isIntersecting) {
          if (!visitedSet.has(slug) && !dwellTimers[slug]) {
            dwellTimers[slug] = setTimeout(function() {
              visitedSet.add(slug);
              try { localStorage.setItem(visitedKey, JSON.stringify(Array.from(visitedSet))); } catch(e) {}
              renderVisitedDots();
              delete dwellTimers[slug];
            }, 5000);
          }
        } else {
          if (dwellTimers[slug]) {
            clearTimeout(dwellTimers[slug]);
            delete dwellTimers[slug];
          }
        }
      });
    }, { threshold: 0.3 });

    sectionEls.forEach(function(el) { visitObserver.observe(el); });
  })();

  // ─── 7b. Restore progress bar from localStorage on reload ───
  try {
    const progressKey = 'playbook-academy-' + programId;
    const savedProgress = JSON.parse(localStorage.getItem(progressKey) || '{}');
    const modData = savedProgress[moduleSlug];
    if (modData) {
      let restoredPct = 0;
      if (modData.completed || (modData.quizScore != null && modData.quizScore >= 80)) {
        restoredPct = 100;
      } else if (modData.completedLessons && modData.completedLessons.length > 0) {
        const totalLessons = modData.totalLessons || totalSections || 1;
        restoredPct = Math.min(Math.round((modData.completedLessons.length / totalLessons) * 100), 99);
      }
      if (restoredPct > 0) {
        const sidebarProg = document.getElementById('sidebar-progress-bar');
        const sidebarLabel = document.getElementById('sidebar-progress-label');
        if (sidebarProg) sidebarProg.style.width = restoredPct + '%';
        if (sidebarLabel) sidebarLabel.textContent = restoredPct + '% complete';
      }
    }
  } catch(e) {}

  // ─── 8. Accessibility: ARIA live region for feedback ───
  const liveRegion = document.createElement('div');
  liveRegion.setAttribute('aria-live', 'polite');
  liveRegion.setAttribute('aria-atomic', 'true');
  liveRegion.className = 'sr-only';
  liveRegion.id = 'a11y-live';
  document.body.appendChild(liveRegion);

  // Announce quiz feedback to screen readers
  document.querySelectorAll('[class*="quiz-feedback"]').forEach(fb => {
    const observer = new MutationObserver(() => {
      if (!fb.classList.contains('hidden')) {
        const text = fb.textContent || '';
        liveRegion.textContent = text;
      }
    });
    observer.observe(fb, { attributes: true, attributeFilter: ['class'] });
  });

  // Announce exercise feedback to screen readers
  document.querySelectorAll('.exercise-item-feedback').forEach(fb => {
    const observer = new MutationObserver(() => {
      if (!fb.classList.contains('hidden')) {
        const text = fb.textContent || '';
        liveRegion.textContent = text;
      }
    });
    observer.observe(fb, { attributes: true, attributeFilter: ['class'] });
  });

  // ─── 9. Audio players for narrator scripts ───
  // Map narrator blockquotes (in document order) to audio files by section.
  // Audio files follow pattern: /audio/{programId}/{moduleSlug}/section-{N}-narrator.mp3
  // Count narrator blockquotes first, then build paths dynamically
  var narratorCount = 0;
  content.querySelectorAll('blockquote').forEach(function(bq) {
    var s = bq.querySelector('strong');
    if (s && s.textContent.includes('Narrator')) narratorCount++;
  });
  var narratorAudioFiles = [];
  for (var ni = 0; ni < narratorCount; ni++) {
    narratorAudioFiles.push('/audio/' + programId + '/' + moduleSlug + '/section-' + (ni + 1) + '-narrator.mp3');
  }
  var allAudioElements = []; // track for auto-pause

  function buildAudioPlayer(audioSrc, transcriptEl) {
    var uid = 'ap-' + Math.random().toString(36).slice(2, 9);
    var container = document.createElement('div');
    container.className = 'audio-player rounded-xl border border-n100 dark:border-navy-light bg-white dark:bg-navy overflow-hidden my-6';

    // -- Controls row --
    var controls = document.createElement('div');
    controls.className = 'flex items-center gap-3 px-4 py-3';

    // Play/pause button
    var playBtn = document.createElement('button');
    playBtn.className = 'w-10 h-10 rounded-full bg-teal text-navy flex items-center justify-center flex-shrink-0 hover:bg-teal-dark transition-colors focus:outline-none focus:ring-2 focus:ring-teal focus:ring-offset-2 dark:focus:ring-offset-navy';
    playBtn.setAttribute('aria-label', 'Play audio');
    var playSvg = '<svg class="ap-icon-play w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
    var pauseSvg = '<svg class="ap-icon-pause w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
    playBtn.innerHTML = playSvg + pauseSvg;
    controls.appendChild(playBtn);

    // Progress area
    var progressWrap = document.createElement('div');
    progressWrap.className = 'flex-1 min-w-0';

    var progressTrack = document.createElement('div');
    progressTrack.className = 'h-2 bg-n100 dark:bg-navy-light rounded-full cursor-pointer relative group';
    progressTrack.setAttribute('role', 'slider');
    progressTrack.setAttribute('aria-label', 'Audio progress');
    progressTrack.setAttribute('aria-valuemin', '0');
    progressTrack.setAttribute('aria-valuemax', '100');
    progressTrack.setAttribute('aria-valuenow', '0');
    progressTrack.setAttribute('tabindex', '0');

    var progressFill = document.createElement('div');
    progressFill.className = 'h-full bg-teal rounded-full transition-[width] duration-100 relative';
    progressFill.style.width = '0%';
    var knob = document.createElement('div');
    knob.className = 'absolute right-0 top-1/2 -translate-y-1/2 w-3.5 h-3.5 bg-teal rounded-full shadow-sm opacity-0 group-hover:opacity-100 transition-opacity';
    progressFill.appendChild(knob);
    progressTrack.appendChild(progressFill);
    progressWrap.appendChild(progressTrack);

    var timeRow = document.createElement('div');
    timeRow.className = 'flex items-center justify-between mt-1';
    var timeCurrent = document.createElement('span');
    timeCurrent.className = 'text-xs text-n500 dark:text-n400 font-mono';
    timeCurrent.textContent = '0:00';
    var timeTotal = document.createElement('span');
    timeTotal.className = 'text-xs text-n500 dark:text-n400 font-mono';
    timeTotal.textContent = '0:00';
    timeRow.appendChild(timeCurrent);
    timeRow.appendChild(timeTotal);
    progressWrap.appendChild(timeRow);
    controls.appendChild(progressWrap);

    // Rate button
    var rateBtn = document.createElement('button');
    rateBtn.className = 'px-2 py-1 text-xs font-heading font-bold text-n500 dark:text-n400 bg-n50 dark:bg-navy-light rounded-md hover:bg-n100 dark:hover:bg-navy-light/70 transition-colors flex-shrink-0 focus:outline-none focus:ring-2 focus:ring-teal';
    rateBtn.setAttribute('aria-label', 'Playback speed: 1x');
    rateBtn.textContent = '1x';
    controls.appendChild(rateBtn);

    container.appendChild(controls);

    // -- Transcript toggle --
    var transcriptSection = document.createElement('div');
    transcriptSection.className = 'border-t border-n100 dark:border-navy-light';
    var transcriptToggle = document.createElement('button');
    transcriptToggle.className = 'flex items-center justify-between w-full px-4 py-2.5 text-sm font-heading font-semibold text-n700 dark:text-n300 hover:bg-n50 dark:hover:bg-navy-light/50 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-teal';
    transcriptToggle.setAttribute('aria-expanded', 'false');
    transcriptToggle.setAttribute('aria-controls', uid + '-transcript');
    transcriptToggle.innerHTML = '<span class="flex items-center gap-2"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>Transcript</span><svg class="ap-chevron w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>';
    transcriptSection.appendChild(transcriptToggle);

    var transcriptBody = document.createElement('div');
    transcriptBody.id = uid + '-transcript';
    transcriptBody.className = 'hidden px-4 pb-4';
    transcriptBody.setAttribute('role', 'region');
    transcriptBody.setAttribute('aria-label', 'Audio transcript');
    var transcriptInner = document.createElement('div');
    transcriptInner.className = 'p-4 rounded-lg bg-n50 dark:bg-navy-light/50 text-sm text-n700 dark:text-n300 font-body leading-relaxed max-h-60 overflow-y-auto';
    // Extract clean transcript text from the narrator blockquote
    transcriptInner.innerHTML = transcriptEl.innerHTML;
    transcriptBody.appendChild(transcriptInner);
    transcriptSection.appendChild(transcriptBody);
    container.appendChild(transcriptSection);

    // -- Wire up audio behaviour --
    // Create a real <audio> element inserted into the DOM so the browser
    // reliably fetches metadata and fires the loadedmetadata event.
    var audio = document.createElement('audio');
    audio.setAttribute('preload', 'metadata');
    audio.style.display = 'none';
    container.appendChild(audio);

    var playing = false;
    var rates = [1, 1.25, 1.5];
    var rateIndex = 0;
    var iconPlay = playBtn.querySelector('.ap-icon-play');
    var iconPause = playBtn.querySelector('.ap-icon-pause');
    var chevron = transcriptToggle.querySelector('.ap-chevron');

    allAudioElements.push(audio);

    function fmtTime(s) {
      if (isNaN(s)) return '0:00';
      var m = Math.floor(s / 60);
      var sec = Math.floor(s % 60);
      return m + ':' + (sec < 10 ? '0' : '') + sec;
    }

    function updateProgress() {
      if (!audio.duration) return;
      var pct = (audio.currentTime / audio.duration) * 100;
      progressFill.style.width = pct + '%';
      progressTrack.setAttribute('aria-valuenow', String(Math.round(pct)));
      timeCurrent.textContent = fmtTime(audio.currentTime);
    }

    // Attach ALL event listeners BEFORE setting src so none are missed
    audio.addEventListener('loadedmetadata', function() {
      timeTotal.textContent = fmtTime(audio.duration);
    });

    audio.addEventListener('error', function(e) {
      // Log error details for debugging
      var mediaErr = audio.error;
      console.error('[AudioPlayer] Failed to load:', audioSrc, 'code:', mediaErr ? mediaErr.code : 'unknown', 'message:', mediaErr ? mediaErr.message : 'none');
      // Replace controls with graceful fallback message
      controls.innerHTML = '<div class="flex items-center gap-2 px-4 py-3 text-sm text-n500 dark:text-n400"><svg class="w-5 h-5 flex-shrink-0 text-n400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"/><path stroke-linecap="round" stroke-linejoin="round" d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"/></svg><span>Audio unavailable &mdash; read transcript below</span></div>';
      // Auto-expand transcript so user can read it
      transcriptBody.classList.remove('hidden');
      transcriptToggle.setAttribute('aria-expanded', 'true');
      if (chevron) chevron.style.transform = 'rotate(180deg)';
    });

    audio.addEventListener('play', function() {
      playing = true;
      if (iconPlay) iconPlay.classList.add('hidden');
      if (iconPause) iconPause.classList.remove('hidden');
      playBtn.setAttribute('aria-label', 'Pause audio');
    });

    audio.addEventListener('pause', function() {
      playing = false;
      if (iconPlay) iconPlay.classList.remove('hidden');
      if (iconPause) iconPause.classList.add('hidden');
      playBtn.setAttribute('aria-label', 'Play audio');
    });

    audio.addEventListener('timeupdate', updateProgress);

    audio.addEventListener('ended', function() {
      playing = false;
      if (iconPlay) iconPlay.classList.remove('hidden');
      if (iconPause) iconPause.classList.add('hidden');
      playBtn.setAttribute('aria-label', 'Play audio');
    });

    // Set src after listeners are attached, then defer load() until the
    // container is in the real DOM (caller inserts it right after return).
    audio.src = audioSrc;
    container._deferLoad = function() {
      audio.load();
      if (audio.readyState >= 1) timeTotal.textContent = fmtTime(audio.duration);
    };

    playBtn.addEventListener('click', function() {
      if (playing) { audio.pause(); } else { audio.play(); }
    });

    // Seek via click
    progressTrack.addEventListener('click', function(e) {
      if (!audio.duration) return;
      var rect = progressTrack.getBoundingClientRect();
      var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      audio.currentTime = pct * audio.duration;
      updateProgress();
    });

    // Seek via keyboard
    progressTrack.addEventListener('keydown', function(e) {
      if (!audio.duration) return;
      var step = audio.duration * 0.05;
      if (e.key === 'ArrowRight') { audio.currentTime = Math.min(audio.duration, audio.currentTime + step); }
      else if (e.key === 'ArrowLeft') { audio.currentTime = Math.max(0, audio.currentTime - step); }
      updateProgress();
    });

    // Rate control
    rateBtn.addEventListener('click', function() {
      rateIndex = (rateIndex + 1) % rates.length;
      audio.playbackRate = rates[rateIndex];
      rateBtn.textContent = rates[rateIndex] + 'x';
      rateBtn.setAttribute('aria-label', 'Playback speed: ' + rates[rateIndex] + 'x');
    });

    // Transcript toggle
    transcriptToggle.addEventListener('click', function(e) {
      e.stopPropagation();
      var expanded = transcriptToggle.getAttribute('aria-expanded') === 'true';
      transcriptToggle.setAttribute('aria-expanded', String(!expanded));
      transcriptBody.classList.toggle('hidden');
      if (chevron) chevron.style.transform = expanded ? '' : 'rotate(180deg)';
    });

    // Expose audio element on container for auto-pause
    container._audio = audio;
    container._isPlaying = function() { return playing; };

    return container;
  }

  // Find all narrator blockquotes in document order and map to audio files
  var narratorIndex = 0;
  content.querySelectorAll('blockquote').forEach(function(bq) {
    var firstStrong = bq.querySelector('strong');
    if (!firstStrong || !firstStrong.textContent.includes('Narrator')) return;
    var audioSrc = narratorIndex < narratorAudioFiles.length ? narratorAudioFiles[narratorIndex] : null;
    narratorIndex++;

    if (audioSrc) {
      var player = buildAudioPlayer(audioSrc, bq);
      bq.parentNode.insertBefore(player, bq);
      // Now that the element is in the real DOM, trigger audio load
      if (player._deferLoad) player._deferLoad();
    }

    // Hide narrator blockquote (transcript lives inside the player now)
    bq.classList.add('hidden');
  });

  // Auto-pause: when the next section or exercise scrolls into view, pause any playing audio
  var autoPauseObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        allAudioElements.forEach(function(a) {
          if (!a.paused) a.pause();
        });
      }
    });
  }, { rootMargin: '0px', threshold: 0.3 });

  // Observe section boundaries and exercises for auto-pause
  document.querySelectorAll('.module-section, [data-has-exercise]').forEach(function(el, i) {
    // Only observe sections after the first one (entering a new section should pause previous audio)
    if (el.classList.contains('module-section') && i === 0) return;
    autoPauseObserver.observe(el);
  });

  // ─── 10. ARIA: glossary tooltip linking ───
  content.querySelectorAll('.glossary-term').forEach((term, idx) => {
    const tooltip = term.querySelector('.glossary-tooltip');
    if (!tooltip) return;
    const tooltipId = 'glossary-tip-' + idx;
    tooltip.id = tooltipId;
    tooltip.setAttribute('role', 'tooltip');
    term.setAttribute('aria-describedby', tooltipId);
    term.setAttribute('tabindex', '0');
  });

  // ─── 10b. ARIA: add aria-disabled to answered quiz/exercise buttons ───
  // Override the click handlers to also set aria-disabled
  // Set aria-disabled on answered buttons
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('button[data-answered]');
    if (btn && btn.dataset.answered) {
      btn.setAttribute('aria-disabled', 'true');
      btn.setAttribute('disabled', '');
      btn.setAttribute('tabindex', '-1');
    }
  }, true);

  // ─── 11. Live sidebar checkmark updates on exercise completion ───
  function updateSidebarCheckmarks() {
    try {
      const key = 'playbook-academy-' + programId;
      const progress = JSON.parse(localStorage.getItem(key) || '{}');
      const modProgress = progress[moduleSlug];
      if (!modProgress || !modProgress.completedLessons) return;
      const completedSet = new Set(modProgress.completedLessons);
      const quizPassed = modProgress.quizScore != null && modProgress.quizScore >= 80;

      document.querySelectorAll('.sidebar-link, .drawer-link').forEach(link => {
        const slug = link.dataset.sidebarLink || link.dataset.drawerLink;
        if (!slug) return;
        const sectionEl = document.getElementById('section-' + slug);
        if (!sectionEl) return;
        // Check if any exercise INSIDE this section has been completed
        const sectionExercises = sectionEl.querySelectorAll('[data-exercise-id]');
        const hasCompletedExercise = Array.from(sectionExercises).some(ex => completedSet.has(ex.dataset.exerciseId));
        const isTestSlug = slug.match(/module-test/i);
        const isTakeawaySlug = slug.match(/key-takeaway/i);
        if (hasCompletedExercise || (quizPassed && isTestSlug) || (quizPassed && isTakeawaySlug)) {
          const circle = link.querySelector('span:first-child');
          if (circle && !circle.classList.contains('bg-success')) {
            circle.classList.remove('border-n300', 'dark:border-n500', 'text-n500', 'bg-n100', 'dark:bg-navy-light', 'border-orange', 'text-orange', 'border-teal', 'text-teal');
            circle.classList.add('border-success', 'bg-success', 'text-white');
            circle.innerHTML = '<svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>';
          }
        }
      });
    } catch(e) {}
  }
  window.addEventListener('exercise-completed', updateSidebarCheckmarks);
  window.addEventListener('progress-updated', updateSidebarCheckmarks);
})();
</script>


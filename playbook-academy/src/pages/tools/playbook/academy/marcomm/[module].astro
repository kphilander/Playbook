  })();

  // ─── 0i. Transform "What X is NOT" list into visual callout ───
  (function() {
    const lists = Array.from(content.querySelectorAll('ul'));
    lists.forEach(ul => {
      const prevEl = ul.previousElementSibling;
      if (!prevEl) return;
      const prevText = prevEl.innerHTML || '';
      if (!prevText.match(/is\s+NOT/i)) return;

      const items = Array.from(ul.querySelectorAll('li'));
      if (items.length === 0) return;

      const callout = document.createElement('div');
      callout.className = 'not-list';
      items.forEach(li => {
        const row = document.createElement('div');
        row.className = 'not-list-item';
        row.innerHTML = `
          <svg class="not-list-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
          <span>${li.innerHTML}</span>
        `;
        callout.appendChild(row);
      });
      ul.style.display = 'none';
      ul.parentNode.insertBefore(callout, ul);
    });
  })();

  // ─── 0j. Wrap comparison tables (Two gaps, one system) with polished wrapper ───
  (function() {
    content.querySelectorAll('table').forEach(t => {
      const headers = Array.from(t.querySelectorAll('th'));
      const headerText = headers.map(h => (h.textContent || '').trim()).join(' ');
      if (headerText.match(/Engagement Gap/) && headerText.match(/Knowledge Gap/)) {
        const wrapper = document.createElement('div');
        wrapper.className = 'comparison-table-wrapper';
        t.parentNode.insertBefore(wrapper, t);
        wrapper.appendChild(t);
      }
    });
  })();

  // ─── 0k. Transform "Before We Begin" into interactive warm-up poll ───
  (function() {
    let beforeH2 = null;
    content.querySelectorAll('h2').forEach(h => {
      if ((h.textContent || '').match(/Before We Begin/i)) beforeH2 = h;
    });
    if (!beforeH2) return;

    // Hide all content until next h2
    let node = beforeH2.nextElementSibling;
    const toHide = [beforeH2];
    while (node && node.tagName !== 'H2') {
      toHide.push(node);
      node = node.nextElementSibling;
    }
    toHide.forEach(n => n.style.display = 'none');

    const poll = document.createElement('div');
    poll.className = 'warmup-poll';
    poll.setAttribute('role', 'group');
    poll.setAttribute('aria-label', 'Warm-up poll');
    poll.innerHTML = `
      <div class="warmup-poll-header">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <h4>Before We Begin</h4>
      </div>
      <div class="warmup-poll-body">
        <p class="warmup-poll-question">What comes to mind when you hear <strong>"responsible gambling"</strong>?</p>
        <button class="warmup-poll-option" data-poll="helpline" aria-pressed="false">
          <span class="poll-radio"></span>
          <span>A helpline number in small print</span>
        </button>
        <button class="warmup-poll-option" data-poll="warning" aria-pressed="false">
          <span class="poll-radio"></span>
          <span>A warning label or age gate</span>
        </button>
        <button class="warmup-poll-option" data-poll="checkbox" aria-pressed="false">
          <span class="poll-radio"></span>
          <span>A compliance checkbox nobody reads</span>
        </button>
        <button class="warmup-poll-option" data-poll="other" aria-pressed="false">
          <span class="poll-radio"></span>
          <span>Something else entirely</span>
        </button>
        <div class="warmup-poll-reveal" style="display:none;">
          <p style="margin:0;"><strong class="warmup-poll-reveal-lead">Most people pick one of the first three.</strong> That\u2019s the problem we\u2019re here to solve. Whatever your answer, hold that thought \u2014 this module will challenge every assumption behind it.</p>
        </div>
      </div>
    `;

    beforeH2.parentNode.insertBefore(poll, beforeH2);

    var pollStorageKey = 'playbook-academy-poll-' + moduleSlug;

    // Wire poll buttons
    poll.querySelectorAll('.warmup-poll-option').forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        poll.querySelectorAll('.warmup-poll-option').forEach(b => {
          b.classList.remove('selected');
          b.setAttribute('aria-pressed', 'false');
        });
        this.classList.add('selected');
        this.setAttribute('aria-pressed', 'true');
        const reveal = poll.querySelector('.warmup-poll-reveal');
        if (reveal) reveal.style.display = '';
        // Persist selection
        try { localStorage.setItem(pollStorageKey, this.dataset.poll); } catch(e) {}
      });
    });

    // Restore saved poll selection on page load
    try {
      var savedPoll = localStorage.getItem(pollStorageKey);
      if (savedPoll) {
        var savedBtn = poll.querySelector('.warmup-poll-option[data-poll="' + savedPoll + '"]');
        if (savedBtn) {
          savedBtn.classList.add('selected');
          savedBtn.setAttribute('aria-pressed', 'true');
          var reveal = poll.querySelector('.warmup-poll-reveal');
          if (reveal) reveal.style.display = '';
        }
      }
    } catch(e) {}
  })();

  // ─── 0l. Add section icons to h2 headings ───
  (function() {
    const iconMap = {
      'engagement gap': { bg: 'rgba(255, 61, 0, 0.1)', color: '#FF3D00', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>' },
      'knowledge gap': { bg: 'rgba(0, 212, 170, 0.1)', color: '#00A888', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>' },
      'two pillars': { bg: 'rgba(27, 40, 56, 0.1)', color: '#1B2838', svg: '<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>' },
    };
    content.querySelectorAll('h2').forEach(h2 => {
      const text = (h2.textContent || '').toLowerCase();
      for (const [key, config] of Object.entries(iconMap)) {
        if (text.includes(key)) {

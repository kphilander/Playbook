---
import '../styles/academy.css';

interface Props {
  title: string;
  description?: string;
  programId?: string;
  programName?: string;
}

const {
  title,
  description = 'Playbook Academy — Operator staff training for the Playbook entertainment literacy brand system.',
  programId,
  programName,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Playbook Academy</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline>
      if (localStorage.getItem('playbook-dark-mode') === 'true') {
        document.documentElement.classList.add('dark');
      }
    </script>
  </head>
  <body class="bg-n50 dark:bg-navy-dark min-h-screen font-body text-n900 dark:text-n100">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-teal focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold">
      Skip to main content
    </a>

    <nav aria-label="Academy navigation" class="sticky top-0 z-50 bg-navy text-white shadow-lg">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2 text-white hover:text-teal transition-colors">
            <svg class="w-7 h-7" viewBox="0 0 64 64" fill="none">
              <rect width="64" height="64" rx="14" fill="#1B2838"/>
              <rect x="14" y="14" width="16" height="36" rx="2" fill="#FFFFFF"/>
              <polygon points="34,14 54,32 34,50" fill="#00D4AA"/>
            </svg>
            <span class="font-heading font-bold text-sm tracking-tight">Playbook Academy</span>
          </a>
          {programName && (
            <div class="hidden sm:flex items-center gap-2 text-sm">
              <a href="/" class="text-white/60 hover:text-white transition-colors font-heading">Programs</a>
              <span class="text-white/30">/</span>
              <a href={`/tools/playbook/academy/${programId}`} class="text-white/80 hover:text-white transition-colors font-heading font-semibold">{programName}</a>
            </div>
          )}
          <button id="dark-mode-toggle" class="p-2 rounded-lg hover:bg-navy-light transition-colors" aria-label="Toggle dark mode">
            <svg class="w-5 h-5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
            </svg>
            <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <main id="main-content">
      <slot />
    </main>

    <footer class="bg-navy text-white/60 py-8 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-sm font-heading">&copy; 2025 GP Advisory LLC. All Rights Reserved.</p>
        <p class="text-xs mt-1 font-heading">Playbook Academy — Operator Staff Training</p>
      </div>
    </footer>

    <script is:inline>
      document.getElementById('dark-mode-toggle')?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('playbook-dark-mode', isDark ? 'true' : 'false');
      });
    </script>
  </body>
</html>

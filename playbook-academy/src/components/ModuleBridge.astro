---
interface Props {
  fromModule: string; // title of previous module
  toModule: string; // title of current module
  recap: string; // 1-2 sentence recap of what was learned
  bridge: string; // 1-2 sentence bridge to what's next
}

const { fromModule, toModule, recap, bridge } = Astro.props;
---

<div class="mb-8 p-5 rounded-xl bg-navy/5 border border-navy/10">
  <p class="text-sm text-n500 font-heading mb-1">
    Previously in <strong class="text-navy">{fromModule}</strong>
  </p>
  <p class="text-n700 mb-2">{recap}</p>
  <p class="text-sm text-navy font-heading">
    Now in <strong>{toModule}</strong>: {bridge}
  </p>
</div>

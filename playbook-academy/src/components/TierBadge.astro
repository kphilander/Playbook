---
interface Props {
  tier: 1 | 2;
  label?: string;
}

const { tier, label } = Astro.props;
const isTier1 = tier === 1;
const defaultLabel = isTier1 ? 'Tier 1 — Entertainment Literacy' : 'Tier 2 — Support & Crisis';
const displayLabel = label || defaultLabel;
---

<span class={`inline-flex items-center gap-1.5 text-xs font-heading font-bold uppercase tracking-wider px-3 py-1 rounded-full ${
  isTier1
    ? 'bg-teal/10 text-teal-dark border border-teal/20'
    : 'bg-orange/10 text-orange-dark border border-orange/20'
}`}>
  <span class={`w-2 h-2 rounded-full ${isTier1 ? 'bg-teal' : 'bg-orange'}`} aria-hidden="true"></span>
  {displayLabel}
</span>

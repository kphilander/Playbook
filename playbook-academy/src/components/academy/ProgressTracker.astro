---
interface ModuleInfo {
  slug: string;
  title: string;
  href: string;
}

interface Props {
  programId: string;
  modules: ModuleInfo[];
}

const { programId, modules } = Astro.props;
---

<div
  id="progress-tracker"
  class="my-8"
  data-program-id={programId}
  data-modules={JSON.stringify(modules)}
  role="navigation"
  aria-label="Module progress"
>
  <!-- Circles row -->
  <div class="flex items-center justify-center gap-1 mb-3" id="progress-circles">
    {modules.map((mod, i) => (
      <>
        <a
          href={mod.href}
          class="progress-circle relative group flex-shrink-0"
          data-progress-module={mod.slug}
          data-module-index={i}
          aria-label={mod.title + ' - not started'}
          title={mod.title}
        >
          <!-- Circle -->
          <div class="progress-ring w-9 h-9 sm:w-10 sm:h-10 rounded-full border-2 border-n200 dark:border-n500 flex items-center justify-center transition-all bg-white dark:bg-navy">
            <span class="progress-number text-xs font-heading font-bold text-n500 dark:text-n400">{i + 1}</span>
            <svg class="progress-check w-4 h-4 text-white hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>

          <!-- Tooltip on hover -->
          <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2.5 py-1 bg-navy dark:bg-white text-white dark:text-navy text-xs font-heading font-semibold rounded-md whitespace-nowrap opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity shadow-lg z-10">
            {mod.title}
            <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-navy dark:border-t-white"></div>
          </div>
        </a>
        {i < modules.length - 1 && (
          <div class="progress-connector h-0.5 w-4 sm:w-6 bg-n200 dark:bg-n500 flex-shrink-0 transition-colors" data-connector={i}></div>
        )}
      </>
    ))}
  </div>

  <!-- Summary text -->
  <p class="text-center text-sm text-n500 dark:text-n400 font-heading" id="progress-summary">
    0 of {modules.length} modules complete
  </p>
</div>

<style>
  .progress-circle .progress-ring.completed {
    border-color: #00D4AA;
    background: #00D4AA;
  }
  .progress-circle .progress-ring.completed .progress-number { display: none; }
  .progress-circle .progress-ring.completed .progress-check { display: block; }

  .progress-circle .progress-ring.in-progress {
    border-color: #00D4AA;
    border-width: 3px;
    box-shadow: 0 0 0 3px rgba(0, 212, 170, 0.15);
  }
  .progress-circle .progress-ring.in-progress .progress-number {
    color: #00D4AA;
  }

  .progress-connector.filled {
    background: #00D4AA;
  }
</style>

<script is:inline>
  (function() {
    var tracker = document.getElementById('progress-tracker');
    if (!tracker) return;

    var programId = tracker.dataset.programId;
    var modules = JSON.parse(tracker.dataset.modules || '[]');

    function updateTracker() {
      try {
        var storageKey = 'playbook-academy-' + programId;
        var progress = JSON.parse(localStorage.getItem(storageKey) || '{}');

        var completedCount = 0;
        var foundInProgress = false;

        modules.forEach(function(mod, i) {
          var circle = tracker.querySelector('[data-progress-module="' + mod.slug + '"]');
          if (!circle) return;

          var ring = circle.querySelector('.progress-ring');
          var modProgress = progress[mod.slug];
          var isComplete = modProgress && modProgress.completed;
          var hasActivity = modProgress && (modProgress.completedLessons.length > 0 || modProgress.lastAccessed);

          if (isComplete) {
            completedCount++;
            ring.classList.add('completed');
            ring.classList.remove('in-progress');
            circle.setAttribute('aria-label', mod.title + ' - complete');

            // Fill connector before this circle
            if (i > 0) {
              var conn = tracker.querySelector('[data-connector="' + (i - 1) + '"]');
              if (conn) conn.classList.add('filled');
            }
          } else if (hasActivity && !foundInProgress) {
            foundInProgress = true;
            ring.classList.add('in-progress');
            ring.classList.remove('completed');
            circle.setAttribute('aria-label', mod.title + ' - in progress');
          } else {
            ring.classList.remove('completed', 'in-progress');
            circle.setAttribute('aria-label', mod.title + ' - not started');
          }
        });

        var summary = document.getElementById('progress-summary');
        if (summary) {
          if (completedCount === modules.length) {
            summary.textContent = 'All ' + modules.length + ' modules complete!';
            summary.classList.add('text-teal', 'font-semibold');
            summary.classList.remove('text-n500', 'dark:text-n400');
          } else {
            summary.textContent = completedCount + ' of ' + modules.length + ' modules complete';
          }
        }
      } catch (e) {
        // Silent fail
      }
    }

    // Initial render
    updateTracker();

    // Listen for progress changes
    window.addEventListener('progress-updated', function(e) {
      if (e.detail && e.detail.programId === programId) {
        updateTracker();
      }
    });

    // Also re-render on storage events (cross-tab)
    window.addEventListener('storage', function(e) {
      if (e.key === 'playbook-academy-' + programId) {
        updateTracker();
      }
    });
  })();
</script>

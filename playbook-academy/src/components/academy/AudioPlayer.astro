---
interface Props {
  src?: string;
  transcript?: string;
}

const { src, transcript } = Astro.props;
const hasAudio = !!src;
const transcriptId = `audio-transcript-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="audio-player rounded-xl border border-n100 dark:border-navy-light bg-white dark:bg-navy overflow-hidden my-6">
  {!hasAudio ? (
    <!-- Placeholder when no audio available -->
    <div class="flex items-center gap-3 px-4 py-3">
      <div class="w-10 h-10 rounded-full bg-n100 dark:bg-navy-light flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-n300 dark:text-n500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-heading font-semibold text-n500 dark:text-n400">Audio narration coming soon</p>
        <p class="text-xs text-n300 dark:text-n500 font-body">An audio version of this content is being prepared.</p>
      </div>
    </div>
  ) : (
    <!-- Full audio player -->
    <div data-audio-player data-audio-src={src}>
      <!-- Controls row -->
      <div class="flex items-center gap-3 px-4 py-3">
        <!-- Play/Pause button -->
        <button
          class="audio-play-btn w-10 h-10 rounded-full bg-teal text-navy flex items-center justify-center flex-shrink-0 hover:bg-teal-dark transition-colors focus:outline-none focus:ring-2 focus:ring-teal focus:ring-offset-2 dark:focus:ring-offset-navy"
          aria-label="Play audio"
        >
          <svg class="audio-icon-play w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <svg class="audio-icon-pause w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </button>

        <!-- Progress area -->
        <div class="flex-1 min-w-0">
          <!-- Progress bar -->
          <div
            class="audio-progress-track h-2 bg-n100 dark:bg-navy-light rounded-full cursor-pointer relative group"
            role="slider"
            aria-label="Audio progress"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
            tabindex="0"
          >
            <div class="audio-progress-fill h-full bg-teal rounded-full transition-[width] duration-100 relative" style="width: 0%">
              <div class="absolute right-0 top-1/2 -translate-y-1/2 w-3.5 h-3.5 bg-teal rounded-full shadow-sm opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
          </div>

          <!-- Time display -->
          <div class="flex items-center justify-between mt-1">
            <span class="audio-time-current text-xs text-n500 dark:text-n400 font-mono">0:00</span>
            <span class="audio-time-total text-xs text-n500 dark:text-n400 font-mono">0:00</span>
          </div>
        </div>

        <!-- Rate control -->
        <button
          class="audio-rate-btn px-2 py-1 text-xs font-heading font-bold text-n500 dark:text-n400 bg-n50 dark:bg-navy-light rounded-md hover:bg-n100 dark:hover:bg-navy-light/70 transition-colors flex-shrink-0 focus:outline-none focus:ring-2 focus:ring-teal"
          aria-label="Playback speed: 1x"
        >
          1x
        </button>
      </div>

      {transcript && (
        <!-- Transcript toggle -->
        <div class="border-t border-n100 dark:border-navy-light">
          <button
            class="audio-transcript-toggle flex items-center justify-between w-full px-4 py-2.5 text-sm font-heading font-semibold text-n700 dark:text-n300 hover:bg-n50 dark:hover:bg-navy-light/50 transition-colors focus:outline-none focus:ring-2 focus:ring-inset focus:ring-teal"
            aria-expanded="false"
            aria-controls={transcriptId}
          >
            <span class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
              </svg>
              Transcript
            </span>
            <svg class="audio-transcript-chevron w-4 h-4 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          <div
            id={transcriptId}
            class="audio-transcript-panel hidden px-4 pb-4"
            role="region"
            aria-label="Audio transcript"
          >
            <div class="p-4 rounded-lg bg-n50 dark:bg-navy-light/50 text-sm text-n700 dark:text-n300 font-body leading-relaxed max-h-60 overflow-y-auto">
              {transcript}
            </div>
          </div>
        </div>
      )}
    </div>
  )}
</div>

<script is:inline>
  (function() {
    document.querySelectorAll('[data-audio-player]').forEach(function(container) {
      var src = container.dataset.audioSrc;
      if (!src) return;

      // Create a real <audio> element in the DOM instead of new Audio()
      // so the browser reliably fetches metadata and fires loadedmetadata.
      var audio = document.createElement('audio');
      audio.setAttribute('preload', 'metadata');
      audio.style.display = 'none';
      container.appendChild(audio);

      var playing = false;
      var rates = [0.75, 1, 1.25, 1.5];
      var rateIndex = 1;

      var playBtn = container.querySelector('.audio-play-btn');
      var iconPlay = container.querySelector('.audio-icon-play');
      var iconPause = container.querySelector('.audio-icon-pause');
      var progressTrack = container.querySelector('.audio-progress-track');
      var progressFill = container.querySelector('.audio-progress-fill');
      var timeCurrent = container.querySelector('.audio-time-current');
      var timeTotal = container.querySelector('.audio-time-total');
      var rateBtn = container.querySelector('.audio-rate-btn');
      var transcriptToggle = container.querySelector('.audio-transcript-toggle');
      var transcriptContent = container.querySelector('.audio-transcript-panel');
      var transcriptChevron = container.querySelector('.audio-transcript-chevron');

      function formatTime(s) {
        if (isNaN(s)) return '0:00';
        var m = Math.floor(s / 60);
        var sec = Math.floor(s % 60);
        return m + ':' + (sec < 10 ? '0' : '') + sec;
      }

      function updateProgress() {
        if (!audio.duration) return;
        var pct = (audio.currentTime / audio.duration) * 100;
        if (progressFill) progressFill.style.width = pct + '%';
        if (progressTrack) progressTrack.setAttribute('aria-valuenow', Math.round(pct));
        if (timeCurrent) timeCurrent.textContent = formatTime(audio.currentTime);
      }

      // Attach ALL event listeners BEFORE setting src so none are missed
      audio.addEventListener('loadedmetadata', function() {
        if (timeTotal) timeTotal.textContent = formatTime(audio.duration);
      });

      audio.addEventListener('error', function() {
        var mediaErr = audio.error;
        console.error('[AudioPlayer] Failed to load:', src, 'code:', mediaErr ? mediaErr.code : 'unknown', 'message:', mediaErr ? mediaErr.message : 'none');
        // Show transcript fallback
        if (transcriptToggle && transcriptContent) {
          transcriptContent.classList.remove('hidden');
          transcriptToggle.setAttribute('aria-expanded', 'true');
          if (transcriptChevron) transcriptChevron.style.transform = 'rotate(180deg)';
        }
      });

      audio.addEventListener('play', function() {
        playing = true;
        if (iconPlay) iconPlay.classList.add('hidden');
        if (iconPause) iconPause.classList.remove('hidden');
        if (playBtn) playBtn.setAttribute('aria-label', 'Pause audio');
      });

      audio.addEventListener('pause', function() {
        playing = false;
        if (iconPlay) iconPlay.classList.remove('hidden');
        if (iconPause) iconPause.classList.add('hidden');
        if (playBtn) playBtn.setAttribute('aria-label', 'Play audio');
      });

      audio.addEventListener('timeupdate', updateProgress);

      audio.addEventListener('ended', function() {
        playing = false;
        if (iconPlay) iconPlay.classList.remove('hidden');
        if (iconPause) iconPause.classList.add('hidden');
        if (playBtn) playBtn.setAttribute('aria-label', 'Play audio');
      });

      // Now set src to start loading (listeners are already attached)
      audio.src = src;
      audio.load();

      // Handle case where metadata loaded synchronously (from cache)
      if (audio.readyState >= 1 && timeTotal) {
        timeTotal.textContent = formatTime(audio.duration);
      }

      // Play/Pause
      if (playBtn) {
        playBtn.addEventListener('click', function() {
          if (playing) {
            audio.pause();
          } else {
            audio.play();
          }
        });
      }

      // Seek
      if (progressTrack) {
        function seek(e) {
          var rect = progressTrack.getBoundingClientRect();
          var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
          audio.currentTime = pct * audio.duration;
          updateProgress();
        }
        progressTrack.addEventListener('click', seek);

        progressTrack.addEventListener('keydown', function(e) {
          var step = audio.duration * 0.05;
          if (e.key === 'ArrowRight') {
            audio.currentTime = Math.min(audio.duration, audio.currentTime + step);
          } else if (e.key === 'ArrowLeft') {
            audio.currentTime = Math.max(0, audio.currentTime - step);
          }
          updateProgress();
        });
      }

      // Rate control
      if (rateBtn) {
        rateBtn.addEventListener('click', function() {
          rateIndex = (rateIndex + 1) % rates.length;
          audio.playbackRate = rates[rateIndex];
          rateBtn.textContent = rates[rateIndex] + 'x';
          rateBtn.setAttribute('aria-label', 'Playback speed: ' + rates[rateIndex] + 'x');
        });
      }

      // Transcript toggle
      if (transcriptToggle && transcriptContent) {
        transcriptToggle.addEventListener('click', function() {
          var expanded = transcriptToggle.getAttribute('aria-expanded') === 'true';
          transcriptToggle.setAttribute('aria-expanded', !expanded);
          transcriptContent.classList.toggle('hidden');
          if (transcriptChevron) {
            transcriptChevron.style.transform = expanded ? '' : 'rotate(180deg)';
          }
        });
      }

      // Auto-pause near exercises
      var exerciseObserver = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting && playing) {
            audio.pause();
          }
        });
      }, { rootMargin: '0px', threshold: 0.3 });

      document.querySelectorAll('[data-has-exercise]').forEach(function(el) {
        exerciseObserver.observe(el);
      });
    });
  })();
</script>

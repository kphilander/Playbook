---
import type { LessonSection } from '../../lib/parse-module';

interface Props {
  sections: LessonSection[];
  moduleTitle: string;
  programId: string;
  moduleSlug: string;
  hasQuiz: boolean;
  hasTakeaways: boolean;
}

const { sections, moduleTitle, programId, moduleSlug, hasQuiz, hasTakeaways } = Astro.props;
---

<!-- Desktop sidebar -->
<aside
  id="lesson-sidebar"
  class="hidden lg:block fixed left-0 top-14 w-72 h-[calc(100vh-3.5rem)] bg-white dark:bg-navy border-r border-n100 dark:border-navy-light overflow-y-auto z-40"
>
  <div class="p-4 border-b border-n100 dark:border-navy-light">
    <p class="text-xs font-heading font-semibold uppercase tracking-wider text-n500 dark:text-n300 mb-1">Lessons</p>
    <p class="text-sm font-heading font-bold text-navy dark:text-white truncate">{moduleTitle}</p>
  </div>

  <nav aria-label="Module lessons" class="p-2">
    <ul class="space-y-0.5">
      {sections.map((section, i) => (
        <li>
          <a
            href={`#section-${section.slug}`}
            data-sidebar-link={section.slug}
            class="sidebar-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors
              text-n700 dark:text-n300 hover:bg-n50 dark:hover:bg-navy-light"
          >
            <span
              data-lesson-check={section.slug}
              class="flex-shrink-0 w-5 h-5 rounded-full border-2 border-n300 dark:border-n500 flex items-center justify-center text-xs transition-colors"
            >
              <svg class="w-3 h-3 hidden" data-check-icon fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </span>
            <span class="truncate">{section.title}</span>
          </a>
        </li>
      ))}

      {hasQuiz && (
        <li class="mt-2 pt-2 border-t border-n100 dark:border-navy-light">
          <a
            href="#module-test"
            data-sidebar-link="module-test"
            class="sidebar-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors
              text-n700 dark:text-n300 hover:bg-n50 dark:hover:bg-navy-light"
          >
            <span class="flex-shrink-0 w-5 h-5 rounded-full border-2 border-orange dark:border-orange-light flex items-center justify-center">
              <svg class="w-3 h-3 text-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4" />
              </svg>
            </span>
            <span class="font-semibold">Module Test</span>
          </a>
        </li>
      )}

      {hasTakeaways && (
        <li>
          <a
            href="#key-takeaways"
            data-sidebar-link="key-takeaways"
            class="sidebar-link flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors
              text-n700 dark:text-n300 hover:bg-n50 dark:hover:bg-navy-light"
          >
            <span class="flex-shrink-0 w-5 h-5 rounded-full border-2 border-teal flex items-center justify-center">
              <svg class="w-3 h-3 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </span>
            <span>Key Takeaways</span>
          </a>
        </li>
      )}
    </ul>
  </nav>
</aside>

<!-- Mobile bottom stepper -->
<div
  id="mobile-stepper"
  class="lg:hidden fixed bottom-0 left-0 right-0 bg-white dark:bg-navy border-t border-n100 dark:border-navy-light z-40 px-4 py-2 flex items-center justify-between"
>
  <button id="stepper-prev" class="p-2 rounded-lg hover:bg-n50 dark:hover:bg-navy-light transition-colors text-n500 disabled:opacity-30" disabled>
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>

  <button id="stepper-counter" class="px-4 py-1.5 rounded-lg bg-n50 dark:bg-navy-light text-sm font-heading font-semibold text-navy dark:text-white">
    Section 1 of {sections.length}
  </button>

  <button id="stepper-next" class="p-2 rounded-lg hover:bg-n50 dark:hover:bg-navy-light transition-colors text-navy dark:text-white">
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>
</div>

<style>
  .sidebar-link.active {
    background: rgba(0, 212, 170, 0.08);
    color: #00A888;
    font-weight: 600;
  }
  .dark .sidebar-link.active {
    background: rgba(0, 212, 170, 0.12);
    color: #00D4AA;
  }
  [data-lesson-check].completed {
    border-color: #00C853;
    background: #00C853;
    color: white;
  }
  [data-lesson-check].completed [data-check-icon] {
    display: block;
  }
</style>

<script is:inline define:vars={{ programId, moduleSlug, sectionCount: sections.length, sectionSlugs: sections.map(s => s.slug) }}>
  // IntersectionObserver for active section highlighting
  let currentSection = 0;

  const observer = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (entry.isIntersecting) {
        const index = parseInt(entry.target.dataset.slideIndex || '0');
        currentSection = index;
        updateActiveSection(index);
      }
    }
  }, { rootMargin: '-20% 0px -60% 0px' });

  document.querySelectorAll('[data-slide-index]').forEach(el => observer.observe(el));

  function updateActiveSection(index) {
    // Update sidebar active state
    document.querySelectorAll('.sidebar-link').forEach(link => link.classList.remove('active'));
    const slug = sectionSlugs[index];
    if (slug) {
      const activeLink = document.querySelector(`[data-sidebar-link="${slug}"]`);
      if (activeLink) activeLink.classList.add('active');
    }

    // Update mobile stepper
    const counter = document.getElementById('stepper-counter');
    if (counter) counter.textContent = `Section ${index + 1} of ${sectionCount}`;

    const prev = document.getElementById('stepper-prev');
    const next = document.getElementById('stepper-next');
    if (prev) prev.disabled = index === 0;
    if (next) next.disabled = index >= sectionCount - 1;
  }

  // Mobile stepper navigation
  document.getElementById('stepper-prev')?.addEventListener('click', () => {
    if (currentSection > 0) {
      const target = document.querySelector(`[data-slide-index="${currentSection - 1}"]`);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  document.getElementById('stepper-next')?.addEventListener('click', () => {
    if (currentSection < sectionCount - 1) {
      const target = document.querySelector(`[data-slide-index="${currentSection + 1}"]`);
      if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

  // Initialize active state
  updateActiveSection(0);
</script>

---
interface Props {
  tier1: string;
  tier2: string;
  context: string;
}

const { tier1, tier2, context } = Astro.props;
const id = `tier-toggle-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="tier-toggle-wrapper my-8" data-tier-toggle={id}>
  <!-- Context / scenario label -->
  <div class="text-xs font-heading font-bold uppercase tracking-wider text-n500 dark:text-n400 mb-3">
    Scenario: {context}
  </div>

  <!-- Toggle switch -->
  <div class="flex items-center gap-3 mb-4">
    <button
      type="button"
      class="tier-toggle-btn"
      data-tier="1"
      role="radio"
      aria-checked="true"
      tabindex="0"
      aria-label="Show Tier 1 version"
    >
      <span class="tier-toggle-indicator active" data-indicator="1"></span>
      <span class="text-sm font-heading font-semibold">Tier 1</span>
    </button>
    <button
      type="button"
      class="tier-toggle-btn"
      data-tier="2"
      role="radio"
      aria-checked="false"
      tabindex="0"
      aria-label="Show Tier 2 version"
    >
      <span class="tier-toggle-indicator" data-indicator="2"></span>
      <span class="text-sm font-heading font-semibold">Tier 2</span>
    </button>
  </div>

  <!-- Tier 1 content -->
  <div class="tier-content tier-1-content active" data-content="1">
    <div class="rounded-xl border-2 border-teal/40 bg-teal/5 dark:bg-teal/10 p-5">
      <span class="inline-block px-2 py-0.5 rounded-full text-xs font-heading font-bold uppercase tracking-wider bg-teal/20 text-teal mb-3">
        Confident / Informative
      </span>
      <p class="text-n900 dark:text-n100 leading-relaxed">{tier1}</p>
    </div>
  </div>

  <!-- Tier 2 content -->
  <div class="tier-content tier-2-content" data-content="2">
    <div class="rounded-xl border-2 border-navy/30 dark:border-white/20 bg-navy/5 dark:bg-white/5 p-5">
      <span class="inline-block px-2 py-0.5 rounded-full text-xs font-heading font-bold uppercase tracking-wider bg-orange/20 text-orange mb-3">
        Warm / Direct
      </span>
      <p class="text-n900 dark:text-n100 leading-relaxed">{tier2}</p>
    </div>
  </div>
</div>

<style>
  .tier-toggle-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    border: 1px solid #E8E8F0;
    background: white;
    cursor: pointer;
    transition: all 150ms ease;
  }
  .tier-toggle-btn:hover {
    border-color: #A8A8C0;
  }
  .tier-toggle-btn:focus-visible {
    outline: 2px solid #00D4AA;
    outline-offset: 2px;
  }
  :global(.dark) .tier-toggle-btn {
    background: #1B2838;
    border-color: #2A3F56;
  }
  :global(.dark) .tier-toggle-btn:hover {
    border-color: #5A7A9A;
  }

  .tier-toggle-indicator {
    display: inline-block;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 9999px;
    border: 2px solid #A8A8C0;
    transition: all 150ms ease;
  }
  .tier-toggle-indicator.active {
    border-color: #00D4AA;
    background: #00D4AA;
    box-shadow: 0 0 0 2px rgba(0, 212, 170, 0.2);
  }

  .tier-content {
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: opacity 200ms ease, max-height 200ms ease;
  }
  .tier-content.active {
    opacity: 1;
    max-height: 500px;
  }
</style>

<script is:inline>
  (function() {
    document.querySelectorAll('[data-tier-toggle]').forEach(function(wrapper) {
      var buttons = wrapper.querySelectorAll('.tier-toggle-btn');
      var contents = wrapper.querySelectorAll('.tier-content');
      var indicators = wrapper.querySelectorAll('.tier-toggle-indicator');

      function switchTo(tier) {
        buttons.forEach(function(btn) {
          var btnTier = btn.getAttribute('data-tier');
          btn.setAttribute('aria-checked', btnTier === tier ? 'true' : 'false');
        });
        indicators.forEach(function(ind) {
          var indTier = ind.getAttribute('data-indicator');
          if (indTier === tier) {
            ind.classList.add('active');
          } else {
            ind.classList.remove('active');
          }
        });
        contents.forEach(function(content) {
          var contentTier = content.getAttribute('data-content');
          if (contentTier === tier) {
            content.classList.add('active');
          } else {
            content.classList.remove('active');
          }
        });
      }

      buttons.forEach(function(btn) {
        btn.addEventListener('click', function() {
          switchTo(btn.getAttribute('data-tier'));
        });
        btn.addEventListener('keydown', function(e) {
          if (e.key === ' ' || e.key === 'Enter') {
            e.preventDefault();
            switchTo(btn.getAttribute('data-tier'));
          }
        });
      });
    });
  })();
</script>

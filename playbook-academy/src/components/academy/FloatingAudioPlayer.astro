---
/**
 * SidebarAudioPlayer — audio player that sits at the bottom of the lesson sidebar.
 * Receives audio tracks via the floating-player-init event from the page script.
 * Orchestrates playback: plays per-section, pauses between sections, shows instructions.
 */
interface Props {
  nextModuleHref?: string;
  nextModuleTitle?: string;
}

const { nextModuleHref, nextModuleTitle } = Astro.props;
---

<div
  id="sidebar-audio-player"
  class="border-t border-n100 dark:border-navy-light bg-white dark:bg-navy"
  data-next-href={nextModuleHref || ''}
  data-next-title={nextModuleTitle || ''}
  role="region"
  aria-label="Audio player"
  style="display: none;"
>
  <!-- Clickable progress bar -->
  <div id="fp-progress-track" class="h-1.5 bg-n100 dark:bg-navy-light cursor-pointer group hover:h-2 transition-all" role="slider" aria-label="Audio seek" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" tabindex="0">
    <div id="fp-progress" class="h-full bg-teal transition-[width] duration-150 pointer-events-none relative" style="width: 0%">
      <div class="absolute right-0 top-1/2 -translate-y-1/2 w-2.5 h-2.5 bg-teal rounded-full shadow-sm opacity-0 group-hover:opacity-100 transition-opacity"></div>
    </div>
  </div>

  <div class="p-3">
    <!-- Section label + message -->
    <div class="mb-2">
      <div id="fp-section-label" class="text-xs font-heading font-bold text-navy dark:text-white truncate">
        Section 1
      </div>
      <div id="fp-message" class="text-xs text-teal font-heading truncate mt-0.5">
        Press play to begin
      </div>
    </div>

    <!-- Controls row -->
    <div class="flex items-center gap-1.5">
      <!-- Rewind 10s -->
      <button
        id="fp-rewind-btn"
        class="w-7 h-7 flex items-center justify-center text-n400 dark:text-n500 hover:text-navy dark:hover:text-white transition-colors flex-shrink-0 focus:outline-none focus:ring-1 focus:ring-teal rounded"
        aria-label="Rewind 10 seconds"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12.5 3C7.81 3 4 6.81 4 11.5h-3l4 4 4-4H6c0-3.59 2.91-6.5 6.5-6.5s6.5 2.91 6.5 6.5-2.91 6.5-6.5 6.5c-1.47 0-2.82-.49-3.91-1.32l-1.41 1.41C8.77 19.22 10.55 20 12.5 20c4.69 0 8.5-3.81 8.5-8.5S17.19 3 12.5 3z"/>
          <text x="9.5" y="14.5" font-size="7" font-weight="bold" fill="currentColor" font-family="sans-serif">10</text>
        </svg>
      </button>

      <!-- Play / Pause -->
      <button
        id="fp-play-btn"
        class="w-8 h-8 rounded-full bg-teal text-navy flex items-center justify-center flex-shrink-0 hover:bg-teal-light transition-colors focus:outline-none focus:ring-2 focus:ring-teal focus:ring-offset-1"
        aria-label="Play audio"
      >
        <svg id="fp-icon-play" class="w-3.5 h-3.5 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M8 5v14l11-7z"/>
        </svg>
        <svg id="fp-icon-pause" class="w-3.5 h-3.5 hidden" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
        </svg>
      </button>

      <!-- Forward 10s -->
      <button
        id="fp-forward-btn"
        class="w-7 h-7 flex items-center justify-center text-n400 dark:text-n500 hover:text-navy dark:hover:text-white transition-colors flex-shrink-0 focus:outline-none focus:ring-1 focus:ring-teal rounded"
        aria-label="Forward 10 seconds"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M11.5 3c4.69 0 8.5 3.81 8.5 8.5h3l-4 4-4-4h3c0-3.59-2.91-6.5-6.5-6.5S5 7.91 5 11.5s2.91 6.5 6.5 6.5c1.47 0 2.82-.49 3.91-1.32l1.41 1.41C15.23 19.22 13.45 20 11.5 20 6.81 20 3 16.19 3 11.5S6.81 3 11.5 3z"/>
          <text x="8.5" y="14.5" font-size="7" font-weight="bold" fill="currentColor" font-family="sans-serif">10</text>
        </svg>
      </button>

      <!-- Time -->
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-1 text-xs font-mono text-n500 dark:text-n400">
          <span id="fp-time-current">0:00</span>
          <span class="text-n300 dark:text-n600">/</span>
          <span id="fp-time-total">0:00</span>
        </div>
      </div>

      <!-- Speed -->
      <button
        id="fp-rate-btn"
        class="px-1.5 py-0.5 text-xs font-heading font-bold text-n500 dark:text-n400 bg-n50 dark:bg-navy-light rounded hover:text-navy dark:hover:text-white transition-colors flex-shrink-0 focus:outline-none focus:ring-1 focus:ring-teal"
        aria-label="Playback speed: 1x"
      >
        1x
      </button>

      <!-- Transcript toggle -->
      <button
        id="fp-transcript-btn"
        class="p-1 text-n400 hover:text-teal transition-colors flex-shrink-0 focus:outline-none focus:ring-1 focus:ring-teal rounded"
        aria-label="Toggle transcript"
        aria-expanded="false"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Expandable transcript panel -->
  <div id="fp-transcript-panel" class="hidden border-t border-n100 dark:border-navy-light">
    <div class="p-3">
      <div id="fp-transcript-text" class="text-xs text-n600 dark:text-n300 font-body leading-relaxed max-h-40 overflow-y-auto">
      </div>
    </div>
  </div>
</div>

<!-- Mobile floating play button (visible on mobile only, since sidebar is hidden) -->
<button
  id="mobile-play-fab"
  class="lg:hidden fixed bottom-20 right-4 z-40 w-12 h-12 rounded-full bg-teal text-navy shadow-lg flex items-center justify-center hover:bg-teal-light transition-colors focus:outline-none focus:ring-2 focus:ring-teal focus:ring-offset-2"
  aria-label="Play audio"
  style="display: none;"
>
  <svg id="mobile-icon-play" class="w-5 h-5 ml-0.5" fill="currentColor" viewBox="0 0 24 24">
    <path d="M8 5v14l11-7z"/>
  </svg>
  <svg id="mobile-icon-pause" class="w-5 h-5 hidden" fill="currentColor" viewBox="0 0 24 24">
    <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
  </svg>
</button>

<script is:inline>
(function() {
  var player = document.getElementById('sidebar-audio-player');
  var mobileFab = document.getElementById('mobile-play-fab');
  if (!player) return;

  // ── Elements ──
  var playBtn = document.getElementById('fp-play-btn');
  var iconPlay = document.getElementById('fp-icon-play');
  var iconPause = document.getElementById('fp-icon-pause');
  var mobileIconPlay = document.getElementById('mobile-icon-play');
  var mobileIconPause = document.getElementById('mobile-icon-pause');
  var progressBar = document.getElementById('fp-progress');
  var sectionLabel = document.getElementById('fp-section-label');
  var messageEl = document.getElementById('fp-message');
  var timeCurrent = document.getElementById('fp-time-current');
  var timeTotal = document.getElementById('fp-time-total');
  var rateBtn = document.getElementById('fp-rate-btn');
  var transcriptBtn = document.getElementById('fp-transcript-btn');
  var transcriptPanel = document.getElementById('fp-transcript-panel');
  var transcriptText = document.getElementById('fp-transcript-text');

  var nextHref = player.dataset.nextHref;
  var nextTitle = player.dataset.nextTitle;

  // ── Audio ──
  var audio = document.createElement('audio');
  audio.preload = 'metadata';
  player.appendChild(audio);

  var state = 'idle';
  var currentSectionIndex = 0;
  var sections = [];
  var audioFiles = [];
  var sectionTitles = [];
  var transcripts = [];
  var rates = [0.75, 1, 1.25, 1.5];
  var rateIndex = 1;
  var isPlaying = false;

  function fmt(s) {
    if (isNaN(s)) return '0:00';
    var m = Math.floor(s / 60);
    var sec = Math.floor(s % 60);
    return m + ':' + (sec < 10 ? '0' : '') + sec;
  }

  function showPlayer() {
    player.style.display = '';
    if (mobileFab) mobileFab.style.display = '';
  }

  function setMessage(msg, color) {
    messageEl.textContent = msg;
    messageEl.style.color = color || '';
    // Reset class-based coloring
    messageEl.className = 'text-xs font-heading truncate mt-0.5';
    if (color === 'orange') messageEl.classList.add('text-orange');
    else messageEl.classList.add('text-teal');
  }

  function updatePlayIcon() {
    if (isPlaying) {
      iconPlay.classList.add('hidden');
      iconPause.classList.remove('hidden');
      if (mobileIconPlay) mobileIconPlay.classList.add('hidden');
      if (mobileIconPause) mobileIconPause.classList.remove('hidden');
      playBtn.setAttribute('aria-label', 'Pause audio');
      if (mobileFab) mobileFab.setAttribute('aria-label', 'Pause audio');
    } else {
      iconPlay.classList.remove('hidden');
      iconPause.classList.add('hidden');
      if (mobileIconPlay) mobileIconPlay.classList.remove('hidden');
      if (mobileIconPause) mobileIconPause.classList.add('hidden');
      playBtn.setAttribute('aria-label', 'Play audio');
      if (mobileFab) mobileFab.setAttribute('aria-label', 'Play audio');
    }
  }

  function loadTrack(index) {
    if (index < 0 || index >= audioFiles.length) return false;
    currentSectionIndex = index;
    var src = audioFiles[index];
    if (!src) return false;
    audio.src = src;
    audio.load();
    sectionLabel.textContent = sectionTitles[index] || ('Section ' + (index + 1));
    progressBar.style.width = '0%';
    if (timeCurrent) timeCurrent.textContent = '0:00';
    if (transcriptText && transcripts[index]) {
      transcriptText.textContent = transcripts[index];
    }
    return true;
  }

  function play() {
    if (!audioFiles[currentSectionIndex]) return;
    audio.play().catch(function() {});
    isPlaying = true;
    state = 'playing';
    updatePlayIcon();
    setMessage('Playing...');
  }

  function pause() {
    audio.pause();
    isPlaying = false;
    state = 'paused';
    updatePlayIcon();
    setMessage('Paused');
  }

  // ── Audio events ──
  audio.addEventListener('loadedmetadata', function() {
    if (timeTotal) timeTotal.textContent = fmt(audio.duration);
  });

  audio.addEventListener('timeupdate', function() {
    if (!audio.duration) return;
    var pct = (audio.currentTime / audio.duration) * 100;
    progressBar.style.width = pct + '%';
    if (timeCurrent) timeCurrent.textContent = fmt(audio.currentTime);
  });

  audio.addEventListener('ended', function() {
    isPlaying = false;
    updatePlayIcon();
    progressBar.style.width = '100%';

    var section = sections[currentSectionIndex];
    var hasExercise = section && section.hasAttribute('data-has-exercise');

    if (hasExercise) {
      state = 'exercise-wait';
      setMessage('Complete the exercise, then continue', 'orange');
    } else if (currentSectionIndex < audioFiles.length - 1) {
      state = 'section-ended';
      setMessage('Section done — scroll to continue');
    } else {
      state = 'complete';
      if (nextHref) {
        setMessage('Module complete!');
        // Add a next-module link
        messageEl.innerHTML = 'Done! <a href="' + nextHref + '" style="text-decoration:underline;">' + (nextTitle || 'Next module') + ' →</a>';
      } else {
        setMessage('Module complete!');
      }
    }
  });

  audio.addEventListener('error', function() {
    setMessage('Audio unavailable');
    if (transcriptPanel) transcriptPanel.classList.remove('hidden');
  });

  // ── Controls ──
  function togglePlay() {
    if (isPlaying) {
      pause();
    } else {
      if (state === 'section-ended' || state === 'exercise-wait') {
        if (currentSectionIndex < audioFiles.length - 1) {
          loadTrack(currentSectionIndex + 1);
        }
      }
      play();
    }
  }

  playBtn.addEventListener('click', togglePlay);
  if (mobileFab) mobileFab.addEventListener('click', togglePlay);

  // Seek by clicking progress bar
  var progressTrack = document.getElementById('fp-progress-track');
  if (progressTrack) {
    progressTrack.addEventListener('click', function(e) {
      if (!audio.duration) return;
      var rect = progressTrack.getBoundingClientRect();
      var pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
      audio.currentTime = pct * audio.duration;
    });
    progressTrack.addEventListener('keydown', function(e) {
      if (!audio.duration) return;
      var step = audio.duration * 0.05;
      if (e.key === 'ArrowRight') audio.currentTime = Math.min(audio.duration, audio.currentTime + step);
      else if (e.key === 'ArrowLeft') audio.currentTime = Math.max(0, audio.currentTime - step);
    });
  }

  // Rewind / Forward 10s
  var rewindBtn = document.getElementById('fp-rewind-btn');
  var forwardBtn = document.getElementById('fp-forward-btn');
  if (rewindBtn) rewindBtn.addEventListener('click', function() {
    audio.currentTime = Math.max(0, audio.currentTime - 10);
  });
  if (forwardBtn) forwardBtn.addEventListener('click', function() {
    audio.currentTime = Math.min(audio.duration || 0, audio.currentTime + 10);
  });

  rateBtn.addEventListener('click', function() {
    rateIndex = (rateIndex + 1) % rates.length;
    audio.playbackRate = rates[rateIndex];
    rateBtn.textContent = rates[rateIndex] + 'x';
  });

  transcriptBtn.addEventListener('click', function() {
    var expanded = transcriptBtn.getAttribute('aria-expanded') === 'true';
    transcriptBtn.setAttribute('aria-expanded', !expanded);
    transcriptPanel.classList.toggle('hidden');
  });

  // ── Page events ──
  var viewedSectionIndex = 0; // tracks what the user is LOOKING at (scrolled to)

  window.addEventListener('section-changed', function(e) {
    var idx = (e.detail || {}).index;
    if (typeof idx !== 'number') return;
    viewedSectionIndex = idx;

    if (idx === currentSectionIndex) {
      // Back on the section that's playing — clear any "playing prior section" message
      if (isPlaying) setMessage('Playing...');
      return;
    }

    if (state === 'section-ended' || state === 'exercise-wait') {
      loadTrack(idx);
      setMessage('Press play to continue');
      state = 'idle';
    } else if (isPlaying) {
      // User scrolled away while audio still plays a prior section
      var playingTitle = sectionTitles[currentSectionIndex] || ('Section ' + (currentSectionIndex + 1));
      sectionLabel.textContent = 'Still playing: ' + playingTitle;
    } else {
      loadTrack(idx);
      setMessage('Press play to listen');
    }
  });

  window.addEventListener('exercise-completed', function() {
    if (state === 'exercise-wait') {
      if (currentSectionIndex < audioFiles.length - 1) {
        setMessage('Exercise done! Press play');
        state = 'section-ended';
      } else {
        state = 'complete';
        setMessage('Module complete!');
      }
    }
  });

  window.addEventListener('floating-player-init', function(e) {
    var config = e.detail || {};
    audioFiles = config.audioFiles || [];
    sectionTitles = config.sectionTitles || [];
    transcripts = config.transcripts || [];
    sections = Array.from(document.querySelectorAll('.module-section'));
    if (audioFiles.length > 0) {
      loadTrack(0);
      showPlayer();
    }
  });
})();
</script>

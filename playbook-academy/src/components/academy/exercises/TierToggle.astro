---
/**
 * TierToggle — Side-by-side comparison of Tier 1 vs Tier 2 messaging.
 * Demonstration component, not graded (no exercise-completed event).
 */
---

<div class="exercise-wrapper">
  <!-- Header -->
  <div class="exercise-header flex items-center justify-between flex-wrap gap-2">
    <div class="flex items-center gap-3 flex-wrap">
      <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 bg-teal/20 text-teal rounded-full text-xs font-heading font-bold uppercase tracking-wider">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
        </svg>
        Demonstration
      </span>
      <h3 class="text-white font-heading font-bold text-lg m-0">Tier Toggle</h3>
    </div>
    <span class="px-2.5 py-0.5 bg-white/10 text-white/70 rounded-full text-xs font-heading font-semibold uppercase tracking-wider">
      Compare
    </span>
  </div>

  <div class="p-5 sm:p-6" id="tier-toggle-root">
    <p class="text-sm text-n700 dark:text-n300 font-body leading-relaxed mb-5">
      Toggle between Tier 1 and Tier 2 to see how the same touchpoint changes when a player may need support.
    </p>

    <!-- Toggle buttons -->
    <div class="flex items-center justify-center mb-6">
      <button
        data-tier="1"
        class="tier-btn flex-1 sm:flex-none px-4 sm:px-5 py-3 text-sm font-heading font-semibold rounded-l-lg border-2 transition-all bg-teal text-navy border-teal"
      >
        Tier 1 <span class="hidden sm:inline">-- Playful / Witty</span>
      </button>
      <button
        data-tier="2"
        class="tier-btn flex-1 sm:flex-none px-4 sm:px-5 py-3 text-sm font-heading font-semibold rounded-r-lg border-2 border-l-0 transition-all bg-white dark:bg-navy text-n500 border-n100 dark:border-navy-light hover:border-n300"
      >
        Tier 2 <span class="hidden sm:inline">-- Warm / Direct</span>
      </button>
    </div>

    <!-- Tier 1 content -->
    <div id="tier-1-content" class="tier-panel">
      <div class="rounded-xl border-2 border-teal bg-white dark:bg-navy-dark p-6 transition-all duration-300">
        <!-- Badge -->
        <div class="mb-4">
          <span class="inline-flex items-center gap-1.5 text-xs font-heading font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-teal/10 text-teal-dark border border-teal/20">
            <span class="w-2 h-2 rounded-full bg-teal"></span>
            Tier 1 -- Entertainment Literacy
          </span>
        </div>

        <h4 class="font-heading font-bold text-xl mb-2 text-navy dark:text-white">
          Set your entertainment budget
        </h4>
        <p class="text-n700 dark:text-n300 mb-5 leading-relaxed">
          Most players find it helpful to set a weekly budget. Think of it like a movie subscription -- the cost of having fun.
        </p>
        <span class="inline-block px-5 py-2.5 text-sm font-heading font-semibold rounded-lg bg-teal text-navy">
          Set my budget
        </span>
      </div>

      <div class="mt-3 p-4 rounded-lg bg-teal/5 border border-teal/10">
        <p class="text-sm text-n700 dark:text-n300 leading-relaxed">
          <span class="font-heading font-semibold text-teal-dark">Tier 1 note: </span>
          This is the default tone. Confident, informative, non-clinical. The deposit limit nudge is framed as a feature of the experience -- not a warning bolted onto it.
        </p>
      </div>
    </div>

    <!-- Tier 2 content -->
    <div id="tier-2-content" class="tier-panel hidden">
      <div class="rounded-xl border-2 border-navy bg-white dark:bg-navy-dark p-6 transition-all duration-300">
        <!-- Badge -->
        <div class="mb-4">
          <span class="inline-flex items-center gap-1.5 text-xs font-heading font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-navy/10 text-navy dark:text-n200 border border-navy/20">
            <span class="w-2 h-2 rounded-full bg-navy"></span>
            Tier 2 -- Support &amp; Crisis
          </span>
        </div>

        <h4 class="font-heading font-bold text-xl mb-2 text-navy dark:text-white">
          Support is here
        </h4>
        <p class="text-n700 dark:text-n300 mb-5 leading-relaxed">
          Call, text, or chat -- free and confidential. Available 24/7.
        </p>
        <span class="inline-block px-5 py-2.5 text-sm font-heading font-semibold rounded-lg bg-navy text-white">
          Talk to someone now
        </span>
      </div>

      <div class="mt-3 p-4 rounded-lg bg-navy/5 border border-navy/10">
        <p class="text-sm text-n700 dark:text-n300 leading-relaxed">
          <span class="font-heading font-semibold text-navy dark:text-n200">What changed: </span>
          The playful tone disappears. The language shifts from "entertainment budget" to direct support. The CTA is immediate and warm -- no friction, no judgment.
        </p>
      </div>
    </div>
  </div>
</div>

<style>
  .tier-panel {
    transition: opacity 0.25s ease-in-out;
  }
  .tier-panel.hidden {
    display: none;
  }
</style>

<script is:inline>
  (function() {
    var root = document.getElementById('tier-toggle-root');
    if (!root) return;

    var buttons = root.querySelectorAll('.tier-btn');
    var tier1Panel = document.getElementById('tier-1-content');
    var tier2Panel = document.getElementById('tier-2-content');

    // Tier 1 button active classes
    var t1Active = 'bg-teal text-navy border-teal';
    var t1Inactive = 'bg-white dark:bg-navy text-n500 border-n100 dark:border-navy-light hover:border-n300';
    // Tier 2 button active classes
    var t2Active = 'bg-navy text-white border-navy';
    var t2Inactive = 'bg-white dark:bg-navy text-n500 border-n100 dark:border-navy-light hover:border-n300';

    function setTier(tier) {
      var btn1 = buttons[0];
      var btn2 = buttons[1];

      if (tier === 1) {
        tier1Panel.classList.remove('hidden');
        tier2Panel.classList.add('hidden');
        // Button 1 active
        t1Inactive.split(' ').forEach(function(c) { btn1.classList.remove(c); });
        t1Active.split(' ').forEach(function(c) { btn1.classList.add(c); });
        // Button 2 inactive
        t2Active.split(' ').forEach(function(c) { btn2.classList.remove(c); });
        t2Inactive.split(' ').forEach(function(c) { btn2.classList.add(c); });
      } else {
        tier1Panel.classList.add('hidden');
        tier2Panel.classList.remove('hidden');
        // Button 1 inactive
        t1Active.split(' ').forEach(function(c) { btn1.classList.remove(c); });
        t1Inactive.split(' ').forEach(function(c) { btn1.classList.add(c); });
        // Button 2 active
        t2Inactive.split(' ').forEach(function(c) { btn2.classList.remove(c); });
        t2Active.split(' ').forEach(function(c) { btn2.classList.add(c); });
      }
    }

    buttons.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var tier = parseInt(btn.dataset.tier, 10);
        setTier(tier);
      });
    });
  })();
</script>

---
/**
 * StigmaSwapGame — flashcard-style exercise.
 * 10 cards shuffled with Fisher-Yates on mount.
 * Click to reveal the Playbook-friendly alternative + rationale.
 * Dispatches `exercise-complete` on completion.
 */
---

<div id="stigma-swap-game" class="my-6 rounded-xl border border-n100 dark:border-navy-light bg-white dark:bg-navy shadow-sm overflow-hidden">
  <!-- Header -->
  <div class="bg-navy px-4 py-3 flex items-center justify-between" id="ssg-header">
    <div>
      <span class="text-xs font-heading font-bold uppercase tracking-wider text-teal">Interactive Exercise</span>
      <h3 class="text-white font-heading font-bold text-sm mt-0.5">Stigma-Free Swap Game</h3>
    </div>
    <div class="flex items-center gap-1" id="ssg-dots"></div>
  </div>

  <!-- Card view (shown during exercise) -->
  <div id="ssg-card-view" class="p-4">
    <!-- Card -->
    <div id="ssg-card" class="rounded-lg overflow-hidden border-2 border-danger/20 mb-3">
      <div class="grid grid-cols-[1fr_auto_1fr] items-stretch">
        <!-- Don't write side -->
        <div class="bg-danger/5 px-4 py-3">
          <p class="text-xs font-heading font-semibold uppercase tracking-wider text-danger/70 mb-1">Don't write</p>
          <p class="font-heading font-bold text-navy dark:text-white line-through decoration-danger/40" id="ssg-dont-write"></p>
        </div>

        <!-- Arrow / question mark -->
        <div class="flex items-center px-2 bg-white dark:bg-navy">
          <span id="ssg-arrow" class="text-n300 text-lg font-bold">?</span>
        </div>

        <!-- Write instead side -->
        <div id="ssg-write-instead-panel" class="px-4 py-3 bg-n50 dark:bg-navy-dark/50">
          <button
            id="ssg-reveal-btn"
            class="w-full h-full flex items-center justify-center text-sm font-heading font-semibold text-teal-dark hover:text-teal transition-colors"
          >
            Tap to reveal
          </button>
          <div id="ssg-write-instead-content" class="hidden">
            <p class="text-xs font-heading font-semibold uppercase tracking-wider text-success/70 mb-1">Write instead</p>
            <p class="font-heading font-bold text-navy dark:text-white" id="ssg-write-instead"></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Explanation + Next -->
    <div id="ssg-explanation-row" class="hidden flex items-start gap-3" aria-live="polite" aria-atomic="true">
      <p class="text-sm text-n700 dark:text-n300 leading-relaxed flex-1" id="ssg-explanation"></p>
      <button
        id="ssg-next-btn"
        class="px-4 py-2 bg-teal text-navy font-heading font-semibold rounded-lg hover:bg-teal-light transition-colors text-sm flex-shrink-0"
      >
        Next
      </button>
    </div>
  </div>

  <!-- Completion view (hidden until all 10 done) -->
  <div id="ssg-complete-view" class="hidden p-4 sm:p-5">
    <div class="text-center mb-4">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-success/10 text-success mb-2">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path d="M5 13l4 4L19 7" />
        </svg>
      </div>
      <p class="text-navy dark:text-white font-heading font-bold">All 10 swaps complete</p>
      <p class="text-xs text-n500 dark:text-n400 mt-0.5">Quick-reference summary:</p>
    </div>
    <div class="space-y-1" id="ssg-summary-list"></div>
    <div class="text-center mt-4">
      <button
        id="ssg-replay-btn"
        class="px-5 py-2.5 bg-teal text-navy font-heading font-semibold rounded-lg hover:bg-teal-light transition-colors text-sm"
      >
        Play again
      </button>
    </div>
  </div>
</div>

<script is:inline>
(function () {
  var container = document.getElementById('stigma-swap-game');
  if (!container) return;

  var SWAPS = [
    { id: 1,  dontWrite: 'Problem gambler',        writeInstead: 'Player',                               explanation: '"Player" is inclusive. "Problem gambler" is a diagnostic label.' },
    { id: 2,  dontWrite: 'Responsible gambling',    writeInstead: 'Set a budget / Know the odds / Check your session', explanation: 'Specific actions beat generic labels.' },
    { id: 3,  dontWrite: 'Gambler',                 writeInstead: 'Player',                               explanation: '"Player" emphasizes agency and entertainment.' },
    { id: 4,  dontWrite: 'Gambling addiction',       writeInstead: 'Difficulty with gambling',              explanation: "Lower barrier, non-diagnostic. Describe, don't label." },
    { id: 5,  dontWrite: 'Self-exclude',             writeInstead: 'Take a break / Pause your account',    explanation: '"Pause" is temporary and empowered. "Self-exclude" sounds permanent.' },
    { id: 6,  dontWrite: 'Intervention',             writeInstead: 'Feature / Tool',                       explanation: 'Tools are things you choose to use. Interventions are done to you.' },
    { id: 7,  dontWrite: 'Reality check',            writeInstead: 'Session reminder',                     explanation: '"Reminder" is helpful. "Reality check" implies you\'ve lost touch.' },
    { id: 8,  dontWrite: 'You should',               writeInstead: 'You can',                              explanation: 'Agency framing. "You can" respects choice.' },
    { id: 9,  dontWrite: 'WARNING',                  writeInstead: 'Heads up',                             explanation: 'Conversational, not alarming.' },
    { id: 10, dontWrite: 'Odds are against you',     writeInstead: 'The house edge is [specific number]',  explanation: 'Factual and educational, not alarming.' }
  ];

  var total = SWAPS.length;
  var shuffled = [];
  var currentIndex = 0;
  var revealed = false;

  // DOM refs
  var dotsEl       = document.getElementById('ssg-dots');
  var cardView     = document.getElementById('ssg-card-view');
  var completeView = document.getElementById('ssg-complete-view');
  var cardEl       = document.getElementById('ssg-card');
  var dontWriteEl  = document.getElementById('ssg-dont-write');
  var arrowEl      = document.getElementById('ssg-arrow');
  var revealBtn    = document.getElementById('ssg-reveal-btn');
  var writePanel   = document.getElementById('ssg-write-instead-panel');
  var writeContent = document.getElementById('ssg-write-instead-content');
  var writeEl      = document.getElementById('ssg-write-instead');
  var explRow      = document.getElementById('ssg-explanation-row');
  var explEl       = document.getElementById('ssg-explanation');
  var nextBtn      = document.getElementById('ssg-next-btn');
  var summaryList  = document.getElementById('ssg-summary-list');
  var replayBtn    = document.getElementById('ssg-replay-btn');

  /** Fisher-Yates shuffle */
  function shuffle(arr) {
    var s = arr.slice();
    for (var i = s.length - 1; i > 0; i--) {
      var j = Math.floor(Math.random() * (i + 1));
      var tmp = s[i]; s[i] = s[j]; s[j] = tmp;
    }
    return s;
  }

  function buildDots() {
    dotsEl.innerHTML = '';
    for (var i = 0; i < total; i++) {
      var dot = document.createElement('div');
      dot.className = 'w-2 h-2 rounded-full transition-colors ' +
        (i < currentIndex ? 'bg-success' : (i === currentIndex ? 'bg-teal' : 'bg-navy-light'));
      dotsEl.appendChild(dot);
    }
  }

  function renderCard() {
    var swap = shuffled[currentIndex];
    revealed = false;

    // Reset card styling
    cardEl.className = 'rounded-lg overflow-hidden border-2 border-danger/20 mb-3';
    writePanel.className = 'px-4 py-3 bg-n50 dark:bg-navy-dark/50';

    dontWriteEl.textContent = swap.dontWrite;
    writeEl.textContent = swap.writeInstead;
    explEl.textContent = swap.explanation;

    // Arrow back to question mark
    arrowEl.innerHTML = '';
    arrowEl.className = 'text-n300 text-lg font-bold';
    arrowEl.textContent = '?';

    // Hide write-instead content, show reveal button
    revealBtn.classList.remove('hidden');
    writeContent.classList.add('hidden');

    // Hide explanation row
    explRow.classList.add('hidden');

    // Update next button text
    nextBtn.textContent = currentIndex < total - 1 ? 'Next' : 'Done';

    buildDots();
  }

  function revealCard() {
    if (revealed) return;
    revealed = true;

    // Update card border
    cardEl.className = 'rounded-lg overflow-hidden border-2 border-n100 dark:border-navy-light mb-3';
    writePanel.className = 'px-4 py-3 bg-success/5 dark:bg-success/10';

    // Show arrow SVG
    arrowEl.className = '';
    arrowEl.innerHTML = '<svg class="w-5 h-5 text-teal" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';

    // Swap content
    revealBtn.classList.add('hidden');
    writeContent.classList.remove('hidden');

    // Show explanation row
    explRow.classList.remove('hidden');
  }

  function goNext() {
    if (currentIndex < total - 1) {
      currentIndex++;
      renderCard();
    } else {
      showComplete();
    }
  }

  function showComplete() {
    cardView.classList.add('hidden');
    completeView.classList.remove('hidden');

    // Update header dots to all complete
    dotsEl.innerHTML = '';
    for (var i = 0; i < total; i++) {
      var dot = document.createElement('div');
      dot.className = 'w-2 h-2 rounded-full bg-success';
      dotsEl.appendChild(dot);
    }

    // Build summary list (show in original order)
    summaryList.innerHTML = '';
    for (var i = 0; i < SWAPS.length; i++) {
      var s = SWAPS[i];
      var row = document.createElement('div');
      row.className = 'flex items-center gap-2 py-2 px-2.5 rounded-lg bg-n50/50 dark:bg-navy-dark/30 border border-n100/50 dark:border-navy-light/30';
      row.innerHTML =
        '<span class="text-xs font-heading font-bold text-n400 w-4 flex-shrink-0">' + s.id + '</span>' +
        '<span class="text-xs text-danger line-through flex-1 min-w-0">' + s.dontWrite + '</span>' +
        '<svg class="w-3.5 h-3.5 text-teal flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>' +
        '<span class="text-xs font-semibold text-navy dark:text-white flex-1 min-w-0">' + s.writeInstead + '</span>';
      summaryList.appendChild(row);
    }

    // Dispatch exercise-complete
    window.dispatchEvent(new CustomEvent('exercise-complete'));
  }

  function reset() {
    currentIndex = 0;
    shuffled = shuffle(SWAPS);
    completeView.classList.add('hidden');
    cardView.classList.remove('hidden');
    renderCard();
  }

  // Event listeners
  revealBtn.addEventListener('click', revealCard);

  // Allow clicking the whole card area to reveal
  cardEl.addEventListener('click', function (e) {
    if (!revealed && !e.target.closest('#ssg-reveal-btn')) {
      revealCard();
    }
  });

  nextBtn.addEventListener('click', goNext);
  replayBtn.addEventListener('click', reset);

  // Keyboard: space/enter to reveal or advance
  container.addEventListener('keydown', function (e) {
    if (e.key === ' ' || e.key === 'Enter') {
      if (completeView.classList.contains('hidden')) {
        if (!revealed) {
          e.preventDefault();
          revealCard();
        }
      }
    }
  });

  // Initialize
  reset();
})();
</script>

---
/**
 * ToneMatcher — match messages to tone registers.
 * 5 messages, each with 4 register options.
 * Immediate feedback on selection, score at completion.
 * Dispatches `exercise-complete` on completion.
 */
---

<div id="tone-matcher" class="my-10 rounded-xl border border-n100 dark:border-navy-light bg-white dark:bg-navy shadow-sm overflow-hidden">
  <!-- Header -->
  <div class="bg-navy px-5 py-4 flex items-center justify-between" id="tm-header">
    <div>
      <span class="text-xs font-heading font-bold uppercase tracking-wider text-teal">Interactive Exercise</span>
      <h3 class="text-white font-heading font-bold text-lg mt-0.5">Tone Matcher</h3>
    </div>
    <div class="flex items-center gap-1.5" id="tm-dots"></div>
  </div>

  <!-- Exercise view -->
  <div id="tm-exercise-view" class="p-5 sm:p-6">
    <!-- Progress -->
    <p class="text-sm text-n500 dark:text-n400 font-heading mb-4" id="tm-progress"></p>

    <!-- Message card -->
    <div class="rounded-lg border-2 border-n100 dark:border-navy-light bg-n50/50 dark:bg-navy-dark/50 p-5 mb-5">
      <p class="text-navy dark:text-white font-heading font-semibold text-lg leading-relaxed" id="tm-message"></p>
    </div>

    <!-- Tone buttons -->
    <p class="text-sm font-heading font-semibold text-n700 dark:text-n300 mb-3">What tone register is this?</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-5" id="tm-buttons" role="radiogroup" aria-label="Select the tone register"></div>

    <!-- Feedback -->
    <div id="tm-feedback" class="hidden rounded-lg p-4 mb-5" role="alert" aria-live="polite" aria-atomic="true">
      <p class="font-heading font-semibold text-sm mb-1" id="tm-feedback-label"></p>
      <p class="text-n700 dark:text-n300 text-sm" id="tm-feedback-text"></p>
    </div>

    <!-- Next button -->
    <div class="flex justify-end">
      <button
        id="tm-next-btn"
        class="hidden px-6 py-3 bg-teal text-navy font-heading font-semibold rounded-lg hover:bg-teal-light transition-colors"
      >
        Next message
      </button>
    </div>
  </div>

  <!-- Completion view -->
  <div id="tm-complete-view" class="hidden p-6 sm:p-8 text-center">
    <div id="tm-score-circle" class="inline-flex items-center justify-center w-20 h-20 rounded-full mb-4">
      <span class="text-3xl font-heading font-bold" id="tm-score-num"></span>
    </div>
    <h4 class="text-xl font-heading font-bold text-navy dark:text-white mb-2" id="tm-score-msg"></h4>
    <p class="text-n600 dark:text-n400 text-sm mb-6 max-w-md mx-auto">
      Each register serves a purpose. The voice stays the same &mdash; confident, generous, never preachy. The tone shifts to match the moment.
    </p>
    <button
      id="tm-retry-btn"
      class="px-6 py-3 bg-orange text-navy font-heading font-semibold rounded-lg hover:bg-orange-light transition-colors"
    >
      Try again
    </button>
  </div>
</div>

<script is:inline>
(function () {
  var container = document.getElementById('tone-matcher');
  if (!container) return;

  var MESSAGES = [
    {
      id: 1,
      text: "Every slot spin is independent. The machine doesn\u2019t know \u2014 or care \u2014 what happened last time.",
      correctTone: 'confident',
      explanation: 'Factual, clear, educational. This is the Confident/Informative register \u2014 sharing how the math works without any humor or warmth.'
    },
    {
      id: 2,
      text: "You just set your first deposit limit! That\u2019s you, playing on your own terms.",
      correctTone: 'celebratory',
      explanation: "An achievement moment. The player did something good, and the content acknowledges it with restrained celebration \u2014 not confetti cannons, just genuine recognition."
    },
    {
      id: 3,
      text: "Think you can spot the pattern? Spoiler: there isn\u2019t one. That\u2019s not a bug \u2014 it\u2019s math.",
      correctTone: 'playful',
      explanation: 'The setup-and-twist structure is classic Playful/Witty. It earns attention through humor directed at the misconception, not at the player.'
    },
    {
      id: 4,
      text: "We\u2019re here if you need us. Call, text, or chat \u2014 free, confidential, no judgment.",
      correctTone: 'warm',
      explanation: 'Warm/Direct at its purest. Short sentences, zero humor, maximum clarity. This is the support voice \u2014 present without being pushy.'
    },
    {
      id: 5,
      text: "Quiz time: What does \u2013110 actually mean? (It\u2019s not what most people think.)",
      correctTone: 'playful',
      explanation: "The teasing parenthetical is classic Playful/Witty. It creates curiosity and implies \u2018you might be surprised\u2019 \u2014 earning the click through intrigue, not obligation."
    }
  ];

  var TONES = ['playful', 'confident', 'warm', 'celebratory'];

  var TONE_LABELS = {
    playful:     'Playful / Witty',
    confident:   'Confident / Informative',
    warm:        'Warm / Direct',
    celebratory: 'Celebratory'
  };

  var TONE_COLORS = {
    playful:     { bg: 'bg-orange/10',  border: 'border-orange/30',  hoverBg: 'hover:bg-orange/10',  hoverBorder: 'hover:border-orange/30' },
    confident:   { bg: 'bg-teal/10',    border: 'border-teal/30',    hoverBg: 'hover:bg-teal/10',    hoverBorder: 'hover:border-teal/30' },
    warm:        { bg: 'bg-success/10',  border: 'border-success/30', hoverBg: 'hover:bg-success/10', hoverBorder: 'hover:border-success/30' },
    celebratory: { bg: 'bg-warning/10',  border: 'border-warning/30', hoverBg: 'hover:bg-warning/10', hoverBorder: 'hover:border-warning/30' }
  };

  var total = MESSAGES.length;
  var currentIndex = 0;
  var answers = {};       // messageId -> tone string
  var feedbackShown = false;

  // DOM refs
  var dotsEl       = document.getElementById('tm-dots');
  var exerciseView = document.getElementById('tm-exercise-view');
  var completeView = document.getElementById('tm-complete-view');
  var progressEl   = document.getElementById('tm-progress');
  var messageEl    = document.getElementById('tm-message');
  var buttonsEl    = document.getElementById('tm-buttons');
  var feedbackEl   = document.getElementById('tm-feedback');
  var feedbackLbl  = document.getElementById('tm-feedback-label');
  var feedbackTxt  = document.getElementById('tm-feedback-text');
  var nextBtn      = document.getElementById('tm-next-btn');
  var scoreCircle  = document.getElementById('tm-score-circle');
  var scoreNum     = document.getElementById('tm-score-num');
  var scoreMsg     = document.getElementById('tm-score-msg');
  var retryBtn     = document.getElementById('tm-retry-btn');

  function buildDots() {
    dotsEl.innerHTML = '';
    for (var i = 0; i < total; i++) {
      var dot = document.createElement('div');
      var cls = 'w-2.5 h-2.5 rounded-full transition-colors ';
      if (i < currentIndex) {
        var mid = MESSAGES[i].id;
        cls += (answers[mid] === MESSAGES[i].correctTone) ? 'bg-success' : 'bg-warning';
      } else if (i === currentIndex) {
        cls += 'bg-teal';
      } else {
        cls += 'bg-navy-light';
      }
      dot.className = cls;
      dotsEl.appendChild(dot);
    }
  }

  function renderQuestion() {
    var msg = MESSAGES[currentIndex];
    feedbackShown = false;

    progressEl.textContent = 'Message ' + (currentIndex + 1) + ' of ' + total;
    messageEl.textContent = '\u201C' + msg.text + '\u201D';

    // Build tone buttons
    buttonsEl.innerHTML = '';
    TONES.forEach(function (tone) {
      var btn = document.createElement('button');
      var colors = TONE_COLORS[tone];
      btn.className = 'px-4 py-3 rounded-lg text-sm font-heading font-semibold transition-all cursor-pointer border-2 border-n100 dark:border-navy-light bg-white dark:bg-navy ' + colors.hoverBg + ' ' + colors.hoverBorder;
      btn.textContent = TONE_LABELS[tone];
      btn.dataset.tone = tone;
      btn.addEventListener('click', function () { handleSelect(tone); });
      buttonsEl.appendChild(btn);
    });

    // Hide feedback and next
    feedbackEl.classList.add('hidden');
    nextBtn.classList.add('hidden');

    buildDots();
  }

  function handleSelect(tone) {
    if (feedbackShown) return;
    feedbackShown = true;

    var msg = MESSAGES[currentIndex];
    answers[msg.id] = tone;
    var isCorrect = tone === msg.correctTone;

    // Update button styles
    var btns = buttonsEl.querySelectorAll('button');
    btns.forEach(function (btn) {
      var t = btn.dataset.tone;
      var colors = TONE_COLORS[t];
      btn.style.cursor = 'default';

      if (t === msg.correctTone) {
        btn.className = 'px-4 py-3 rounded-lg text-sm font-heading font-semibold transition-all cursor-default border-2 ' + colors.border + ' ' + colors.bg;
      } else if (t === tone && !isCorrect) {
        btn.className = 'px-4 py-3 rounded-lg text-sm font-heading font-semibold transition-all cursor-default border-2 border-warning/40 bg-warning/5';
      } else {
        btn.className = 'px-4 py-3 rounded-lg text-sm font-heading font-semibold transition-all cursor-default border-2 border-n100 dark:border-navy-light bg-white dark:bg-navy opacity-50';
      }
    });

    // Show feedback
    feedbackEl.classList.remove('hidden');
    if (isCorrect) {
      feedbackEl.className = 'rounded-lg p-4 mb-5 bg-success/10 border border-success/20';
      feedbackLbl.textContent = 'Nailed it.';
      feedbackLbl.className = 'font-heading font-semibold text-sm mb-1 text-success';
    } else {
      feedbackEl.className = 'rounded-lg p-4 mb-5 bg-warning/10 border border-warning/20';
      feedbackLbl.textContent = 'Not quite \u2014 this is ' + TONE_LABELS[msg.correctTone] + '.';
      feedbackLbl.className = 'font-heading font-semibold text-sm mb-1 text-warning';
    }
    feedbackTxt.textContent = msg.explanation;

    // Show next button
    nextBtn.classList.remove('hidden');
    nextBtn.textContent = currentIndex < total - 1 ? 'Next message' : 'See results';

    buildDots();
  }

  function goNext() {
    if (currentIndex < total - 1) {
      currentIndex++;
      renderQuestion();
    } else {
      showComplete();
    }
  }

  function countCorrect() {
    var c = 0;
    for (var i = 0; i < total; i++) {
      if (answers[MESSAGES[i].id] === MESSAGES[i].correctTone) c++;
    }
    return c;
  }

  function getScoreMessage(correct) {
    if (correct === total) return "Perfect score. You've got the voice down cold.";
    if (correct >= 4) return correct + '/' + total + " \u2014 you've got an ear for this.";
    if (correct >= 3) return correct + '/' + total + " \u2014 solid. A few more rounds and you'll nail it.";
    return correct + '/' + total + " \u2014 the registers take practice. Review the tone spectrum and try again.";
  }

  function showComplete() {
    exerciseView.classList.add('hidden');
    completeView.classList.remove('hidden');

    var correct = countCorrect();
    scoreNum.textContent = correct + '/' + total;

    if (correct === total) {
      scoreCircle.className = 'inline-flex items-center justify-center w-20 h-20 rounded-full mb-4 bg-success/10 text-success';
    } else {
      scoreCircle.className = 'inline-flex items-center justify-center w-20 h-20 rounded-full mb-4 bg-teal/10 text-teal-dark';
    }

    scoreMsg.textContent = getScoreMessage(correct);

    // Update dots to all answered
    buildDots();

    // Dispatch exercise-complete
    window.dispatchEvent(new CustomEvent('exercise-complete'));
  }

  function reset() {
    currentIndex = 0;
    answers = {};
    feedbackShown = false;
    completeView.classList.add('hidden');
    exerciseView.classList.remove('hidden');
    renderQuestion();
  }

  // Event listeners
  nextBtn.addEventListener('click', goNext);
  retryBtn.addEventListener('click', reset);

  // Initialize
  reset();
})();
</script>

---
import Exercise from '../Exercise.astro';

interface RubricItem {
  label: string;
  description: string;
}

interface Props {
  title: string;
  prompt: string;
  placeholder?: string;
  rubric: RubricItem[];
  modelAnswer: string;
}

const {
  title,
  prompt,
  placeholder = 'Write your response here...',
  rubric,
  modelAnswer,
} = Astro.props;

const storageKey = `playbook-exercise-${title.replace(/\s+/g, '-').toLowerCase()}`;
---

<Exercise
  name={title}
  type="Writing Exercise"
  instructions="Write a response that meets the minimum word count, then self-evaluate against the rubric criteria."
>
  <div
    id="gen-exercise"
    data-storage-key={storageKey}
    data-rubric={JSON.stringify(rubric)}
    data-model-answer={modelAnswer}
  >
    <!-- Prompt -->
    <p class="font-heading font-semibold text-navy dark:text-white mb-4">{prompt}</p>

    <!-- Textarea -->
    <textarea
      id="gen-textarea"
      rows={5}
      placeholder={placeholder}
      class="w-full rounded-lg border-2 border-n100 dark:border-navy-light bg-white dark:bg-navy-dark p-4 text-sm leading-relaxed font-body text-n900 dark:text-n200 resize-y transition-colors focus:border-teal focus:ring-1 focus:ring-teal/30 focus:outline-none"
      aria-label={prompt}
    ></textarea>

    <!-- Word count + submit -->
    <div class="flex items-center justify-between mt-2 mb-5">
      <span id="gen-wordcount" class="text-xs font-heading text-n400">
        0 / 30 words minimum
      </span>
      <button
        id="gen-submit"
        disabled
        class="px-5 py-2.5 bg-navy text-white font-heading font-semibold rounded-lg hover:bg-navy-light transition-colors disabled:opacity-40 disabled:cursor-not-allowed text-sm"
      >
        Submit &amp; self-evaluate
      </button>
    </div>

    <!-- Self-evaluation rubric (hidden until submit) -->
    <div id="gen-rubric-section" class="hidden" aria-live="polite">
      <div class="rounded-lg border border-n100 dark:border-navy-light p-5 mb-5">
        <p class="font-heading font-semibold text-navy dark:text-white text-sm mb-3">
          Self-evaluate your response:
        </p>
        <div id="gen-rubric-list" class="space-y-3">
          {rubric.map((item, i) => (
            <label class="flex items-start gap-3 cursor-pointer group">
              <input
                type="checkbox"
                data-rubric-index={i}
                class="gen-rubric-check mt-0.5 w-5 h-5 rounded border-2 border-n300 text-teal accent-[#00D4AA] flex-shrink-0"
              />
              <div>
                <span class="text-sm font-heading font-semibold text-navy dark:text-white block">
                  {item.label}
                </span>
                <span class="text-xs text-n500 dark:text-n400">{item.description}</span>
              </div>
            </label>
          ))}
        </div>

        <!-- Criteria score -->
        <div class="mt-4 pt-3 border-t border-n100 dark:border-navy-light flex items-center justify-between">
          <span id="gen-criteria-count" class="text-sm font-heading text-n500 dark:text-n400">
            0 of {rubric.length} criteria met
          </span>
          <span id="gen-all-met" class="hidden text-sm font-heading font-bold text-teal">
            All criteria met.
          </span>
        </div>
      </div>

      <!-- Model answer toggle -->
      <div class="mb-4">
        <button
          id="gen-model-toggle"
          class="inline-flex items-center gap-2 text-sm font-heading font-semibold text-navy-light dark:text-n300 hover:text-navy dark:hover:text-white transition-colors"
          aria-expanded="false"
        >
          <svg id="gen-model-arrow" class="w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
          Compare with model answer
        </button>

        <div id="gen-model-content" class="hidden mt-3 rounded-lg bg-teal/5 border border-teal/20 p-4">
          <p class="text-xs font-heading font-bold uppercase tracking-wider text-teal mb-2">
            Model Answer
          </p>
          <p class="text-sm text-n700 dark:text-n300 leading-relaxed whitespace-pre-line">{modelAnswer}</p>
        </div>
      </div>

      <!-- Retry -->
      <button
        id="gen-retry"
        class="text-sm font-heading font-semibold text-n500 hover:text-navy dark:hover:text-white transition-colors"
      >
        Try again with a different approach
      </button>
    </div>
  </div>
</Exercise>

<script is:inline>
  (function() {
    var container = document.getElementById('gen-exercise');
    if (!container) return;

    var storageKey = container.dataset.storageKey;
    var rubricData = JSON.parse(container.dataset.rubric || '[]');
    var rubricLen = rubricData.length;
    var MIN_WORDS = 30;

    var textarea = document.getElementById('gen-textarea');
    var wordcountEl = document.getElementById('gen-wordcount');
    var submitBtn = document.getElementById('gen-submit');
    var rubricSection = document.getElementById('gen-rubric-section');
    var criteriaCount = document.getElementById('gen-criteria-count');
    var allMetEl = document.getElementById('gen-all-met');
    var modelToggle = document.getElementById('gen-model-toggle');
    var modelArrow = document.getElementById('gen-model-arrow');
    var modelContent = document.getElementById('gen-model-content');
    var retryBtn = document.getElementById('gen-retry');
    var checks = container.querySelectorAll('.gen-rubric-check');

    var submitted = false;
    var exerciseDispatched = false;
    var modelShown = false;

    // Restore draft from localStorage
    try {
      var draft = localStorage.getItem(storageKey);
      if (draft && textarea) textarea.value = draft;
    } catch (e) {}

    function countWords(str) {
      return str.trim().split(/\s+/).filter(Boolean).length;
    }

    function updateWordCount() {
      var wc = countWords(textarea.value);
      if (wordcountEl) {
        wordcountEl.textContent = wc + ' / ' + MIN_WORDS + ' words minimum';
        wordcountEl.className = 'text-xs font-heading ' + (wc >= MIN_WORDS ? 'text-success' : 'text-n400');
      }
      if (submitBtn && !submitted) {
        submitBtn.disabled = wc < MIN_WORDS;
      }
    }

    function saveDraft() {
      if (submitted) return;
      try { localStorage.setItem(storageKey, textarea.value); } catch (e) {}
    }

    function checkCompletion() {
      var checked = 0;
      checks.forEach(function(cb) { if (cb.checked) checked++; });
      if (criteriaCount) criteriaCount.textContent = checked + ' of ' + rubricLen + ' criteria met';
      if (allMetEl) {
        if (checked === rubricLen) {
          allMetEl.classList.remove('hidden');
        } else {
          allMetEl.classList.add('hidden');
        }
      }
      if (checked === rubricLen && !exerciseDispatched) {
        exerciseDispatched = true;
        window.dispatchEvent(new CustomEvent('exercise-complete'));
      }
    }

    // Event listeners
    if (textarea) {
      textarea.addEventListener('input', function() {
        updateWordCount();
        saveDraft();
      });
    }

    if (submitBtn) {
      submitBtn.addEventListener('click', function() {
        if (countWords(textarea.value) < MIN_WORDS) return;
        submitted = true;
        textarea.disabled = true;
        textarea.classList.remove('focus:border-teal', 'focus:ring-1', 'focus:ring-teal/30');
        textarea.classList.add('bg-n50', 'dark:bg-navy-dark/50', 'cursor-default');
        submitBtn.classList.add('hidden');
        rubricSection.classList.remove('hidden');
      });
    }

    checks.forEach(function(cb) {
      cb.addEventListener('change', checkCompletion);
    });

    if (modelToggle) {
      modelToggle.addEventListener('click', function() {
        modelShown = !modelShown;
        if (modelShown) {
          modelContent.classList.remove('hidden');
          modelArrow.classList.add('rotate-90');
          modelToggle.setAttribute('aria-expanded', 'true');
          modelToggle.childNodes[modelToggle.childNodes.length - 1].textContent = ' Hide model answer';
        } else {
          modelContent.classList.add('hidden');
          modelArrow.classList.remove('rotate-90');
          modelToggle.setAttribute('aria-expanded', 'false');
          modelToggle.childNodes[modelToggle.childNodes.length - 1].textContent = ' Compare with model answer';
        }
      });
    }

    if (retryBtn) {
      retryBtn.addEventListener('click', function() {
        submitted = false;
        exerciseDispatched = false;
        modelShown = false;
        textarea.value = '';
        textarea.disabled = false;
        textarea.classList.remove('bg-n50', 'dark:bg-navy-dark/50', 'cursor-default');
        textarea.classList.add('focus:border-teal', 'focus:ring-1', 'focus:ring-teal/30');
        submitBtn.classList.remove('hidden');
        rubricSection.classList.add('hidden');
        modelContent.classList.add('hidden');
        modelArrow.classList.remove('rotate-90');
        modelToggle.setAttribute('aria-expanded', 'false');
        checks.forEach(function(cb) { cb.checked = false; });
        try { localStorage.removeItem(storageKey); } catch (e) {}
        updateWordCount();
      });
    }

    // Initial word count (in case draft was restored)
    updateWordCount();
  })();
</script>

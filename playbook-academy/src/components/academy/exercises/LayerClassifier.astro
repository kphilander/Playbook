---
/**
 * LayerClassifier — Astro exercise component (no React)
 * Presents 10 scenarios one at a time; learner classifies each into
 * Compliance, Public Health, or Informed Choice.
 * Fisher-Yates shuffle on mount. 80% pass threshold.
 * All data is hardcoded; no props required.
 */
---

<div class="exercise-wrapper" id="lc-root">
  <!-- Header -->
  <div class="exercise-header flex items-center justify-between">
    <div class="flex items-center gap-3 flex-wrap">
      <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 bg-teal/20 text-teal rounded-full text-xs font-heading font-bold uppercase tracking-wider">
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Interactive Exercise
      </span>
      <h3 class="text-white font-heading font-bold text-lg m-0" id="lc-heading">Layer Classifier</h3>
    </div>
    <span class="text-sm font-heading text-white/60" id="lc-counter">1 of 10</span>
  </div>

  <!-- Active quiz view -->
  <div class="p-5 sm:p-6" id="lc-quiz">
    <!-- Progress dots -->
    <div class="flex gap-1.5 mb-5" id="lc-dots"></div>

    <!-- Scenario card -->
    <div class="bg-n50 rounded-lg p-5 mb-6 border border-n100" id="lc-scenario-card">
      <p class="text-n900 text-[0.95rem] leading-relaxed" id="lc-scenario-text"></p>
    </div>

    <!-- Prompt -->
    <p class="font-heading font-semibold text-n700 text-sm mb-3">Which layer does this belong to?</p>

    <!-- Layer buttons -->
    <div class="grid sm:grid-cols-3 gap-3 mb-5" id="lc-buttons">
      <button class="lc-btn" data-layer="compliance">
        <span class="lc-dot bg-navy"></span>
        Compliance (Floor)
      </button>
      <button class="lc-btn" data-layer="public-health">
        <span class="lc-dot bg-orange"></span>
        Public Health (Population)
      </button>
      <button class="lc-btn" data-layer="informed-choice">
        <span class="lc-dot bg-teal"></span>
        Informed Choice (Individual)
      </button>
    </div>

    <!-- Feedback area -->
    <div id="lc-feedback" class="hidden mb-5" aria-live="polite" aria-atomic="true"></div>

    <!-- Next button -->
    <div class="flex justify-end" id="lc-next-wrap" style="display:none;">
      <button id="lc-next" class="px-5 py-2 bg-navy text-white text-sm font-heading font-semibold rounded-lg hover:bg-navy-light transition-colors">
        Next scenario
      </button>
    </div>

    <!-- Skip -->
    <button id="lc-skip" class="mt-3 text-xs text-n400 hover:text-n600 transition-colors underline">
      Skip exercise &mdash; continue audio
    </button>
  </div>

  <!-- Results view (hidden initially) -->
  <div class="p-6 sm:p-8 text-center hidden" id="lc-results">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full mb-4" id="lc-result-circle">
      <span class="text-3xl font-heading font-bold" id="lc-result-score"></span>
    </div>
    <h4 class="text-xl font-heading font-bold text-navy mb-2" id="lc-result-title"></h4>
    <p class="text-n700 mb-6 max-w-md mx-auto" id="lc-result-body"></p>
    <button id="lc-restart" class="px-6 py-3 bg-teal text-navy font-heading font-semibold rounded-lg hover:bg-teal-light transition-colors">
      Run it again
    </button>
  </div>
</div>

<style>
  .lc-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    transition: all 0.2s;
    border: 2px solid #E8E8F0;
    background: white;
    color: #1B2838;
    cursor: pointer;
    text-align: left;
  }
  .lc-btn:hover:not(:disabled) {
    border-color: #00D4AA;
    background: rgba(0, 212, 170, 0.05);
  }
  .lc-btn:disabled { cursor: default; }
  .lc-btn.correct {
    border-color: #00C853;
    background: rgba(0, 200, 83, 0.1);
    color: #00C853;
  }
  .lc-btn.incorrect {
    border-color: #FF9800;
    background: rgba(255, 152, 0, 0.1);
    color: #FF9800;
  }
  .lc-btn.dimmed {
    border-color: #E8E8F0;
    background: white;
    opacity: 0.5;
    color: #9CA3AF;
  }
  .lc-btn.dimmed .lc-dot { background: #9CA3AF !important; }
  .lc-btn.correct .lc-dot { background: #00C853 !important; }
  .lc-btn.incorrect .lc-dot { background: #FF9800 !important; }
  .lc-dot {
    display: inline-block;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 9999px;
    margin-right: 0.5rem;
    flex-shrink: 0;
  }
  @keyframes lc-fade-in {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .lc-animate { animation: lc-fade-in 0.25s ease-out; }
</style>

<script is:inline>
  (function () {
    var root = document.getElementById('lc-root');
    if (!root) return;

    var SCENARIOS = [
      { id: 1, text: 'An operator is required by law to display a helpline number on all marketing materials.', correctLayer: 'compliance', explanation: 'This is a legal requirement \u2014 the compliance floor. Every operator must do this regardless of their approach to player education.' },
      { id: 2, text: 'A regulator publishes population-level data showing that problem gambling prevalence has increased from 0.7% to 1.1% over five years.', correctLayer: 'public-health', explanation: 'Population-level prevalence data is a public health lens \u2014 looking at harm across the entire population, not individual players.' },
      { id: 3, text: 'An operator creates a quiz showing players how parlay odds compound, helping them understand why parlays rarely pay out.', correctLayer: 'informed-choice', explanation: 'Teaching players how the math works so they can make better decisions \u2014 that\u2019s Informed Choice. Equipping the individual with information.' },
      { id: 4, text: 'A jurisdiction mandates that all online gambling sites must offer self-exclusion options.', correctLayer: 'compliance', explanation: 'Mandatory self-exclusion is regulatory compliance \u2014 the floor that every operator must meet.' },
      { id: 5, text: 'A research organization runs a national awareness campaign about gambling harm during Responsible Gambling Week.', correctLayer: 'public-health', explanation: 'A national awareness campaign targeting the general population is public health \u2014 addressing prevalence and awareness at the population level.' },
      { id: 6, text: 'A sports betting app shows users their win/loss history with a monthly summary email, framing it as \u201Cyour entertainment spending.\u201D', correctLayer: 'informed-choice', explanation: 'Helping individual players see their actual spending patterns and framing gambling as an entertainment cost \u2014 that\u2019s Informed Choice in action.' },
      { id: 7, text: 'New legislation requires operators to verify customer age and identity before allowing any gambling activity.', correctLayer: 'compliance', explanation: 'Age and identity verification is fundamental regulatory compliance \u2014 the absolute floor.' },
      { id: 8, text: 'A government funds research into the relationship between gambling advertising volume and youth gambling initiation rates.', correctLayer: 'public-health', explanation: 'Studying the population-level impact of advertising on a demographic group is public health research.' },
      { id: 9, text: 'An operator adds a \u201CHow Slots Actually Work\u201D article to their content hub, explaining RNG and house edge in plain language.', correctLayer: 'informed-choice', explanation: 'Product education that helps players understand game mechanics \u2014 classic Informed Choice. Information that enables rational decision-making.' },
      { id: 10, text: 'A regulator sets maximum stake limits on fixed-odds betting terminals.', correctLayer: 'compliance', explanation: 'Mandatory stake limits set by the regulator are compliance \u2014 a regulatory constraint all operators must follow.' }
    ];

    // Fisher-Yates shuffle
    function shuffle(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
      }
      return a;
    }

    var scenarios = shuffle(SCENARIOS);
    var currentIndex = 0;
    var results = [];        // array of booleans
    var submitted = false;
    var selectedLayer = null;
    var exerciseDispatched = false;

    var heading = document.getElementById('lc-heading');
    var counter = document.getElementById('lc-counter');
    var dotsEl = document.getElementById('lc-dots');
    var scenarioText = document.getElementById('lc-scenario-text');
    var buttonsWrap = document.getElementById('lc-buttons');
    var buttons = buttonsWrap.querySelectorAll('.lc-btn');
    var feedbackEl = document.getElementById('lc-feedback');
    var nextWrap = document.getElementById('lc-next-wrap');
    var nextBtn = document.getElementById('lc-next');
    var skipBtn = document.getElementById('lc-skip');
    var quizView = document.getElementById('lc-quiz');
    var resultsView = document.getElementById('lc-results');
    var resultCircle = document.getElementById('lc-result-circle');
    var resultScore = document.getElementById('lc-result-score');
    var resultTitle = document.getElementById('lc-result-title');
    var resultBody = document.getElementById('lc-result-body');
    var restartBtn = document.getElementById('lc-restart');

    var TOTAL = scenarios.length;

    function buildDots() {
      dotsEl.innerHTML = '';
      for (var i = 0; i < TOTAL; i++) {
        var dot = document.createElement('div');
        dot.className = 'h-1.5 flex-1 rounded-full transition-colors ';
        if (i < results.length) {
          dot.className += results[i] ? 'bg-success' : 'bg-warning';
        } else if (i === currentIndex) {
          dot.className += 'bg-navy';
        } else {
          dot.className += 'bg-n100';
        }
        dotsEl.appendChild(dot);
      }
    }

    function resetButtons() {
      for (var b = 0; b < buttons.length; b++) {
        var btn = buttons[b];
        btn.disabled = false;
        btn.className = 'lc-btn';
        // Restore original dot color
        var dot = btn.querySelector('.lc-dot');
        var layer = btn.getAttribute('data-layer');
        if (layer === 'compliance') dot.className = 'lc-dot bg-navy';
        else if (layer === 'public-health') dot.className = 'lc-dot bg-orange';
        else dot.className = 'lc-dot bg-teal';
      }
    }

    function renderQuiz() {
      var sc = scenarios[currentIndex];
      counter.textContent = (currentIndex + 1) + ' of ' + TOTAL;
      heading.textContent = 'Layer Classifier';
      scenarioText.textContent = sc.text;

      buildDots();
      resetButtons();

      feedbackEl.classList.add('hidden');
      feedbackEl.innerHTML = '';
      nextWrap.style.display = 'none';
      submitted = false;
      selectedLayer = null;
    }

    function showFeedback(correct, explanation) {
      feedbackEl.classList.remove('hidden');
      feedbackEl.className = 'mb-5 p-4 rounded-lg lc-animate ' +
        (correct ? 'bg-success/10 border border-success/20' : 'bg-warning/10 border border-warning/20');
      feedbackEl.innerHTML =
        '<p class="font-heading font-semibold text-sm mb-1" style="color:' + (correct ? 'var(--color-success,#00C853)' : 'var(--color-warning,#FF9800)') + '">' +
        (correct ? 'Exactly.' : 'Not quite.') + '</p>' +
        '<p class="text-n700 text-sm leading-relaxed">' + escapeHtml(explanation) + '</p>';
    }

    function escapeHtml(str) {
      var d = document.createElement('div');
      d.textContent = str;
      return d.innerHTML;
    }

    function handleSelect(layer) {
      if (submitted) return;
      submitted = true;
      selectedLayer = layer;

      var sc = scenarios[currentIndex];
      var correct = layer === sc.correctLayer;
      results.push(correct);

      // Style buttons
      for (var b = 0; b < buttons.length; b++) {
        var btn = buttons[b];
        var bLayer = btn.getAttribute('data-layer');
        btn.disabled = true;
        if (bLayer === sc.correctLayer) {
          btn.className = 'lc-btn correct';
        } else if (bLayer === layer && !correct) {
          btn.className = 'lc-btn incorrect';
        } else {
          btn.className = 'lc-btn dimmed';
        }
      }

      showFeedback(correct, sc.explanation);
      buildDots();

      // Show next button
      nextWrap.style.display = 'flex';
      nextBtn.textContent = currentIndex < TOTAL - 1 ? 'Next scenario' : 'See results';
    }

    function showResults() {
      quizView.classList.add('hidden');
      resultsView.classList.remove('hidden');

      var correctCount = 0;
      for (var i = 0; i < results.length; i++) { if (results[i]) correctCount++; }
      var pct = Math.round((correctCount / TOTAL) * 100);
      var passed = pct >= 80;

      heading.textContent = 'Layer Classifier \u2014 Results';
      counter.textContent = '';

      resultCircle.className = 'inline-flex items-center justify-center w-20 h-20 rounded-full mb-4 ' +
        (passed ? 'bg-success/10 text-success' : 'bg-warning/10 text-warning');
      resultScore.textContent = correctCount + '/' + TOTAL;
      resultTitle.textContent = passed ? 'You know your layers.' : 'Getting there.';

      if (passed) {
        resultBody.textContent = correctCount + ' out of ' + TOTAL + ' classified correctly (' + pct + '%). You can tell the floor from the ceiling \u2014 and that matters for every content decision.';
      } else {
        resultBody.textContent = correctCount + ' out of ' + TOTAL + ' classified correctly (' + pct + '%). Review the three layers above and give it another run \u2014 the distinctions get clearer with practice.';
      }

      restartBtn.textContent = passed ? 'Run it again' : 'Try again';

      // Dispatch completion
      if (!exerciseDispatched) {
        exerciseDispatched = true;
        window.dispatchEvent(new CustomEvent('exercise-complete'));
      }
    }

    // Button clicks
    for (var b = 0; b < buttons.length; b++) {
      buttons[b].addEventListener('click', function () {
        handleSelect(this.getAttribute('data-layer'));
      });
    }

    // Next
    nextBtn.addEventListener('click', function () {
      if (currentIndex < TOTAL - 1) {
        currentIndex++;
        renderQuiz();
      } else {
        showResults();
      }
    });

    // Restart
    restartBtn.addEventListener('click', function () {
      scenarios = shuffle(SCENARIOS);
      currentIndex = 0;
      results = [];
      submitted = false;
      selectedLayer = null;
      exerciseDispatched = false;
      resultsView.classList.add('hidden');
      quizView.classList.remove('hidden');
      renderQuiz();
    });

    // Skip
    skipBtn.addEventListener('click', function () {
      window.dispatchEvent(new CustomEvent('exercise-complete'));
    });

    // Init
    renderQuiz();
  })();
</script>

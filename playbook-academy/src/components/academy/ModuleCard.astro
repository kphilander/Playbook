---
interface Props {
  href: string;
  moduleSlug: string;
  moduleNumber: number;
  title: string;
  description: string;
  duration: number;
  color?: string;
}

const { href, moduleSlug, moduleNumber, title, description, duration, color = 'teal' } = Astro.props;

const colorMap: Record<string, { bg: string; text: string; bar: string }> = {
  teal: { bg: 'bg-teal/10', text: 'text-teal-dark', bar: 'bg-teal' },
  orange: { bg: 'bg-orange/10', text: 'text-orange-dark', bar: 'bg-orange' },
  info: { bg: 'bg-info/10', text: 'text-info', bar: 'bg-info' },
};
const colors = colorMap[color] || colorMap.teal;
---

<a href={href} data-module-card={moduleSlug}
   class="group block rounded-xl border border-n100 bg-white dark:bg-navy dark:border-navy-light shadow-sm hover:shadow-md transition-all overflow-hidden">
  <div class="p-6">
    <div class="flex items-center justify-between mb-3">
      <div class="flex items-center gap-3">
        <span class={`w-10 h-10 rounded-lg ${colors.bg} ${colors.text} flex items-center justify-center font-heading font-bold text-lg`}>
          {moduleNumber + 1}
        </span>
        <span class="text-xs font-heading font-semibold uppercase tracking-wider text-n500 dark:text-n300">Module {moduleNumber + 1}</span>
      </div>
      <span class="text-sm text-n500 dark:text-n300 font-heading">{duration} min</span>
    </div>
    <h3 class="text-xl font-heading font-bold text-navy dark:text-white mb-2">{title}</h3>
    <p class="text-n700 dark:text-n300 text-sm leading-relaxed">{description}</p>
  </div>
  <div class="px-6 pb-0 hidden" data-module-progress={moduleSlug}>
    <div class="flex items-center justify-between mb-1.5">
      <span class="text-xs text-n500 font-heading" data-progress-label></span>
      <span class="text-xs text-n400 font-heading" data-progress-pct></span>
    </div>
    <div class="progress-bar-track">
      <div class={`progress-bar-fill ${colors.bar}`} data-progress-bar style="width: 0%"></div>
    </div>
  </div>
  <div class="px-6 py-3 bg-n50 dark:bg-navy-dark border-t border-n100 dark:border-navy-light flex items-center justify-between mt-4">
    <span class="text-sm text-n500 dark:text-n300 font-heading" data-module-cta>Start module</span>
    <svg class="w-5 h-5 text-n300 group-hover:text-teal transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>

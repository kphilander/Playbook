---
interface ModuleInfo {
  slug: string;
  title: string;
  href: string;
}

interface Props {
  programId: string;
  modules: ModuleInfo[];
}

const { programId, modules } = Astro.props;
---

<div
  id="continue-banner"
  class="hidden"
  data-program-id={programId}
  data-modules={JSON.stringify(modules)}
  role="complementary"
  aria-label="Continue learning"
>
  <div class="bg-navy border border-navy-light rounded-xl shadow-lg overflow-hidden mb-8 animate-fade-in">
    <div class="flex items-center gap-4 px-5 py-4">
      <!-- Icon -->
      <div class="flex-shrink-0 w-10 h-10 rounded-full bg-teal/20 flex items-center justify-center">
        <svg class="w-5 h-5 text-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>

      <!-- Text -->
      <div class="flex-1 min-w-0">
        <p class="text-xs font-heading font-semibold uppercase tracking-wider text-teal mb-0.5">Continue where you left off</p>
        <p class="text-white font-heading font-bold text-sm truncate" id="continue-module-title"></p>
      </div>

      <!-- Action -->
      <a
        id="continue-link"
        href="#"
        class="flex-shrink-0 inline-flex items-center gap-1.5 px-4 py-2 bg-teal text-navy text-sm font-heading font-semibold rounded-lg hover:bg-teal-dark transition-colors focus:outline-none focus:ring-2 focus:ring-teal focus:ring-offset-2 focus:ring-offset-navy"
      >
        Continue
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>

    <!-- Progress hint bar -->
    <div class="h-1 bg-navy-light">
      <div id="continue-progress-bar" class="h-full bg-teal/50 transition-[width] duration-500" style="width: 0%"></div>
    </div>
  </div>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(-8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.3s ease-out forwards;
  }
</style>

<script is:inline>
  (function() {
    var banner = document.getElementById('continue-banner');
    if (!banner) return;

    var programId = banner.dataset.programId;
    var modules = JSON.parse(banner.dataset.modules || '[]');
    if (!programId || !modules.length) return;

    try {
      var storageKey = 'playbook-academy-' + programId;
      var progress = JSON.parse(localStorage.getItem(storageKey) || '{}');

      // Find the last-accessed module
      var lastSlug = null;
      var lastTime = '';
      for (var slug in progress) {
        if (progress[slug].lastAccessed && progress[slug].lastAccessed > lastTime) {
          // Only show if not yet completed
          if (!progress[slug].completed) {
            lastSlug = slug;
            lastTime = progress[slug].lastAccessed;
          }
        }
      }

      if (!lastSlug) return;

      // Find matching module info
      var mod = null;
      for (var i = 0; i < modules.length; i++) {
        if (modules[i].slug === lastSlug) {
          mod = modules[i];
          break;
        }
      }

      if (!mod) return;

      // Calculate progress percentage for this module
      var modProgress = progress[lastSlug];
      var pct = 0;
      if (modProgress && modProgress.totalLessons > 0) {
        pct = Math.round((modProgress.completedLessons.length / modProgress.totalLessons) * 100);
      }

      // Show banner
      var titleEl = document.getElementById('continue-module-title');
      var linkEl = document.getElementById('continue-link');
      var barEl = document.getElementById('continue-progress-bar');

      if (titleEl) titleEl.textContent = mod.title;
      if (linkEl) linkEl.href = mod.href;
      if (barEl) {
        // Animate after a short delay for visual effect
        setTimeout(function() {
          barEl.style.width = pct + '%';
        }, 300);
      }

      banner.classList.remove('hidden');
    } catch (e) {
      // Silent fail -- banner stays hidden
    }
  })();
</script>

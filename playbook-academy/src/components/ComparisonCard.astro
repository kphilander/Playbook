---
interface Props {
  beforeLabel?: string;
  afterLabel?: string;
}

const { beforeLabel = 'Before', afterLabel = 'After' } = Astro.props;
---

<div class="my-6 grid grid-cols-1 md:grid-cols-2 gap-4">
  <div class="rounded-xl border-2 border-orange/30 bg-orange/5 p-5">
    <span class="inline-block text-xs font-heading font-bold uppercase tracking-wider text-orange-dark bg-orange/10 px-2 py-0.5 rounded mb-3">
      {beforeLabel}
    </span>
    <div class="text-n700 text-[0.95rem] leading-relaxed [&>p]:mb-2 [&>p:last-child]:mb-0">
      <slot name="before" />
    </div>
  </div>
  <div class="rounded-xl border-2 border-teal/30 bg-teal/5 p-5">
    <span class="inline-block text-xs font-heading font-bold uppercase tracking-wider text-teal-dark bg-teal/10 px-2 py-0.5 rounded mb-3">
      {afterLabel}
    </span>
    <div class="text-n700 text-[0.95rem] leading-relaxed [&>p]:mb-2 [&>p:last-child]:mb-0">
      <slot name="after" />
    </div>
  </div>
</div>

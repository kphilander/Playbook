---
/**
 * Glossary tooltip component for technical terms and abbreviations.
 * Renders an <abbr> tag with a hover tooltip showing the definition.
 *
 * Usage:
 *   <Glossary term="RG" definition="Responsible Gambling" />
 *   <Glossary term="RTP" definition="Return to Player — the theoretical percentage of wagered money a game pays back over time" />
 */

interface Props {
  term: string;
  definition: string;
}

const { term, definition } = Astro.props;
---

<abbr
  title={definition}
  tabindex="0"
  class="glossary-term no-underline border-b border-dotted border-n400 cursor-help relative group"
>
  {term}<span class="glossary-tooltip invisible group-hover:visible group-focus-within:visible focus-within:visible opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition-opacity duration-150 absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-2 text-xs text-white bg-navy rounded-lg shadow-lg whitespace-nowrap max-w-xs z-50 font-normal not-italic pointer-events-none" role="tooltip">
    <span class="block font-heading font-semibold text-teal mb-0.5">{term}</span>
    {definition}
    <span class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-navy"></span>
  </span>
</abbr>

---
interface Props {
  value: string;
  label: string;
  source?: string;
}

const { value, label, source } = Astro.props;
---

<div class="my-6 flex items-center gap-5 p-5 rounded-xl bg-navy text-white">
  <span class="flex-shrink-0 text-4xl sm:text-5xl font-heading font-extrabold text-teal leading-none">
    {value}
  </span>
  <div>
    <p class="text-white/90 text-[0.95rem] leading-snug">{label}</p>
    {source && <p class="text-white/50 text-xs mt-1">{source}</p>}
  </div>
</div>
